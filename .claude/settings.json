      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(ps:*)",
      "Bash(touch:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)"
