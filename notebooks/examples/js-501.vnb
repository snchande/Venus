='168.1' stroke='#f59e0b' stroke-width='2'/><circle cx='506.9' cy='181.0' r='3.5' fill='none' stroke='#f59e0b' stroke-width='1.5'/><text x='506.9' y='281' text-anchor='middle' font-size='11' fill='#8888aa'>Treatment C</text><text x='506.9' y='296' text-anchor='middle' font-size='10' fill='#f59e0b'>med=64.8</text> <line x1='0' y1='263' x2='600' y2='263' stroke='#3a3a6a'/> <line x1='0' y1='0' x2='0' y2='263' stroke='#3a3a6a'/> <text x='-8' y='245.1' text-anchor='end' font-size='11' fill='#8888aa'>30</text><text x='-8' y='201.3' text-anchor='end' font-size='11' fill='#8888aa'>40</text><text x='-8' y='157.4' text-anchor='end' font-size='11' fill='#8888aa'>50</text><text x='-8' y='113.6' text-anchor='end' font-size='11' fill='#8888aa'>60</text><text x='-8' y='69.8' text-anchor='end' font-size='11' fill='#8888aa'>70</text><text x='-8' y='25.9' text-anchor='end' font-size='11' fill='#8888aa'>80</text> <text text-anchor='middle' fill='#8888aa' font-size='11' transform='translate(-44,132) rotate(-90)'>Score</text> </g> </svg>\n",
