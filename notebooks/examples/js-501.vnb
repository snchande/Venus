    {
      "id": "jsc-heatmap",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: heatmap-feature-correlation-matrix\n//@ description: ── HEATMAP — Feature Correlation Matrix ─────────────────────────────────\n// ── HEATMAP — Feature Correlation Matrix ─────────────────────────────────\nconst d3 = require('d3');\n\nconst labels = ['Revenue','Users','Sessions','Conversions','Retention'];\nconst matrix = [\n  [1.00, 0.87, 0.82, 0.73, 0.65],\n  [0.87, 1.00, 0.91, 0.68, 0.72],\n  [0.82, 0.91, 1.00, 0.74, 0.69],\n  [0.73, 0.68, 0.74, 1.00, 0.81],\n  [0.65, 0.72, 0.69, 0.81, 1.00]\n];\n\nconst n=labels.length;\nconst W=540, H=460, ml=110, mt=90, mr=20, mb=20;\nconst iw=W-ml-mr, ih=H-mt-mb;\nconst cw=iw/n, ch=ih/n;\nconst BG='#13131f', TXT='#8888aa', TTL='#cdd6f4';\n\n// Color: low=cool blue, high=vivid purple\nconst colorScale = d3.scaleSequential().domain([0.55,1.0]).interpolator(\n  t => `hsl(${(260-t*40).toFixed(0)},${(40+t*45).toFixed(0)}%,${(25+t*30).toFixed(0)}%)`\n);\n\nconst cells = matrix.flatMap((row,i)=>row.map((val,j)=>{\n  const color = colorScale(val);\n  const tc = val>0.78 ? '#e8d8ff' : '#9090b8';\n  const fw = val===1.0 ? 'bold' : 'normal';\n  return `<rect x='${(j*cw).toFixed(1)}' y='${(i*ch).toFixed(1)}' width='${cw.toFixed(1)}' height='${ch.toFixed(1)}' fill='${color}' stroke='${BG}' stroke-width='2.5'/>`\n       + `<text x='${(j*cw+cw/2).toFixed(1)}' y='${(i*ch+ch/2+5).toFixed(1)}' text-anchor='middle' font-size='13' font-weight='${fw}' fill='${tc}'>${val.toFixed(2)}</text>`;\n})).join('');\n\nconst rowLbls = labels.map((l,i)=>\n  `<text x='-8' y='${(i*ch+ch/2+5).toFixed(1)}' text-anchor='end' font-size='12' fill='${TXT}'>${l}</text>`\n).join('');\nconst colLbls = labels.map((l,i)=>{\n  const cx2 = (i*cw+cw/2).toFixed(1);\n  return `<text x='${cx2}' y='-14' text-anchor='middle' font-size='12' fill='${TXT}' transform='rotate(-35,${cx2},-14)'>${l}</text>`;\n}).join('');\n\n// Color legend bar\nconst gradStops = Array.from({length:10},(_,k)=>{\n  const t=k/9;\n  const v = 0.55+t*0.45;\n  return `<stop offset='${(t*100).toFixed(0)}%' stop-color='${colorScale(v)}'/>` ;\n}).join('');\nconst legend =\n  `<defs><linearGradient id='lg' x1='0' x2='1'>${gradStops}</linearGradient></defs>`\n+ `<rect x='${ml}' y='${H-16}' width='${iw}' height='12' fill='url(#lg)' rx='3'/>`\n+ `<text x='${ml}' y='${H-20}' font-size='10' fill='${TXT}'>0.55</text>`\n+ `<text x='${ml+iw}' y='${H-20}' text-anchor='end' font-size='10' fill='${TXT}'>1.00</text>`;\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${W/2}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>Feature Correlation Matrix — Heatmap</text>\n  <g transform='translate(${ml},${mt})'>${cells}${rowLbls}${colLbls}</g>\n  ${legend}\n</svg>`);",
      "output": "VENUS_HTML:<svg xmlns='http://www.w3.org/2000/svg' width='540' height='460' style='background:#13131f;border-radius:10px;font-family:system-ui,sans-serif'> <text x='270' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='#cdd6f4'>Feature Correlation Matrix — Heatmap</text> <g transform='translate(110,90)'><rect x='0.0' y='0.0' width='82.0' height='70.0' fill='hsl(220,85%,55%)' stroke='#13131f' stroke-width='2.5'/><text x='41.0' y='40.0' text-anchor='middle' font-size='13' font-weight='bold' fill='#e8d8ff'>1.00</text><rect x='82.0' y='0.0' width='82.0' height='70.0' fill='hsl(232,72%,46%)' stroke='#13131f' stroke-width='2.5'/><text x='123.0' y='40.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#e8d8ff'>0.87</text><rect x='164.0' y='0.0' width='82.0' height='70.0' fill='hsl(236,67%,43%)' stroke='#13131f' stroke-width='2.5'/><text x='205.0' y='40.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#e8d8ff'>0.82</text><rect x='246.0' y='0.0' width='82.0' height='70.0' fill='hsl(244,58%,37%)' stroke='#13131f' stroke-width='2.5'/><text x='287.0' y='40.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.73</text><rect x='328.0' y='0.0' width='82.0' height='70.0' fill='hsl(251,50%,32%)' stroke='#13131f' stroke-width='2.5'/><text x='369.0' y='40.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.65</text><rect x='0.0' y='70.0' width='82.0' height='70.0' fill='hsl(232,72%,46%)' stroke='#13131f' stroke-width='2.5'/><text x='41.0' y='110.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#e8d8ff'>0.87</text><rect x='82.0' y='70.0' width='82.0' height='70.0' fill='hsl(220,85%,55%)' stroke='#13131f' stroke-width='2.5'/><text x='123.0' y='110.0' text-anchor='middle' font-size='13' font-weight='bold' fill='#e8d8ff'>1.00</text><rect x='164.0' y='70.0' width='82.0' height='70.0' fill='hsl(228,76%,49%)' stroke='#13131f' stroke-width='2.5'/><text x='205.0' y='110.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#e8d8ff'>0.91</text><rect x='246.0' y='70.0' width='82.0' height='70.0' fill='hsl(248,53%,34%)' stroke='#13131f' stroke-width='2.5'/><text x='287.0' y='110.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.68</text><rect x='328.0' y='70.0' width='82.0' height='70.0' fill='hsl(245,57%,36%)' stroke='#13131f' stroke-width='2.5'/><text x='369.0' y='110.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.72</text><rect x='0.0' y='140.0' width='82.0' height='70.0' fill='hsl(236,67%,43%)' stroke='#13131f' stroke-width='2.5'/><text x='41.0' y='180.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#e8d8ff'>0.82</text><rect x='82.0' y='140.0' width='82.0' height='70.0' fill='hsl(228,76%,49%)' stroke='#13131f' stroke-width='2.5'/><text x='123.0' y='180.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#e8d8ff'>0.91</text><rect x='164.0' y='140.0' width='82.0' height='70.0' fill='hsl(220,85%,55%)' stroke='#13131f' stroke-width='2.5'/><text x='205.0' y='180.0' text-anchor='middle' font-size='13' font-weight='bold' fill='#e8d8ff'>1.00</text><rect x='246.0' y='140.0' width='82.0' height='70.0' fill='hsl(243,59%,38%)' stroke='#13131f' stroke-width='2.5'/><text x='287.0' y='180.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.74</text><rect x='328.0' y='140.0' width='82.0' height='70.0' fill='hsl(248,54%,34%)' stroke='#13131f' stroke-width='2.5'/><text x='369.0' y='180.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.69</text><rect x='0.0' y='210.0' width='82.0' height='70.0' fill='hsl(244,58%,37%)' stroke='#13131f' stroke-width='2.5'/><text x='41.0' y='250.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.73</text><rect x='82.0' y='210.0' width='82.0' height='70.0' fill='hsl(248,53%,34%)' stroke='#13131f' stroke-width='2.5'/><text x='123.0' y='250.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.68</text><rect x='164.0' y='210.0' width='82.0' height='70.0' fill='hsl(243,59%,38%)' stroke='#13131f' stroke-width='2.5'/><text x='205.0' y='250.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.74</text><rect x='246.0' y='210.0' width='82.0' height='70.0' fill='hsl(220,85%,55%)' stroke='#13131f' stroke-width='2.5'/><text x='287.0' y='250.0' text-anchor='middle' font-size='13' font-weight='bold' fill='#e8d8ff'>1.00</text><rect x='328.0' y='210.0' width='82.0' height='70.0' fill='hsl(237,66%,42%)' stroke='#13131f' stroke-width='2.5'/><text x='369.0' y='250.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#e8d8ff'>0.81</text><rect x='0.0' y='280.0' width='82.0' height='70.0' fill='hsl(251,50%,32%)' stroke='#13131f' stroke-width='2.5'/><text x='41.0' y='320.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.65</text><rect x='82.0' y='280.0' width='82.0' height='70.0' fill='hsl(245,57%,36%)' stroke='#13131f' stroke-width='2.5'/><text x='123.0' y='320.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.72</text><rect x='164.0' y='280.0' width='82.0' height='70.0' fill='hsl(248,54%,34%)' stroke='#13131f' stroke-width='2.5'/><text x='205.0' y='320.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#9090b8'>0.69</text><rect x='246.0' y='280.0' width='82.0' height='70.0' fill='hsl(237,66%,42%)' stroke='#13131f' stroke-width='2.5'/><text x='287.0' y='320.0' text-anchor='middle' font-size='13' font-weight='normal' fill='#e8d8ff'>0.81</text><rect x='328.0' y='280.0' width='82.0' height='70.0' fill='hsl(220,85%,55%)' stroke='#13131f' stroke-width='2.5'/><text x='369.0' y='320.0' text-anchor='middle' font-size='13' font-weight='bold' fill='#e8d8ff'>1.00</text><text x='-8' y='40.0' text-anchor='end' font-size='12' fill='#8888aa'>Revenue</text><text x='-8' y='110.0' text-anchor='end' font-size='12' fill='#8888aa'>Users</text><text x='-8' y='180.0' text-anchor='end' font-size='12' fill='#8888aa'>Sessions</text><text x='-8' y='250.0' text-anchor='end' font-size='12' fill='#8888aa'>Conversions</text><text x='-8' y='320.0' text-anchor='end' font-size='12' fill='#8888aa'>Retention</text><text x='41.0' y='-14' text-anchor='middle' font-size='12' fill='#8888aa' transform='rotate(-35,41.0,-14)'>Revenue</text><text x='123.0' y='-14' text-anchor='middle' font-size='12' fill='#8888aa' transform='rotate(-35,123.0,-14)'>Users</text><text x='205.0' y='-14' text-anchor='middle' font-size='12' fill='#8888aa' transform='rotate(-35,205.0,-14)'>Sessions</text><text x='287.0' y='-14' text-anchor='middle' font-size='12' fill='#8888aa' transform='rotate(-35,287.0,-14)'>Conversions</text><text x='369.0' y='-14' text-anchor='middle' font-size='12' fill='#8888aa' transform='rotate(-35,369.0,-14)'>Retention</text></g> <defs><linearGradient id='lg' x1='0' x2='1'><stop offset='0%' stop-color='hsl(260,40%,25%)'/><stop offset='11%' stop-color='hsl(256,45%,28%)'/><stop offset='22%' stop-color='hsl(251,50%,32%)'/><stop offset='33%' stop-color='hsl(247,55%,35%)'/><stop offset='44%' stop-color='hsl(242,60%,38%)'/><stop offset='56%' stop-color='hsl(238,65%,42%)'/><stop offset='67%' stop-color='hsl(233,70%,45%)'/><stop offset='78%' stop-color='hsl(229,75%,48%)'/><stop offset='89%' stop-color='hsl(224,80%,52%)'/><stop offset='100%' stop-color='hsl(220,85%,55%)'/></linearGradient></defs><rect x='110' y='444' width='410' height='12' fill='url(#lg)' rx='3'/><text x='110' y='440' font-size='10' fill='#8888aa'>0.55</text><text x='520' y='440' text-anchor='end' font-size='10' fill='#8888aa'>1.00</text> </svg>\n",
