    {
      "id": "jsc-setup",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: import-d3\n//@ description: Imports d3 package\nconst d3 = require('d3');\nconsole.log('D3.js', d3.version, '— ready');\nconsole.log('');\nconsole.log('Chart types in this notebook:');\nconsole.log('  Bar Chart     — monthly revenue comparison');\nconsole.log('  Line Chart    — multi-series stock performance');\nconsole.log('  Scatter Plot  — correlation + linear regression');\nconsole.log('  Histogram     — normal distribution with bell curve');\nconsole.log('  Donut Chart   — market share breakdown');\nconsole.log('  Heatmap       — feature correlation matrix');\nconsole.log('  Box Plot      — A/B/C test group comparison');\nconsole.log('  Area Chart    — website traffic by channel');",
      "output": "D3.js 6.7.0 — ready\n\nChart types in this notebook:\n  Bar Chart     — monthly revenue comparison\n  Line Chart    — multi-series stock performance\n  Scatter Plot  — correlation + linear regression\n  Histogram     — normal distribution with bell curve\n  Donut Chart   — market share breakdown\n  Heatmap       — feature correlation matrix\n  Box Plot      — A/B/C test group comparison\n  Area Chart    — website traffic by channel\n",
      "returnValue": null,
      "executed": true,
      "executionCount": 1,
      "error": "",
      "anchor": "import-d3",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Imports d3 package"
    },
    {
      "id": "jsc-bar",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: bar-chart-monthly-revenue\n//@ description: ── BAR CHART — Monthly Revenue ──────────────────────────────────────────\n// ── BAR CHART — Monthly Revenue ──────────────────────────────────────────\nconst d3 = require('d3');\n\nconst data = [\n  {m:'Jan',v:42},{m:'Feb',v:38},{m:'Mar',v:51},{m:'Apr',v:47},\n  {m:'May',v:63},{m:'Jun',v:58},{m:'Jul',v:71},{m:'Aug',v:68},\n  {m:'Sep',v:55},{m:'Oct',v:72},{m:'Nov',v:65},{m:'Dec',v:80}\n];\n\nconst W=680, H=340, ml=55, mt=42, mr=20, mb=45;\nconst iw=W-ml-mr, ih=H-mt-mb;\nconst BG='#13131f', GRID='#252540', TXT='#8888aa', TTL='#cdd6f4';\n\nconst x = d3.scaleBand().domain(data.map(d=>d.m)).range([0,iw]).padding(0.3);\nconst y = d3.scaleLinear().domain([0, d3.max(data,d=>d.v)*1.15]).range([ih,0]).nice();\nconst maxV = d3.max(data,d=>d.v);\nconst yTicks = y.ticks(5);\n\nconst grid = yTicks.map(t=>\n  `<line x1='0' y1='${y(t).toFixed(1)}' x2='${iw}' y2='${y(t).toFixed(1)}' stroke='${GRID}' stroke-dasharray='3,3'/>`\n).join('');\n\nconst bars = data.map(d=>{\n  const t = d.v/maxV;\n  const hue  = (260+t*40).toFixed(0);\n  const sat  = (58+t*22).toFixed(0);\n  const lit  = (44+t*16).toFixed(0);\n  const bx   = x(d.m).toFixed(1);\n  const bw   = x.bandwidth().toFixed(1);\n  const bh   = (ih-y(d.v)).toFixed(1);\n  const by   = y(d.v).toFixed(1);\n  const mid  = (x(d.m)+x.bandwidth()/2).toFixed(1);\n  return `<rect x='${bx}' y='${by}' width='${bw}' height='${bh}' fill='hsl(${hue},${sat}%,${lit}%)' rx='3'/>`\n       + `<text x='${mid}' y='${(y(d.v)-5).toFixed(1)}' text-anchor='middle' font-size='10' fill='${TXT}'>${d.v}k</text>`;\n}).join('');\n\nconst xLbls = data.map(d=>\n  `<text x='${(x(d.m)+x.bandwidth()/2).toFixed(1)}' y='${ih+15}' text-anchor='middle' font-size='11' fill='${TXT}'>${d.m}</text>`\n).join('');\nconst yLbls = yTicks.map(t=>\n  `<text x='-8' y='${(y(t)+4).toFixed(1)}' text-anchor='end' font-size='11' fill='${TXT}'>${t}k</text>`\n).join('');\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${W/2}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>Monthly Revenue 2024 — Bar Chart</text>\n  <g transform='translate(${ml},${mt})'>\n    ${grid}${bars}\n    <line x1='0' y1='${ih}' x2='${iw}' y2='${ih}' stroke='#3a3a6a'/>\n    <line x1='0' y1='0' x2='0' y2='${ih}' stroke='#3a3a6a'/>\n    ${xLbls}${yLbls}\n    <text text-anchor='middle' fill='${TXT}' font-size='11' transform='translate(-42,${(ih/2).toFixed(0)}) rotate(-90)'>Revenue ($K)</text>\n  </g>\n</svg>`);",
      "output": "VENUS_HTML:<svg xmlns='http://www.w3.org/2000/svg' width='680' height='340' style='background:#13131f;border-radius:10px;font-family:system-ui,sans-serif'> <text x='340' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='#cdd6f4'>Monthly Revenue 2024 — Bar Chart</text> <g transform='translate(55,42)'> <line x1='0' y1='253.0' x2='605' y2='253.0' stroke='#252540' stroke-dasharray='3,3'/><line x1='0' y1='202.4' x2='605' y2='202.4' stroke='#252540' stroke-dasharray='3,3'/><line x1='0' y1='151.8' x2='605' y2='151.8' stroke='#252540' stroke-dasharray='3,3'/><line x1='0' y1='101.2' x2='605' y2='101.2' stroke='#252540' stroke-dasharray='3,3'/><line x1='0' y1='50.6' x2='605' y2='50.6' stroke='#252540' stroke-dasharray='3,3'/><line x1='0' y1='0.0' x2='605' y2='0.0' stroke='#252540' stroke-dasharray='3,3'/><rect x='14.8' y='146.7' width='34.4' height='106.3' fill='hsl(281,70%,52%)' rx='3'/><text x='32.0' y='141.7' text-anchor='middle' font-size='10' fill='#8888aa'>42k</text><rect x='63.9' y='156.9' width='34.4' height='96.1' fill='hsl(279,68%,52%)' rx='3'/><text x='81.2' y='151.9' text-anchor='middle' font-size='10' fill='#8888aa'>38k</text><rect x='113.1' y='124.0' width='34.4' height='129.0' fill='hsl(286,72%,54%)' rx='3'/><text x='130.3' y='119.0' text-anchor='middle' font-size='10' fill='#8888aa'>51k</text><rect x='162.3' y='134.1' width='34.4' height='118.9' fill='hsl(284,71%,53%)' rx='3'/><text x='179.5' y='129.1' text-anchor='middle' font-size='10' fill='#8888aa'>47k</text><rect x='211.5' y='93.6' width='34.4' height='159.4' fill='hsl(292,75%,57%)' rx='3'/><text x='228.7' y='88.6' text-anchor='middle' font-size='10' fill='#8888aa'>63k</text><rect x='260.7' y='106.3' width='34.4' height='146.7' fill='hsl(289,74%,56%)' rx='3'/><text x='277.9' y='101.3' text-anchor='middle' font-size='10' fill='#8888aa'>58k</text><rect x='309.9' y='73.4' width='34.4' height='179.6' fill='hsl(296,78%,58%)' rx='3'/><text x='327.1' y='68.4' text-anchor='middle' font-size='10' fill='#8888aa'>71k</text><rect x='359.1' y='81.0' width='34.4' height='172.0' fill='hsl(294,77%,58%)' rx='3'/><text x='376.3' y='76.0' text-anchor='middle' font-size='10' fill='#8888aa'>68k</text><rect x='408.3' y='113.8' width='34.4' height='139.2' fill='hsl(288,73%,55%)' rx='3'/><text x='425.5' y='108.8' text-anchor='middle' font-size='10' fill='#8888aa'>55k</text><rect x='457.4' y='70.8' width='34.4' height='182.2' fill='hsl(296,78%,58%)' rx='3'/><text x='474.7' y='65.8' text-anchor='middle' font-size='10' fill='#8888aa'>72k</text><rect x='506.6' y='88.5' width='34.4' height='164.4' fill='hsl(293,76%,57%)' rx='3'/><text x='523.8' y='83.5' text-anchor='middle' font-size='10' fill='#8888aa'>65k</text><rect x='555.8' y='50.6' width='34.4' height='202.4' fill='hsl(300,80%,60%)' rx='3'/><text x='573.0' y='45.6' text-anchor='middle' font-size='10' fill='#8888aa'>80k</text> <line x1='0' y1='253' x2='605' y2='253' stroke='#3a3a6a'/> <line x1='0' y1='0' x2='0' y2='253' stroke='#3a3a6a'/> <text x='32.0' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>Jan</text><text x='81.2' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>Feb</text><text x='130.3' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>Mar</text><text x='179.5' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>Apr</text><text x='228.7' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>May</text><text x='277.9' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>Jun</text><text x='327.1' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>Jul</text><text x='376.3' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>Aug</text><text x='425.5' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>Sep</text><text x='474.7' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>Oct</text><text x='523.8' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>Nov</text><text x='573.0' y='268' text-anchor='middle' font-size='11' fill='#8888aa'>Dec</text><text x='-8' y='257.0' text-anchor='end' font-size='11' fill='#8888aa'>0k</text><text x='-8' y='206.4' text-anchor='end' font-size='11' fill='#8888aa'>20k</text><text x='-8' y='155.8' text-anchor='end' font-size='11' fill='#8888aa'>40k</text><text x='-8' y='105.2' text-anchor='end' font-size='11' fill='#8888aa'>60k</text><text x='-8' y='54.6' text-anchor='end' font-size='11' fill='#8888aa'>80k</text><text x='-8' y='4.0' text-anchor='end' font-size='11' fill='#8888aa'>100k</text> <text text-anchor='middle' fill='#8888aa' font-size='11' transform='translate(-42,127) rotate(-90)'>Revenue ($K)</text> </g> </svg>\n",
      "returnValue": null,
      "executed": true,
      "executionCount": 2,
      "error": "",
