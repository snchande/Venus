    {
      "id": "cell-1774845980837",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: version-check\n//@ description: Version check\nconst d3 = require('d3');\n\n// Version check\nconst [major] = d3.version.split('.').map(Number);\nif (major < 6) console.warn(`⚠ Expected D3 v6+, got ${d3.version}`);\n\nconsole.log(`D3.js ${d3.version} — ready`);\n\n// Verify key submodules are available\nconst checks = {\n  'scaleLinear': !!d3.scaleLinear,\n  'line':        !!d3.line,\n  'arc':         !!d3.arc,\n  'histogram':   !!d3.bin,      // renamed bin() in v6\n  'format':      !!d3.format,\n};\nconst allOk = Object.values(checks).every(Boolean);\nconsole.log(`Submodule check: ${allOk ? '✓ all present' : '✗ some missing'}`);\nif (!allOk) console.table(checks);\n\n// Chart index\nconst charts = [\n  ['Bar Chart',    'monthly revenue comparison'],\n  ['Line Chart',   'multi-series stock performance'],\n  ['Scatter Plot', 'correlation + linear regression'],\n  ['Histogram',    'normal distribution with bell curve'],\n  ['Donut Chart',  'market share breakdown'],\n  ['Heatmap',      'feature correlation matrix'],\n  ['Box Plot',     'A/B/C test group comparison'],\n  ['Area Chart',   'website traffic by channel'],\n];\n\nconsole.log('\\nChart types in this notebook:');\ncharts.forEach(([type, desc]) => console.log(`  ${type.padEnd(14)} — ${desc}`));",
      "output": "D3.js 6.7.0 — ready\nSubmodule check: ✓ all present\n\nChart types in this notebook:\n  Bar Chart      — monthly revenue comparison\n  Line Chart     — multi-series stock performance\n  Scatter Plot   — correlation + linear regression\n  Histogram      — normal distribution with bell curve\n  Donut Chart    — market share breakdown\n  Heatmap        — feature correlation matrix\n  Box Plot       — A/B/C test group comparison\n  Area Chart     — website traffic by channel\n",
      "returnValue": null,
      "executed": true,
      "executionCount": 1,
