    {
      "id": "jsc-area",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: area-chart-multi-channel-website-tr\n//@ description: ── AREA CHART — Multi-channel Website Traffic ────────────────────────────\n// ── AREA CHART — Multi-channel Website Traffic ────────────────────────────\nconst d3 = require('d3');\n\nlet _s = 55;\nconst rng = () => { _s=(_s*1664525+1013904223)&0xffffffff; return (_s>>>0)/4294967296; };\n\nconst N=30;\nconst days=Array.from({length:N},(_,i)=>i);\nconst organic = days.map(i=>Math.round(1200+i*15+(rng()-0.5)*220));\nconst paid    = days.map(i=>Math.round(800 +i*10+(rng()-0.5)*160));\nconst direct  = days.map(i=>Math.round(500 +i*5 +(rng()-0.5)*110));\n\nconst W=680, H=340, ml=60, mt=42, mr=120, mb=45;\nconst iw=W-ml-mr, ih=H-mt-mb;\nconst BG='#13131f', GRID='#252540', TXT='#8888aa', TTL='#cdd6f4';\n\nconst allV=[...organic,...paid,...direct];\nconst x = d3.scaleLinear().domain([0,N-1]).range([0,iw]);\nconst y = d3.scaleLinear().domain([0, d3.max(allV)*1.1]).range([ih,0]).nice();\n\nconst areaFn = vals => d3.area().x((_,i)=>x(i)).y0(y(0)).y1(v=>y(v)).curve(d3.curveMonotoneX)(vals);\nconst lineFn  = vals => d3.line().x((_,i)=>x(i)).y(v=>y(v)).curve(d3.curveMonotoneX)(vals);\n\nconst layers = [\n  { vals:organic, color:'#7c3aed', name:'Organic' },\n  { vals:paid,    color:'#06b6d4', name:'Paid'    },\n  { vals:direct,  color:'#10b981', name:'Direct'  }\n];\n\nconst areas = layers.map(l=>\n  `<path d='${areaFn(l.vals)}' fill='${l.color}' fill-opacity='0.2'/>`\n+ `<path d='${lineFn(l.vals)}' fill='none' stroke='${l.color}' stroke-width='2.5'/>`\n).join('');\n\nconst xTicks=[0,5,10,15,20,25,29];\nconst yTicks=y.ticks(5);\nconst grid = yTicks.map(t=>`<line x1='0' y1='${y(t).toFixed(1)}' x2='${iw}' y2='${y(t).toFixed(1)}' stroke='${GRID}' stroke-dasharray='3,3'/>`).join('');\nconst yLbls = yTicks.map(t=>`<text x='-8' y='${(y(t)+4).toFixed(1)}' text-anchor='end' font-size='11' fill='${TXT}'>${(t/1000).toFixed(1)}k</text>`).join('');\nconst xLbls = xTicks.map(t=>`<text x='${x(t).toFixed(1)}' y='${ih+15}' text-anchor='middle' font-size='11' fill='${TXT}'>Day ${t+1}</text>`).join('');\n\nconst legend = layers.map((l,i)=>\n  `<rect x='${iw+10}' y='${i*24}' width='14' height='14' fill='${l.color}' rx='3' fill-opacity='0.85'/>`\n+ `<text x='${iw+28}' y='${i*24+11}' font-size='12' fill='${TXT}'>${l.name}</text>`\n).join('');\n\n// End-of-period summary\nconst summary = layers.map((l,i)=>{\n  const last=l.vals[N-1], first=l.vals[0];\n  const pct=((last-first)/first*100).toFixed(0);\n  const sign=pct>0?'+':'';\n  return `<text x='${iw+28}' y='${i*24+24}' font-size='10' fill='${pct>0?\"#10b981\":\"#ef4444\"}'>${sign}${pct}% </text>`;\n}).join('');\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${(W-120)/2}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>Website Traffic by Channel — Area Chart</text>\n  <g transform='translate(${ml},${mt})'>\n    ${grid}${areas}\n    <line x1='0' y1='${ih}' x2='${iw}' y2='${ih}' stroke='#3a3a6a'/>\n    <line x1='0' y1='0' x2='0' y2='${ih}' stroke='#3a3a6a'/>\n    ${xLbls}${yLbls}${legend}${summary}\n    <text text-anchor='middle' fill='${TXT}' font-size='11' transform='translate(-46,${(ih/2).toFixed(0)}) rotate(-90)'>Sessions</text>\n  </g>\n</svg>`);",
      "output": "VENUS_HTML:<svg xmlns='http://www.w3.org/2000/svg' width='680' height='340' style='background:#13131f;border-radius:10px;font-family:system-ui,sans-serif'> <text x='280' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='#cdd6f4'>Website Traffic by Channel — Area Chart</text> <g transform='translate(60,42)'> <line x1='0' y1='253.0' x2='500' y2='253.0' stroke='#252540' stroke-dasharray='3,3'/><line x1='0' y1='189.8' x2='500' y2='189.8' stroke='#252540' stroke-dasharray='3,3'/><line x1='0' y1='126.5' x2='500' y2='126.5' stroke='#252540' stroke-dasharray='3,3'/><line x1='0' y1='63.3' x2='500' y2='63.3' stroke='#252540' stroke-dasharray='3,3'/><line x1='0' y1='0.0' x2='500' y2='0.0' stroke='#252540' stroke-dasharray='3,3'/><path d='M0,107.9045C5.747126436781609,107.54608333333333,11.494252873563216,107.18766666666667,17.241379310344826,105.754C22.988505747126435,104.32033333333334,28.73563218390804,100.69399999999999,34.48275862068965,98.0375C40.229885057471265,95.38099999999999,45.97701149425287,89.815,51.724137931034484,89.815C57.47126436781609,89.815,63.218390804597696,106.3865,68.9655172413793,106.3865C74.71264367816092,106.3865,80.45977011494253,84.8815,86.20689655172414,84.8815C91.95402298850576,84.8815,97.70114942528735,102.3385,103.44827586206897,102.3385C109.19540229885058,102.3385,114.94252873563218,101.91683333333333,120.6896551724138,101.0735C126.43678160919539,100.23016666666666,132.183908045977,90.34208333333333,137.9310344827586,86.3995C143.67816091954023,82.45691666666667,149.42528735632183,78.85166666666667,155.17241379310346,77.418C160.91954022988506,75.98433333333334,166.66666666666669,75.2675,172.41379310344828,75.2675C178.16091954022988,75.2675,183.90804597701148,83.1105,189.65517241379308,83.1105C195.4022988505747,83.1105,201.1494252873563,82.8575,206.89655172413794,82.8575C212.64367816091954,82.8575,218.39080459770116,83.8695,224.13793103448276,83.8695C229.88505747126436,83.8695,235.632183908046,72.864,241.3793103