    {
      "id": "jsc-donut",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: donut-chart-market-share\n//@ description: ── DONUT CHART — Market Share ────────────────────────────────────────────\n// ── DONUT CHART — Market Share ────────────────────────────────────────────\nconst d3 = require('d3');\n\nconst data = [\n  {label:'VenusAI',  value:34, color:'#7c3aed'},\n  {label:'CloudSys', value:28, color:'#06b6d4'},\n  {label:'DataFlow', value:19, color:'#10b981'},\n  {label:'NetPulse', value:12, color:'#f59e0b'},\n  {label:'Others',   value:7,  color:'#6b7280'}\n];\n\nconst W=680, H=380;\nconst cx=W/2-80, cy=H/2+8;\nconst outerR=140, innerR=72;\nconst BG='#13131f', TXT='#8888aa', TTL='#cdd6f4';\n\nconst pie = d3.pie().value(d=>d.value).sort(null);\nconst arc = d3.arc().innerRadius(innerR).outerRadius(outerR);\nconst labelArc = d3.arc().innerRadius(outerR+22).outerRadius(outerR+22);\nconst hoverArc = d3.arc().innerRadius(innerR).outerRadius(outerR+6);\n\nconst arcs = pie(data);\nconst slices = arcs.map(a=>{\n  const pathD = arc(a);\n  const [lx,ly] = labelArc.centroid(a);\n  const pct = ((a.endAngle-a.startAngle)/(2*Math.PI)*100).toFixed(1);\n  const lbl = pct>5 ? `<text x='${lx.toFixed(1)}' y='${(ly+4).toFixed(1)}' text-anchor='middle' font-size='11' fill='${TXT}'>${pct}%</text>` : '';\n  return `<path d='${pathD}' fill='${a.data.color}' stroke='${BG}' stroke-width='2.5'/>${lbl}`;\n}).join('');\n\nconst legend = data.map((d,i)=>{\n  const ly = (H-data.length*28)/2 + i*28;\n  return `<rect x='${W-162}' y='${ly}' width='15' height='15' fill='${d.color}' rx='3'/>`\n       + `<text x='${W-143}' y='${ly+12}' font-size='12' fill='${TXT}'>${d.label}</text>`\n       + `<text x='${W-30}'  y='${ly+12}' text-anchor='end' font-size='12' fill='${d.color}' font-weight='600'>${d.value}%</text>`;\n}).join('');\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${cx}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>Market Share — Donut Chart</text>\n  <g transform='translate(${cx},${cy})'>${slices}</g>\n  <text x='${cx}' y='${cy-10}' text-anchor='middle' font-size='22' font-weight='bold' fill='${TTL}'>100%</text>\n  <text x='${cx}' y='${cy+14}' text-anchor='middle' font-size='11' fill='${TXT}'>Market Total</text>\n  ${legend}\n</svg>`);",
      "output": "VENUS_HTML:<svg xmlns='http://www.w3.org/2000/svg' width='680' height='380' style='background:#13131f;border-radius:10px;font-family:system-ui,sans-serif'> <text x='260' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='#cdd6f4'>Market Share — Donut Chart</text> <g transform='translate(260,198)'><path d='M8.572527594031473e-15,-140A140,140,0,0,1,118.20590957028207,75.01575129705957L60.791610636145066,38.57952923848777A72,72,0,0,0,4.408728476930472e-15,-72Z' fill='#7c3aed' stroke='#13131f' stroke-width='2.5'/><text x='142.0' y='-74.0' text-anchor='middle' font-size='11' fill='#8888aa'>34.0%</text><path d='M118.20590957028207,75.01575129705957A140,140,0,0,1,-95.83659483001647,102.05560783899756L-49.28739162686561,52.4857411743416A72,72,0,0,0,60.791610636145066,38.57952923848777Z' fill='#06b6d4' stroke='#13131f' stroke-width='2.5'/><text x='20.3' y='164.7' text-anchor='middle' font-size='11' fill='#8888aa'>28.0%</text><path d='M-95.83659483001647,102.05560783899756A140,140,0,0,1,-130.16870802435517,-51.537437375854964L-66.9439069839541,-26.50496779329684A72,72,0,0,0,-49.28739162686561,52.4857411743416Z' fill='#10b981' stroke='#13131f' stroke-width='2.5'/><text x='-158.1' y='39.3' text-anchor='middle' font-size='11' fill='#8888aa'>19.0%</text><path d='M-130.16870802435517,-51.537437375854964A140,140,0,0,1,-59.609100819110104,-126.67578734524277L-30.656108992685194,-65.14754777755343A72,72,0,0,0,-66.9439069839541,-26.50496779329684Z' fill='#f59e0b' stroke='#13131f' stroke-width='2.5'/><text x='-118.1' y='-106.9' text-anchor='middle' font-size='11' fill='#8888aa'>12.0%</text><path d='M-59.609100819110104,-126.67578734524277A140,140,0,0,1,9.862739597592311e-14,-140L5.07226607876176e-14,-72A72,72,0,0,0,-30.656108992685194,-65.14754777755343Z' fill='#6b7280' stroke='#13131f' stroke-width='2.5'/><text x='-35.3' y='-154.1' text-anchor='middle' font-size='11' fill='#8888aa'>7.0%</text></g> <text x='260' y='188' text-anchor='middle' font-size='22' font-weight='bold' fill='#cdd6f4'>100%</text> <text x='260' y='212' text-anchor='middle' font-size='11' fill='#8888aa'>Market Total</text> <rect x='518' y='120' width='15' height='15' fill='#7c3aed' rx='3'/><text x='537' y='132' font-size='12' fill='#8888aa'>VenusAI</text><text x='650'  y='132' text-anchor='end' font-size='12' fill='#7c3aed' font-weight='600'>34%</text><rect x='518' y='148' width='15' height='15' fill='#06b6d4' rx='3'/><text x='537' y='160' font-size='12' fill='#8888aa'>CloudSys</text><text x='650'  y='160' text-anchor='end' font-size='12' fill='#06b6d4' font-weight='600'>28%</text><rect x='518' y='176' width='15' height='15' fill='#10b981' rx='3'/><text x='537' y='188' font-size='12' fill='#8888aa'>DataFlow</text><text x='650'  y='188' text-anchor='end' font-size='12' fill='#10b981' font-weight='600'>19%</text><rect x='518' y='204' width='15' height='15' fill='#f59e0b' rx='3'/><text x='537' y='216' font-size='12' fill='#8888aa'>NetPulse</text><text x='650'  y='216' text-anchor='end' font-size='12' fill='#f59e0b' font-weight='600'>12%</text><rect x='518' y='232' width='15' height='15' fill='#6b7280' rx='3'/><text x='537' y='244' font-size='12' fill='#8888aa'>Others</text><text x='650'  y='244' text-anchor='end' font-size='12' fill='#6b7280' font-weight='600'>7%</text> </svg>\n",
