oke='#10b981' stroke-width='1' stroke-dasharray='4,3'/><line x1='385.7' y1='0' x2='385.7' y2='258' stroke='#10b981' stroke-width='1' stroke-dasharray='4,3'/><text x='389.7' y='26' font-size='10' fill='#10b981'>±1σ</text><line x1='128.6' y1='0' x2='128.6' y2='258' stroke='#3a7a5a' stroke-width='1' stroke-dasharray='3,4'/><line x1='471.4' y1='0' x2='471.4' y2='258' stroke='#3a7a5a' stroke-width='1' stroke-dasharray='3,4'/><text x='475.4' y='40' font-size='10' fill='#3a7a5a'>±2σ</text> <line x1='0' y1='258' x2='600' y2='258' stroke='#3a3a6a'/> <line x1='0' y1='0' x2='0' y2='258' stroke='#3a3a6a'/> <text x='42.9' y='273' text-anchor='middle' font-size='11' fill='#8888aa'>140</text><text x='128.6' y='273' text-anchor='middle' font-size='11' fill='#8888aa'>150</text><text x='214.3' y='273' text-anchor='middle' font-size='11' fill='#8888aa'>160</text><text x='300.0' y='273' text-anchor='middle' font-size='11' fill='#8888aa'>170</text><text x='385.7' y='273' text-anchor='middle' font-size='11' fill='#8888aa'>180</text><text x='471.4' y='273' text-anchor='middle' font-size='11' fill='#8888aa'>190</text><text x='557.1' y='273' text-anchor='middle' font-size='11' fill='#8888aa'>200</text><text x='-8' y='262.0' text-anchor='end' font-size='11' fill='#8888aa'>0</text><text x='-8' y='210.4' text-anchor='end' font-size='11' fill='#8888aa'>10</text><text x='-8' y='158.8' text-anchor='end' font-size='11' fill='#8888aa'>20</text><text x='-8' y='107.2' text-anchor='end' font-size='11' fill='#8888aa'>30</text><text x='-8' y='55.6' text-anchor='end' font-size='11' fill='#8888aa'>40</text><text x='-8' y='4.0' text-anchor='end' font-size='11' fill='#8888aa'>50</text> <text text-anchor='middle' fill='#8888aa' font-size='11' transform='translate(-44,129) rotate(-90)'>Count</text> <text x='300' y='296' text-anchor='middle' font-size='11' fill='#8888aa'>Height (cm)</text> </g> </svg>\n",
