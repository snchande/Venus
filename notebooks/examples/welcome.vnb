    {
      "id": "cell-time",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: datetime-operations\n//@ description: Date/time operations using java.time — LocalDateTime, formatting, arithmetic\nimport java.time.*;\nimport java.time.format.DateTimeFormatter;\n\nvar now = LocalDateTime.now();\nvar formatter = DateTimeFormatter.ofPattern(\"EEEE, MMMM d yyyy 'at' HH:mm\");\nSystem.out.println(\"Now: \" + now.format(formatter));\n\n// Date arithmetic\nvar release = LocalDate.of(2026, 3, 8);\nvar today = LocalDate.now();\nvar daysSince = java.time.temporal.ChronoUnit.DAYS.between(release, today);\nSystem.out.printf(\"Venus released: %s (%+d days from today)%n\", release, daysSince);\n\n// Working with durations\nvar start = Instant.now();\nThread.sleep(10);\nvar elapsed = Duration.between(start, Instant.now());\nSystem.out.println(\"Slept for: \" + elapsed.toMillis() + \"ms\");",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": 16,
      "error": "",
