    {
      "id": "cell-md-streams",
      "type": "MARKDOWN",
      "mode": "jshell",
      "source": "## 3. Java Streams\nStream pipelines work directly in JShell — no class wrapper needed.",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
