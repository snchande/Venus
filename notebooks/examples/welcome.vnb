    {
      "id": "cell-streams",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: stream-pipeline-filter-map-sort-col\n//@ description: Stream pipeline — filter, map, sort, collect\n// Stream pipeline — filter, map, sort, collect\nvar fruits = List.of(\"apple\", \"banana\", \"cherry\", \"avocado\", \"blueberry\", \"apricot\");\n\nvar aFruits = fruits.stream()\n    .filter(f -> f.startsWith(\"a\"))\n    .map(String::toUpperCase)\n    .sorted()\n    .toList();\n\nSystem.out.println(\"Fruits starting with A: \" + aFruits);\n\n// Word frequency\nvar wordCount = fruits.stream()\n    .collect(java.util.stream.Collectors.groupingBy(\n        f -> f.length(), java.util.stream.Collectors.counting()));\nSystem.out.println(\"By length: \" + new java.util.TreeMap<>(wordCount));",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": 9,
      "error": "",
      "anchor": "stream-pipeline-filter-map-sort-col",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Stream pipeline — filter, map, sort, collect"
    },
    {
      "id": "cell-streams2",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: numeric-streams-summary-statistics\n//@ description: Numeric streams — summary statistics\nimport java.util.stream.IntStream;\n\n// Numeric streams — summary statistics\nvar stats = IntStream.rangeClosed(1, 100)\n    .filter(n -> n % 3 == 0 || n % 5 == 0)\n    .summaryStatistics();\n\nSystem.out.printf(\"Multiples of 3 or 5 up to 100:%n\");\nSystem.out.printf(\"  Count=%d  Sum=%d  Avg=%.1f  Min=%d  Max=%d%n\",\n    stats.getCount(), (long)stats.getSum(), stats.getAverage(),\n    stats.getMin(), stats.getMax());",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": 10,
      "error": "",
      "anchor": "numeric-streams-summary-statistics",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Numeric streams — summary statistics"
    },
    {
      "id": "cell-md-records",
