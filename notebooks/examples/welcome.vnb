      "id": "cell-textblocks",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: text-blocks\n//@ description: Text blocks\n// Text blocks\nvar json = \"\"\"\n    {\n      \"project\": \"Venus Notebooks\",\n      \"version\": \"1.0\",\n      \"creator\": \"Suresh Chande\",\n      \"language\": \"Java\",\n      \"released\": \"2026-03-08\"\n    }\n    \"\"\";\n\nSystem.out.println(json);\nSystem.out.printf(\"Lines: %d  Characters: %d%n\", json.lines().count(), json.length());\nSystem.out.println(\"Contains 'Java': \" + json.contains(\"Java\"));\n\n// String methods demo\nSystem.out.println(\"Upper: \" + \"venus\".toUpperCase());\nSystem.out.println(\"Repeat: \" + \"* \".repeat(5));\nSystem.out.println(\"Strip: '\" + \"  hello  \".strip() + \"'\");",
      "output": "",
