    {
      "id": "cell-collections",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: map-of-list-of-immutable-factory-meth\n//@ description: Map.of, List.of — immutable factory methods (java.util is auto-imported)\n// Map.of, List.of — immutable factory methods (java.util is auto-imported)\nvar capitals = Map.of(\n    \"France\",  \"Paris\",\n    \"Germany\", \"Berlin\",\n    \"Japan\",   \"Tokyo\",\n    \"Brazil\",  \"Brasilia\"\n);\n\ncapitals.entrySet().stream()\n    .sorted(Map.Entry.comparingByKey())\n    .forEach(e -> System.out.printf(\"%-12s -> %s%n\", e.getKey(), e.getValue()));\n\nSystem.out.println();\n\n// Mutable map with merge/compute\nvar scores = new HashMap<String, Integer>();\nList.of(\"Alice\",\"Bob\",\"Alice\",\"Charlie\",\"Bob\",\"Alice\")\n    .forEach(name -> scores.merge(name, 1, Integer::sum));\nSystem.out.println(\"Vote counts: \" + new TreeMap<>(scores));",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": 14,
      "error": "",
      "anchor": "map-of-list-of-immutable-factory-meth",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Map.of, List.of — immutable factory methods (java.util is auto-imported)"
    },
