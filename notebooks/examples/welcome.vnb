    {
      "id": "cell-records",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: records-concise-immutable-data-classes\n//@ description: Records — concise immutable data classes\n// Records — concise immutable data classes\nrecord Point(double x, double y) {\n    double distanceTo(Point other) {\n        double dx = x - other.x(), dy = y - other.y();\n        return Math.sqrt(dx*dx + dy*dy);\n    }\n}\n\nrecord Circle(Point center, double radius) {\n    double area()        { return Math.PI * radius * radius; }\n    double circumference() { return 2 * Math.PI * radius; }\n    boolean contains(Point p) { return center.distanceTo(p) <= radius; }\n}\n\nvar c = new Circle(new Point(0, 0), 5.0);\nSystem.out.printf(\"Circle: area=%.2f  circumference=%.2f%n\", c.area(), c.circumference());\nSystem.out.printf(\"Contains (3,4): %s  Contains (4,4): %s%n\",\n    c.contains(new Point(3,4)), c.contains(new Point(4,4)));",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": 11,
      "error": "",
      "anchor": "records-concise-immutable-data-classes",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Records — concise immutable data classes"
    },
    {
      "id": "cell-pattern",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: sealed-interfaces-pattern-matching-swi\n//@ description: Sealed interfaces + pattern matching switch (Java 21)\n// Sealed interfaces + pattern matching switch (Java 21)\nsealed interface Expr permits Num, Add, Mul {}\nrecord Num(double val) implements Expr {}\nrecord Add(Expr a, Expr b) implements Expr {}\nrecord Mul(Expr a, Expr b) implements Expr {}\n\n// [JShell] Type-pattern switch — works on JDK 21+\ndouble eval(Expr e) {\n    return switch (e) {\n        case Num n -> n.val();\n        case Add a -> eval(a.a()) + eval(a.b());\n        case Mul m -> eval(m.a()) * eval(m.b());\n    };\n}\n\n// Compute (2 + 3) * 4\nvar expr = new Mul(new Add(new Num(2), new Num(3)), new Num(4));\nSystem.out.println(\"(2 + 3) * 4 = \" + eval(expr));",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": 12,
      "error": "",
      "anchor": "sealed-interfaces-pattern-matching-swi",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Sealed interfaces + pattern matching switch (Java 21)"
    },
