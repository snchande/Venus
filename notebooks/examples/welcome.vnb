    {
      "id": "cell-optional",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: simulated-user-database\n//@ description: Simulated user database\nimport java.util.Optional;\n\n// Simulated user database\nvar users = Map.of(\"u1\", \"Alice\", \"u2\", \"Bob\", \"u3\", \"Charlie\");\n\nOptional<String> findUser(String id) {\n    return Optional.ofNullable(users.get(id));\n}\n\nString displayUser(String id) {\n    return findUser(id)\n        .map(name -> name + \" (\" + id + \")\")\n        .orElseGet(() -> \"Unknown user: \" + id);\n}\n\nList.of(\"u1\", \"u99\", \"u3\", \"u42\")\n    .forEach(id -> System.out.println(displayUser(id)));",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": 15,
      "error": "",
      "anchor": "simulated-user-database",
      "dependsOn": [],
