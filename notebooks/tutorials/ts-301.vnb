{
  "id": "ts-301",
  "name": "TypeScript Advanced — Conditional & Mapped Types",
  "description": "Conditional types, mapped types, `infer`, and template literal types — the type-system power tools",
  "cells": [
    {
      "id": "ts-301-md-1",
      "type": "MARKDOWN",
      "source": "# TypeScript 301 — Type-System Power Tools\n\nThis notebook covers the advanced type-level features that let you express *transformations* between types:\n\n1. **Conditional types** — `T extends U ? X : Y`\n2. **Mapped types** — iterate a type's keys and rebuild a new type\n3. **`infer`** — pattern-match within a conditional and bind a name\n4. **Template literal types** — string types you can build by interpolation\n5. **Key remapping** — `as` clauses in mapped types",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-301-1",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: conditional-types\n//@ description: T extends U ? X : Y\n\ntype IsString<T> = T extends string ? \"yes\" : \"no\";\n\ntype A = IsString<\"hello\">;  // \"yes\"\ntype B = IsString<42>;       // \"no\"\ntype C = IsString<boolean>;  // \"no\"\n\n// Distributive — applied to each union member\ntype OnlyStrings<T> = T extends string ? T : never;\ntype Filtered = OnlyStrings<string | number | boolean | \"hello\">; // \"hello\" | string\n\nconst exA: A = \"yes\";\nconst exB: B = \"no\";\nconst exC: C = \"no\";\nconst f:   Filtered = \"venus\";\n\nconsole.log({ exA, exB, exC, f });",
      "output": "",
      "executed": false,
      "anchor": "conditional-types",
      "description": "T extends U ? X : Y"
    },
    {
      "id": "ts-301-2",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: mapped-types\n//@ description: Rebuild types by iterating their keys\n\ninterface User { id: number; name: string; email: string; }\n\n// Make everything optional (TypeScript's built-in Partial does exactly this)\ntype MyPartial<T> = { [K in keyof T]?: T[K] };\n\n// Make everything readonly\ntype MyReadonly<T> = { readonly [K in keyof T]: T[K] };\n\n// Turn every property into a string version of itself\ntype Stringify<T> = { [K in keyof T]: string };\n\nconst p: MyPartial<User>    = { name: \"Bob\" };\nconst r: MyReadonly<User>   = { id: 1, name: \"A\", email: \"a@b.c\" };\nconst s: Stringify<User>    = { id: \"1\", name: \"A\", email: \"a@b.c\" };\n\nconsole.log({ p, r, s });",
      "output": "",
      "executed": false,
      "anchor": "mapped-types",
      "description": "Rebuild types by iterating their keys"
    },
    {
      "id": "ts-301-3",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: infer-keyword\n//@ description: `infer` extracts a type from a position in another type\n\ntype UnpackArray<T> = T extends (infer U)[] ? U : T;\n\ntype A = UnpackArray<number[]>;   // number\ntype B = UnpackArray<string[]>;   // string\ntype C = UnpackArray<boolean>;    // boolean (passes through)\n\n// Built-in ReturnType is just `infer R` over the return position\ntype MyReturnType<F> = F extends (...args: any[]) => infer R ? R : never;\n\nfunction makeUser(id: number, name: string) {\n  return { id, name, createdAt: new Date() };\n}\ntype User = MyReturnType<typeof makeUser>;\n\nconst u: User = makeUser(1, \"Alice\");\nconsole.log(u);",
      "output": "",
      "executed": false,
      "anchor": "infer-keyword",
      "description": "`infer` extracts a type from a position in another type"
    },
    {
      "id": "ts-301-md-2",
      "type": "MARKDOWN",
      "source": "## Template literal types\n\nString types you can build by **interpolating** other string types. Great for API routes, CSS units, and ID prefixes.",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-301-4",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: template-literal-types\n//@ description: CSS units, route prefixes, event names\n\ntype CssUnit  = \"px\" | \"em\" | \"rem\" | \"%\";\ntype CssValue = `${number}${CssUnit}`;\n\nconst width:  CssValue = \"100%\";\nconst height: CssValue = \"24px\";\n\ntype HttpMethod = \"GET\" | \"POST\" | \"PUT\" | \"DELETE\";\ntype Route<P extends string> = `${HttpMethod} /api/${P}`;\n\nconst r1: Route<\"users\">         = \"GET /api/users\";\nconst r2: Route<\"users/:id\">     = \"PUT /api/users/:id\";\n\nconsole.log({ width, height, r1, r2 });",
      "output": "",
      "executed": false,
      "anchor": "template-literal-types",
      "description": "CSS units, route prefixes, event names"
    },
    {
      "id": "ts-301-md-3",
      "type": "MARKDOWN",
      "source": "## Key remapping with `as`\n\nA mapped type can rewrite the keys themselves — useful for building getter signatures or renaming a whole shape.",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-301-5",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: key-remapping\n//@ description: Build Getters<T> from a record type\n\ninterface Point { x: number; y: number; z: number; }\n\n// For every key K in Point, produce a `get{K}` method that returns the value.\ntype Getters<T> = {\n  [K in keyof T as `get${Capitalize<string & K>}`]: () => T[K];\n};\n\ntype PointGetters = Getters<Point>;\n// PointGetters is { getX: () => number; getY: () => number; getZ: () => number }\n\nconst impl: PointGetters = {\n  getX: () => 1,\n  getY: () => 2,\n  getZ: () => 3,\n};\n\nconsole.log(\"x =\", impl.getX(), \"y =\", impl.getY(), \"z =\", impl.getZ());",
      "output": "",
      "executed": false,
      "anchor": "key-remapping",
      "description": "Build Getters<T> from a record type"
    }
  ],
  "metadata": {
    "category": "tutorial",
    "language": "typescript",
    "level": 301,
    "subcategory": "Advanced"
  }
}
