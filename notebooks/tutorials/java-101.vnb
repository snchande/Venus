    {
      "id": "j101-hello-java",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: java-mode-full-class-with-main-met\n//@ description: ☕ Java Mode — full class with main() method (standard Java program structure)\n// ☕ Java Mode — full class with main() method (standard Java program structure)\n// In a real .java file this would be the entire file content.\npublic class HelloWorld {\n    public static void main(String[] args) {\n        System.out.println(\"Hello, Arima Notebooks!\");\n        System.out.println(\"Java version: \" + Runtime.version());\n        System.out.printf(\"Today is %s%n\", java.time.LocalDate.now());\n        String greeting = String.format(\"Welcome to Java %s!\",\n                Runtime.version().version().get(0));\n        System.out.println(greeting);\n    }\n}\n// JShell can define and run classes too:\nnew HelloWorld().main(new String[]{});  // call main explicitly",
      "output": "Hello, Arima Notebooks!\r\nJava version: 25+37-LTS-3491\r\nToday is 2026-03-14\r\nWelcome to Java 25!\r\n",
