    {
      "id": "j101-loops-jshell",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: jshell-mode-2\n//@ description: 🔵 JShell Mode\n// 🔵 JShell Mode\n// Classic for loop\nSystem.out.print(\"1–5:  \");\nfor (int i = 1; i <= 5; i++) System.out.print(i + \" \");\nSystem.out.println();\n\n// While loop\nint n = 1;\nSystem.out.print(\"Powers of 2: \");\nwhile (n <= 32) { System.out.print(n + \" \"); n *= 2; }\nSystem.out.println();\n\n// Enhanced for-each\nvar fruits = new String[]{\"apple\", \"banana\", \"cherry\"};\nfor (var fruit : fruits) System.out.println(\"  • \" + fruit);\n\n// break / continue\nSystem.out.print(\"Odd 1–9: \");\nfor (int i = 1; i <= 10; i++) {\n    if (i % 2 == 0) continue;\n    if (i > 9) break;\n    System.out.print(i + \" \");\n}\nSystem.out.println();",
      "output": "1�5:  1 2 3 4 5 \r\nPowers of 2: 1 2 4 8 16 32 \r\n  � apple\r\n  � banana\r\n  � cherry\r\nOdd 1�9: 1 3 5 7 9 \r\n",
      "returnValue": "",
      "executed": true,
      "executionCount": 19,
      "error": "",
      "anchor": "jshell-mode-2",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "🔵 JShell Mode"
    },
    {
      "id": "j101-loops-java",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: java-mode-loops-inside-a-class\n//@ description: ☕ Java Mode — loops inside a class\n// ☕ Java Mode — loops inside a class\nimport java.util.List;\n\npublic class LoopsDemo {\n    // do-while (less common; useful when body runs at least once)\n    static void countDown(int from) {\n        System.out.print(\"Countdown: \");\n        do {\n            System.out.print(from + \" \");\n            from--;\n        } while (from > 0);\n        System.out.println(\"Go!\");\n    }\n\n    public static void main(String[] args) {\n        // Nested loops — multiplication table\n        System.out.println(\"Multiplication table (1–4):\");\n        for (int i = 1; i <= 4; i++) {\n            for (int j = 1; j <= 4; j++) {\n                System.out.printf(\"%3d\", i * j);\n            }\n            System.out.println();\n        }\n        countDown(5);\n\n        // for-each over a List\n        var colors = List.of(\"red\", \"green\", \"blue\");\n        colors.forEach(c -> System.out.println(\"  Color: \" + c));\n    }\n}\nnew LoopsDemo().main(null);",
      "output": "Multiplication table (1�4):\r\n  1  2  3  4\r\n  2  4  6  8\r\n  3  6  9 12\r\n  4  8 12 16\r\nCountdown: 5 4 3 2 1 Go!\r\n  Color: red\r\n  Color: green\r\n  Color: blue\r\n",
      "returnValue": "",
      "executed": true,
      "executionCount": 20,
      "error": "",
      "anchor": "java-mode-loops-inside-a-class",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "☕ Java Mode — loops inside a class"
    },
