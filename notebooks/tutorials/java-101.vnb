    {
      "id": "j101-classes-jshell",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: jshell-mode-define-a-class-inline-t\n//@ description: 🔵 JShell Mode — define a class inline, then instantiate it\n// 🔵 JShell Mode — define a class inline, then instantiate it\nclass Point {\n    double x, y;\n\n    Point(double x, double y) { this.x = x; this.y = y; }\n\n    double distanceTo(Point other) {\n        double dx = this.x - other.x;\n        double dy = this.y - other.y;\n        return Math.sqrt(dx*dx + dy*dy);\n    }\n\n    @Override public String toString() {\n        return String.format(\"Point(%.1f, %.1f)\", x, y);\n    }\n}\n\nvar p1 = new Point(0, 0);\nvar p2 = new Point(3, 4);\nSystem.out.println(\"p1 = \" + p1);\nSystem.out.println(\"p2 = \" + p2);\nSystem.out.printf(\"Distance p1→p2 = %.2f%n\", p1.distanceTo(p2));",
      "output": "p1 = Point(0.0, 0.0)\r\np2 = Point(3.0, 4.0)\r\nDistance p1?p2 = 5.00\r\n",
      "returnValue": "java.io.PrintStream@6267c3bb",
      "executed": true,
      "executionCount": 23,
      "error": "",
      "anchor": "jshell-mode-define-a-class-inline-t",
