    {
      "id": "j101-control-jshell",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: jshell-mode\n//@ description: 🔵 JShell Mode\n// 🔵 JShell Mode\nint score = 85;\n\n// Traditional if-else\nif (score >= 90)      System.out.println(\"Grade: A\");\nelse if (score >= 80) System.out.println(\"Grade: B\");\nelse if (score >= 70) System.out.println(\"Grade: C\");\nelse                  System.out.println(\"Grade: F\");\n\n// Switch expression (Java 14+)\nvar grade = switch (score / 10) {\n    case 10, 9 -> \"A\";\n    case 8     -> \"B\";\n    case 7     -> \"C\";\n    case 6     -> \"D\";\n    default    -> \"F\";\n};\nSystem.out.println(\"Switch grade: \" + grade);\n\n// Ternary\nSystem.out.println(\"Result: \" + (score >= 60 ? \"Pass\" : \"Fail\"));",
      "output": "Grade: B\r\nSwitch grade: B\r\nResult: Pass\r\n",
      "returnValue": "",
      "executed": true,
      "executionCount": 17,
      "error": "",
      "anchor": "jshell-mode",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "🔵 JShell Mode"
    },
    {
      "id": "j101-control-java",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: java-mode-same-control-flow-inside-a\n//@ description: ☕ Java Mode — same control flow inside a class\n// ☕ Java Mode — same control flow inside a class\npublic class ControlFlowDemo {\n    static String getGrade(int score) {\n        return switch (score / 10) {\n            case 10, 9 -> \"A\";\n            case 8     -> \"B\";\n            case 7     -> \"C\";\n            case 6     -> \"D\";\n            default    -> \"F\";\n        };\n    }\n\n    public static void main(String[] args) {\n        int[] scores = {95, 85, 75, 65, 55};\n        System.out.println(\"Score | Grade | Result\");\n        System.out.println(\"------|-------|-------\");\n        for (int score : scores) {\n            System.out.printf(\"  %3d | %5s | %s%n\",\n                score, getGrade(score), score >= 60 ? \"Pass\" : \"Fail\");\n        }\n    }\n}\nnew ControlFlowDemo().main(null);",
      "output": "Score | Grade | Result\r\n------|-------|-------\r\n   95 |     A | Pass\r\n   85 |     B | Pass\r\n   75 |     C | Pass\r\n   65 |     D | Pass\r\n   55 |     F | Fail\r\n",
      "returnValue": "",
      "executed": true,
      "executionCount": 18,
      "error": "",
      "anchor": "java-mode-same-control-flow-inside-a",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "☕ Java Mode — same control flow inside a class"
    },
