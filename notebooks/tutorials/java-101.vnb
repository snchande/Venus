    },
    {
      "id": "j101-classes-java",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: java-mode-classic-oop-class-with-en\n//@ description: ☕ Java Mode — classic OOP: class with encapsulation, constructor, toString\n// ☕ Java Mode — classic OOP: class with encapsulation, constructor, toString\npublic class BankAccount {\n    private String owner;\n    private double balance;\n\n    public BankAccount(String owner, double initialBalance) {\n        this.owner   = owner;\n        this.balance = initialBalance;\n    }\n\n    public void deposit(double amount) {\n        if (amount <= 0) throw new IllegalArgumentException(\"Amount must be positive\");\n        balance += amount;\n        System.out.printf(\"  Deposited $%.2f → balance $%.2f%n\", amount, balance);\n    }\n\n    public void withdraw(double amount) {\n        if (amount > balance) throw new IllegalStateException(\"Insufficient funds\");\n        balance -= amount;\n        System.out.printf(\"  Withdrew $%.2f → balance $%.2f%n\", amount, balance);\n    }\n\n    @Override public String toString() {\n        return String.format(\"BankAccount[owner=%s, balance=$%.2f]\", owner, balance);\n    }\n}\n\nvar account = new BankAccount(\"Alice\", 1000.00);\nSystem.out.println(\"Created: \" + account);\naccount.deposit(500);\naccount.withdraw(200);\nSystem.out.println(\"Final:   \" + account);",
      "output": "Created: BankAccount[owner=Alice, balance=$1000.00]\r\n  Deposited $500.00 ? balance $1500.00\r\n  Withdrew $200.00 ? balance $1300.00\r\nFinal:   BankAccount[owner=Alice, balance=$1300.00]\r\n",
      "returnValue": "",
      "executed": true,
      "executionCount": 24,
      "error": "",
      "anchor": "java-mode-classic-oop-class-with-en",
