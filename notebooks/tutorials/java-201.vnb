    {
      "id": "j202-lambdas-jshell",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: jshell-mode-lambdas-as-first-class-f\n//@ description: 🔵 JShell Mode — lambdas as first-class functions\n// 🔵 JShell Mode — lambdas as first-class functions\nimport java.util.function.*;\n\n// Lambda syntax: (params) -> expression  or  (params) -> { block }\nFunction<String, Integer> length = s -> s.length();\nPredicate<Integer>  isEven = n -> n % 2 == 0;\nConsumer<String>    print  = System.out::println;  // method reference\nSupplier<String>    now    = () -> java.time.LocalTime.now().toString();\n\nSystem.out.println(length.apply(\"Hello\"));\nSystem.out.println(isEven.test(42));\nprint.accept(\"Method reference!\");\nSystem.out.println(\"Time: \" + now.get());\n\n// BiFunction: two inputs\nBiFunction<Integer, Integer, Integer> max = Math::max;\nSystem.out.println(\"max(3,7) = \" + max.apply(3, 7));\n\n// Compose: g(f(x))\nvar shout = length.andThen(n -> n + \" chars\").andThen(String::toUpperCase);\nSystem.out.println(shout.apply(\"hello\"));",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "jshell-mode-lambdas-as-first-class-f",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "🔵 JShell Mode — lambdas as first-class functions"
    },
    {
      "id": "j202-lambdas-java",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: java-mode-custom-functional-interfac\n//@ description: ☕ Java Mode — custom functional interface + strategy pattern\n// ☕ Java Mode — custom functional interface + strategy pattern\nimport java.util.*;\nimport java.util.function.*;\n\n@FunctionalInterface\ninterface Transformer<T> {\n    T transform(T input);\n\n    // Default method for chaining\n    default Transformer<T> andThen(Transformer<T> next) {\n        return input -> next.transform(this.transform(input));\n    }\n}\n\npublic class LambdaDemo {\n    public static void main(String[] args) {\n        // Build a pipeline of transformers\n        Transformer<String> trim  = String::strip;\n        Transformer<String> upper = String::toUpperCase;\n        Transformer<String> excl  = s -> s + \"!\";\n\n        var pipeline = trim.andThen(upper).andThen(excl);\n\n        List<String> inputs = List.of(\"  hello  \", \" world \", \" venus \");\n        inputs.stream()\n              .map(pipeline::transform)\n              .forEach(System.out::println);\n    }\n}\nnew LambdaDemo().main(null);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "java-mode-custom-functional-interfac",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "☕ Java Mode — custom functional interface + strategy pattern"
    },
