    {
      "id": "js-201-classes",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: classes\n//@ description: Classes\n// --- Classes ---\n// WHY: ES6 classes are syntactic sugar over prototype-based inheritance.\n// They make OOP patterns much more readable without changing the underlying model.\n\nclass Animal {\n    #name;      // private field (ES2022) — only accessible inside this class\n    #sound;\n\n    constructor(name, sound) {\n        this.#name  = name;\n        this.#sound = sound;\n        this.energy = 100;\n    }\n\n    speak() {\n        console.log(`${this.#name} says: ${this.#sound}!`);\n    }\n\n    eat(food) {\n        this.energy += 10;\n        console.log(`${this.#name} eats ${food}. Energy: ${this.energy}`);\n    }\n\n    get name() { return this.#name; }   // getter\n\n    static create(name, sound) {        // static factory method\n        return new Animal(name, sound);\n    }\n}\n\nclass Dog extends Animal {\n    constructor(name) {\n        super(name, 'Woof');    // must call super() before using 'this'\n        this.tricks = [];\n    }\n\n    learn(trick) {\n        this.tricks.push(trick);\n        console.log(`${this.name} learned: ${trick}`);\n    }\n\n    speak() {\n        super.speak();          // call parent method\n        console.log(`${this.name} wags tail.`);\n    }\n}\n\nconst cat = Animal.create('Whiskers', 'Meow');\ncat.speak();\ncat.eat('tuna');\n\nconst dog = new Dog('Rex');\ndog.speak();\ndog.learn('sit');\ndog.learn('shake');\nconsole.log('tricks:', dog.tricks);\nconsole.log('is Animal:', dog instanceof Animal);",
      "output": "",
