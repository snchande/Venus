    {
      "id": "js-201-let-const",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: let-and-const-vs-var\n//@ description: let and const vs var\n// --- let and const vs var ---\n// WHY: 'var' is function-scoped and hoisted to the top of its function,\n// which causes surprising bugs. 'let' and 'const' are BLOCK-scoped.\n\n// var hoisting demo — this does NOT throw, it prints undefined\nvar hoistDemo = function() {\n    console.log('x before declaration:', x);  // undefined (hoisted, not ReferenceError)\n    var x = 5;\n    console.log('x after declaration:', x);   // 5\n};\nhoistDemo();\n\n// let: block-scoped, not hoisted in a useful way\nconst blockScopeDemo = function() {\n    let score = 100;\n    if (true) {\n        let score = 999;   // different 'score' — only lives inside this if-block\n        console.log('inside block:', score);   // 999\n    }\n    console.log('outside block:', score);  // 100 — unchanged\n};\nblockScopeDemo();\n\n// const: must be initialized, cannot be reassigned (but objects/arrays are still mutable!)\nconst PI = 3.14159;\n// PI = 3;  // TypeError: Assignment to constant variable\n\nconst user = { name: 'Alice', age: 30 };\nuser.age = 31;           // OK — we're mutating the object, not reassigning the variable\n// user = {};            // TypeError\nconsole.log('user.age after mutation:', user.age);\n\n// Rule of thumb: use const by default, let when you need to reassign, never var.\nconsole.log('PI:', PI);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "let-and-const-vs-var",
      "dependsOn": [],
