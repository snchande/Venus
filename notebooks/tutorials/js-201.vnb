    {
      "id": "js-201-rest-spread",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: default-parameters-rest-and-spread\n//@ description: Default Parameters, Rest, and Spread\n// --- Default Parameters, Rest, and Spread ---\n// WHY: Makes function signatures flexible and expressive without manual argument checking.\n\n// Default parameters\nfunction createUser(name, role = 'viewer', active = true) {\n    return { name, role, active };  // shorthand property: {name} === {name: name}\n}\nconsole.log(createUser('Alice'));\nconsole.log(createUser('Bob', 'admin'));\nconsole.log(createUser('Carol', 'editor', false));\n\n// Rest parameters: collect remaining args into an array\nfunction sum(label, ...numbers) {\n    const total = numbers.reduce((acc, n) => acc + n, 0);\n    console.log(`${label}: ${numbers.join(' + ')} = ${total}`);\n    return total;\n}\nsum('Total', 1, 2, 3, 4, 5);\nsum('Quick', 10, 20);\n\n// Spread operator: expand an array/object into individual elements\nconst evens = [2, 4, 6];\nconst odds  = [1, 3, 5];\nconst all   = [...odds, ...evens].sort((a, b) => a - b);\nconsole.log('merged & sorted:', all);\n\n// Spread for shallow copy (avoids mutation bugs)\nconst original = { a: 1, b: 2, c: 3 };\nconst copy     = { ...original, c: 99, d: 4 };  // override c, add d\nconsole.log('original:', original);\nconsole.log('copy    :', copy);\n\n// Spread in function calls\nconst nums = [3, 1, 4, 1, 5, 9, 2, 6];\nconsole.log('max:', Math.max(...nums));   // same as Math.max(3,1,4,1,5,9,2,6)",
      "output": "",
      "returnValue": null,
