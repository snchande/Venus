    {
      "id": "js-201-destructuring",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: destructuring\n//@ description: Destructuring\n// --- Destructuring ---\n// WHY: Unpacking values from arrays/objects into named variables cleanly.\n// Reduces boilerplate and makes intent clearer.\n\n// Array destructuring\nconst rgb = [255, 128, 0];\nconst [red, green, blue] = rgb;\nconsole.log(`R:${red} G:${green} B:${blue}`);\n\n// Skip elements with commas\nconst [first, , third] = ['a', 'b', 'c'];\nconsole.log('first:', first, ' third:', third);\n\n// Swap variables without a temp\nlet x = 1, y = 2;\n[x, y] = [y, x];\nconsole.log('swapped x:', x, ' y:', y);\n\n// Object destructuring\nconst user = { name: 'Bob', age: 25, city: 'Austin', role: 'admin' };\nconst { name, age, city } = user;\nconsole.log(`${name}, ${age}, from ${city}`);\n\n// Rename while destructuring\nconst { name: userName, role: userRole } = user;\nconsole.log(`userName: ${userName}  role: ${userRole}`);\n\n// Default values\nconst { name: n2, theme = 'light', lang = 'en' } = user;\nconsole.log(`theme: ${theme}  lang: ${lang}`);\n\n// Nested destructuring\nconst order = { id: 42, customer: { name: 'Alice', email: 'a@b.com' }, total: 99.99 };\nconst { id, customer: { name: custName, email }, total } = order;\nconsole.log(`Order #${id} by ${custName} (${email}) — $${total}`);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
