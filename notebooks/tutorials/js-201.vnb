    {
      "id": "js-201-arrow-functions",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: arrow-functions\n//@ description: Arrow Functions\n// --- Arrow Functions ---\n// WHY: Arrow functions have LEXICAL 'this' — they capture 'this' from the\n// surrounding scope at definition time. Regular functions define their OWN 'this'.\n// This eliminates the classic 'var self = this' workaround.\n\n// Syntax forms:\nconst double   = x => x * 2;                          // single param, expression body\nconst add      = (a, b) => a + b;                      // multiple params\nconst greet    = name => `Hello, ${name}!`;            // returns a string\nconst identity = x => ({ value: x });                  // return object literal — wrap in ()\nconst noop     = () => {};                             // no params\nconst verbose  = (x) => {                              // block body — needs explicit return\n    const result = x * x;\n    return result;\n};\n\nconsole.log('double(7)    :', double(7));\nconsole.log('add(3,4)     :', add(3, 4));\nconsole.log('greet        :', greet('Venus'));\nconsole.log('identity(42) :', identity(42));\nconsole.log('verbose(5)   :', verbose(5));\n\n// The 'this' binding difference\nfunction Timer() {\n    this.seconds = 0;\n    // With a regular function, 'this' inside the callback would be undefined (strict) or global\n    // Arrow function captures 'this' from Timer's constructor context\n    const tick = () => {\n        this.seconds++;\n    };\n    tick(); tick(); tick();\n    console.log('Timer seconds:', this.seconds);  // 3\n}\nnew Timer();\n\n// Arrows are great as callbacks — clean and lexically safe\nconst nums = [1, 2, 3, 4, 5];\nconsole.log('doubled:', nums.map(n => n * 2));\nconsole.log('evens:  ', nums.filter(n => n % 2 === 0));",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
