    {
      "id": "js-201-async",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: promises-and-async-await\n//@ description: Promises and async/await\n// --- Promises and async/await ---\n// WHY: JavaScript is single-threaded. Async operations (I/O, timers, network)\n// use callbacks, which nest deeply ('callback hell'). Promises flatten this.\n// async/await makes async code look and behave like synchronous code.\n\n// A Promise represents a value that will be available in the future.\n// States: pending → fulfilled (resolved) or rejected\nconst fetchUser = (id) => new Promise((resolve, reject) => {\n    // Simulate async work with setTimeout\n    setTimeout(() => {\n        if (id > 0) {\n            resolve({ id, name: `User ${id}`, email: `user${id}@example.com` });\n        } else {\n            reject(new Error(`Invalid user id: ${id}`));\n        }\n    }, 10);   // 10ms delay to simulate async\n});\n\n// Promise chaining with .then() / .catch()\nfetchUser(1)\n    .then(user => {\n        console.log('Fetched:', user.name);\n        return fetchUser(2);         // chain: return another promise\n    })\n    .then(user => console.log('Also fetched:', user.name))\n    .catch(err => console.error('Error:', err.message));\n\n// async/await — cleaner syntax for the same thing\nasync function loadUsers() {\n    try {\n        const u1 = await fetchUser(1);\n        const u2 = await fetchUser(2);\n        console.log('\\nasync/await result:');\n        console.log(` ${u1.name} | ${u1.email}`);\n        console.log(` ${u2.name} | ${u2.email}`);\n\n        // Run both in PARALLEL with Promise.all\n        const [u3, u4] = await Promise.all([fetchUser(3), fetchUser(4)]);\n        console.log(`\\nParallel fetch: ${u3.name}, ${u4.name}`);\n    } catch (err) {\n        console.error('loadUsers error:', err.message);\n    }\n}\n\nloadUsers();",
