    {
      "id": "js-201-template-literals",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: template-literals\n//@ description: Template Literals\n// --- Template Literals ---\n// WHY: String concatenation with + is error-prone and hard to read.\n// Template literals (backtick strings) support embedded expressions and newlines.\n\nconst name = 'Alice';\nconst age  = 30;\nconst balance = 1234.56;\n\n// Embedded expressions with ${...}\nconst greeting = `Hello, ${name}! You are ${age} years old.`;\nconsole.log(greeting);\n\n// Multi-line strings — newlines are literal\nconst receipt = `\n=== Account Summary ===\nName    : ${name}\nAge     : ${age}\nBalance : $${balance.toFixed(2)}\nStatus  : ${balance > 1000 ? 'Gold Member' : 'Standard'}\n`;\nconsole.log(receipt);\n\n// Expressions inside ${} can be anything\nconst items = ['Widget', 'Gadget', 'Doohickey'];\nconsole.log(`Cart has ${items.length} item${items.length !== 1 ? 's' : ''}.`);\nconsole.log(`Items: ${items.join(', ')}`);\n\n// Tagged template literals (advanced): a function processes the template\nfunction highlight(strings, ...values) {\n    return strings.reduce((result, str, i) =>\n        result + str + (values[i] !== undefined ? `[${values[i]}]` : ''), '');\n}\nconst product = 'Widget';\nconst price   = 9.99;\nconsole.log(highlight`Buy ${product} for $${price} today!`);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
