    {
      "id": "jshell-101-vars",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: declaring-variables\n//@ description: Declaring variables\n// --- Declaring variables ---\n// Java is statically typed: every variable has a fixed type.\n// You can declare types explicitly or use 'var' to let the compiler infer the type.\n\nint age = 28;                        // 32-bit integer\ndouble salary = 95_000.50;           // 64-bit floating-point (underscores for readability)\nboolean isActive = true;             // true or false\nchar grade = 'A';                    // single Unicode character\nString name = \"Alice\";              // String is a class, not a primitive\n\n// 'var' infers the type from the right-hand side (Java 10+)\nvar city = \"San Francisco\";          // inferred as String\nvar score = 42;                      // inferred as int\n\n// Print all variables to confirm\nSystem.out.println(\"Name   : \" + name);\nSystem.out.println(\"Age    : \" + age);\nSystem.out.println(\"Salary : \" + salary);\nSystem.out.println(\"Active : \" + isActive);\nSystem.out.println(\"Grade  : \" + grade);\nSystem.out.println(\"City   : \" + city + \"  Score: \" + score);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "declaring-variables",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Declaring variables"
