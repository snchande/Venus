    {
      "id": "jshell-101-casting",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: type-casting\n//@ description: Type casting\n// --- Type casting ---\n// Widening cast: smaller type → larger type, done automatically (no data loss)\n// Narrowing cast: larger type → smaller type, must be explicit (possible data loss)\n\nint intVal = 42;\ndouble wideDouble = intVal;              // widening: int → double (automatic)\nSystem.out.println(\"int → double (widening): \" + wideDouble);  // 42.0\n\ndouble piApprox = 3.99999;\nint narrowedInt = (int) piApprox;        // narrowing: double → int (truncates, NOT rounds!)\nSystem.out.println(\"double → int (narrowing, truncates): \" + narrowedInt);  // 3\n\n// Parsing strings to numbers\nString numberStr = \"123\";\nint parsed = Integer.parseInt(numberStr);\ndouble parsedDouble = Double.parseDouble(\"3.14159\");\nSystem.out.println(\"Parsed int    : \" + parsed);\nSystem.out.println(\"Parsed double : \" + parsedDouble);\n\n// Converting numbers back to String\nString backToString = String.valueOf(parsed);    // or: Integer.toString(parsed)\nSystem.out.println(\"Back to string: '\" + backToString + \"'  (type: \" + backToString.getClass().getSimpleName() + \")\");",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "type-casting",
      "dependsOn": [],
