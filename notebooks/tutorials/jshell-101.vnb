    {
      "id": "jshell-101-arithmetic",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: arithmetic-operators\n//@ description: Arithmetic operators\n// --- Arithmetic operators ---\n// The standard operators work as expected.\n// Integer division truncates the decimal part — watch out for this!\n\nint a = 17;\nint b = 5;\n\nSystem.out.println(\"a + b  = \" + (a + b));   // 22  addition\nSystem.out.println(\"a - b  = \" + (a - b));   // 12  subtraction\nSystem.out.println(\"a * b  = \" + (a * b));   // 85  multiplication\nSystem.out.println(\"a / b  = \" + (a / b));   // 3   integer division (truncates!)\nSystem.out.println(\"a % b  = \" + (a % b));   // 2   modulus (remainder)\n\n// To get a decimal result, cast at least one operand to double\ndouble exactDiv = (double) a / b;\nSystem.out.println(\"(double)a / b = \" + exactDiv);  // 3.4\n\n// Compound assignment operators\nint counter = 10;\ncounter += 5;   // same as: counter = counter + 5\ncounter *= 2;   // same as: counter = counter * 2\nSystem.out.println(\"counter after += 5, *= 2: \" + counter);  // 30",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
