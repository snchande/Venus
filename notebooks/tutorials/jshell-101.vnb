    {
      "id": "jshell-101-printf",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: formatted-output-with-printf-string-form\n//@ description: Formatted output with printf / String.format\n// --- Formatted output with printf / String.format ---\n// Format specifiers:\n//   %d  integer      %f  floating-point   %s  string   %n  newline\n//   %-10s  left-align in 10-char field     %.2f  2 decimal places\n\nString[] products = {\"Widget\", \"Gadget\", \"Doohickey\"};\ndouble[] prices   = {4.99, 12.50, 0.75};\nint[]    qtys     = {100, 25, 500};\n\n// Print a simple table\nSystem.out.printf(\"%-12s %8s %6s %10s%n\", \"Product\", \"Price\", \"Qty\", \"Total\");\nSystem.out.println(\"-\".repeat(40));\nfor (int i = 0; i < products.length; i++) {\n    double total = prices[i] * qtys[i];\n    System.out.printf(\"%-12s %8.2f %6d %10.2f%n\",\n                      products[i], prices[i], qtys[i], total);\n}\nSystem.out.println(\"-\".repeat(40));\n\n// Grand total using a stream (preview of things to come)\ndouble grandTotal = 0;\nfor (int i = 0; i < prices.length; i++) grandTotal += prices[i] * qtys[i];\nSystem.out.printf(\"%-12s %8s %6s %10.2f%n\", \"TOTAL\", \"\", \"\", grandTotal);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
