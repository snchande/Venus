    {
      "id": "jshell-101-conditionals",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: conditionals-if-else-and-the-ternary-ope\n//@ description: Conditionals: if/else and the ternary operator\n// --- Conditionals: if/else and the ternary operator ---\n// Variables from earlier cells are still in scope!\n\nint temperature = 22;\n\n// Standard if / else if / else\nif (temperature < 0) {\n    System.out.println(\"Freezing! Bundle up.\");\n} else if (temperature < 15) {\n    System.out.println(\"Cold. Wear a jacket.\");\n} else if (temperature < 25) {\n    System.out.println(\"Comfortable. Enjoy the day!\");\n} else {\n    System.out.println(\"Hot! Stay hydrated.\");\n}\n\n// Ternary operator: condition ? valueIfTrue : valueIfFalse\nString verdict = (temperature >= 15 && temperature <= 25) ? \"pleasant\" : \"extreme\";\nSystem.out.println(\"The weather is \" + verdict + \" (\" + temperature + \"°C)\");\n\n// Combining with variables from cell 1 (name, score are still in scope)\nSystem.out.println();\nSystem.out.println(\"=== Score Report ===\");\nSystem.out.printf(\"Student: %s%n\", name);\nSystem.out.printf(\"Score  : %d%n\", score);\nString letterGrade = score >= 90 ? \"A\" : score >= 80 ? \"B\" : score >= 70 ? \"C\" : score >= 60 ? \"D\" : \"F\";\nSystem.out.printf(\"Grade  : %s%n\", letterGrade);",
      "output": "",
      "returnValue": null,
