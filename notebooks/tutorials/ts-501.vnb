{
  "id": "ts-501",
  "name": "TypeScript Expert — Typed Data Analysis",
  "description": "Real-world data analysis with typed records, statistics, charts via venus helpers, and npm packages",
  "cells": [
    {
      "id": "ts-501-md-1",
      "type": "MARKDOWN",
      "source": "# TypeScript 501 — Typed Data Analysis\n\nThis notebook brings TypeScript's type system to a data-analysis workflow:\n\n1. Define a strict `Sale` record\n2. Load and aggregate with type-safe `reduce` and `groupBy`\n3. Compute statistics manually and with `simple-statistics`\n4. Render results as Venus tables and inline HTML\n5. Defensive parsing with `Result<T, E>`\n\n> **Optional:** install the `simple-statistics` npm package (Packages → npm tab) for richer stats. The cell that uses it will fall back to manual computation if it's not installed.",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-501-1",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: dataset\n//@ description: Strict record types and a small dataset\n\nexport interface Sale {\n  id: number;\n  region: \"N\" | \"S\" | \"E\" | \"W\";\n  product: string;\n  qty: number;\n  unitPrice: number;\n  /** YYYY-MM */\n  month: string;\n}\n\nexport const sales: ReadonlyArray<Sale> = [\n  { id: 1,  region: \"N\", product: \"Widget\",   qty: 12, unitPrice: 19.95, month: \"2026-01\" },\n  { id: 2,  region: \"S\", product: \"Widget\",   qty:  9, unitPrice: 19.95, month: \"2026-01\" },\n  { id: 3,  region: \"E\", product: \"Gadget\",   qty: 14, unitPrice: 29.50, month: \"2026-01\" },\n  { id: 4,  region: \"W\", product: \"Gadget\",   qty:  8, unitPrice: 29.50, month: \"2026-01\" },\n  { id: 5,  region: \"N\", product: \"Sprocket\", qty: 22, unitPrice:  4.95, month: \"2026-02\" },\n  { id: 6,  region: \"S\", product: \"Widget\",   qty: 11, unitPrice: 19.95, month: \"2026-02\" },\n  { id: 7,  region: \"E\", product: \"Sprocket\", qty: 31, unitPrice:  4.95, month: \"2026-02\" },\n  { id: 8,  region: \"W\", product: \"Gadget\",   qty:  6, unitPrice: 29.50, month: \"2026-02\" },\n  { id: 9,  region: \"N\", product: \"Widget\",   qty: 15, unitPrice: 19.95, month: \"2026-03\" },\n  { id: 10, region: \"S\", product: \"Sprocket\", qty: 27, unitPrice:  4.95, month: \"2026-03\" },\n  { id: 11, region: \"E\", product: \"Gadget\",   qty: 17, unitPrice: 29.50, month: \"2026-03\" },\n  { id: 12, region: \"W\", product: \"Widget\",   qty: 13, unitPrice: 19.95, month: \"2026-03\" },\n];\n\nconsole.log(`Loaded ${sales.length} sales records spanning ${new Set(sales.map(s => s.month)).size} months`);\nvenus.table(sales.slice(0, 5) as unknown as Record<string, unknown>[]);",
      "output": "",
      "executed": false,
      "anchor": "dataset",
      "description": "Strict record types and a small dataset"
    },
    {
      "id": "ts-501-2",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: aggregate-by-region\n//@ description: Group by region and rank by total revenue\n\ninterface Sale {\n  id: number; region: \"N\" | \"S\" | \"E\" | \"W\";\n  product: string; qty: number; unitPrice: number; month: string;\n}\n\nconst sales: Sale[] = [\n  { id: 1,  region: \"N\", product: \"Widget\",   qty: 12, unitPrice: 19.95, month: \"2026-01\" },\n  { id: 2,  region: \"S\", product: \"Widget\",   qty:  9, unitPrice: 19.95, month: \"2026-01\" },\n  { id: 3,  region: \"E\", product: \"Gadget\",   qty: 14, unitPrice: 29.50, month: \"2026-01\" },\n  { id: 4,  region: \"W\", product: \"Gadget\",   qty:  8, unitPrice: 29.50, month: \"2026-01\" },\n  { id: 5,  region: \"N\", product: \"Sprocket\", qty: 22, unitPrice:  4.95, month: \"2026-02\" },\n  { id: 6,  region: \"S\", product: \"Widget\",   qty: 11, unitPrice: 19.95, month: \"2026-02\" },\n  { id: 7,  region: \"E\", product: \"Sprocket\", qty: 31, unitPrice:  4.95, month: \"2026-02\" },\n  { id: 8,  region: \"W\", product: \"Gadget\",   qty:  6, unitPrice: 29.50, month: \"2026-02\" },\n  { id: 9,  region: \"N\", product: \"Widget\",   qty: 15, unitPrice: 19.95, month: \"2026-03\" },\n  { id: 10, region: \"S\", product: \"Sprocket\", qty: 27, unitPrice:  4.95, month: \"2026-03\" },\n  { id: 11, region: \"E\", product: \"Gadget\",   qty: 17, unitPrice: 29.50, month: \"2026-03\" },\n  { id: 12, region: \"W\", product: \"Widget\",   qty: 13, unitPrice: 19.95, month: \"2026-03\" },\n];\n\ninterface RegionSummary { region: string; orders: number; units: number; revenue: number; }\n\nconst byRegion = sales.reduce<Record<string, RegionSummary>>((acc, s) => {\n  const cur = acc[s.region] ?? { region: s.region, orders: 0, units: 0, revenue: 0 };\n  cur.orders  += 1;\n  cur.units   += s.qty;\n  cur.revenue += s.qty * s.unitPrice;\n  acc[s.region] = cur;\n  return acc;\n}, {});\n\nconst ranked = Object.values(byRegion)\n  .sort((a, b) => b.revenue - a.revenue)\n  .map(r => ({ Region: r.region, Orders: r.orders, Units: r.units, Revenue: r.revenue.toFixed(2) }));\n\nvenus.table(ranked);",
      "output": "",
      "executed": false,
      "anchor": "aggregate-by-region",
      "description": "Group by region and rank by total revenue"
    },
    {
      "id": "ts-501-md-2",
      "type": "MARKDOWN",
      "source": "## Statistics — built-in and via simple-statistics\n\nVenus's `venus.stats(...)` covers the basics. For richer statistics, install `simple-statistics` from the Packages → npm tab.",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-501-3",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: typed-stats\n//@ description: venus.stats + optional simple-statistics fallback\n\nconst readings: number[] = [\n  23.4, 24.1, 22.8, 25.0, 26.2,\n  23.9, 24.5, 24.0, 27.3, 22.1,\n  23.8, 25.7, 24.4, 26.5, 23.0,\n];\n\nconsole.log(\"=== venus.stats ===\");\nvenus.stats(readings);\n\n// We use `any` here because simple-statistics ships without a bundled .d.ts.\n// Install @types/simple-statistics if you want full IntelliSense.\nasync function richStats(): Promise<void> {\n  try {\n    const ss: any = await import(\"simple-statistics\");\n    console.log(\"\\n=== simple-statistics ===\");\n    console.log(\"median:\",             Number(ss.median(readings)).toFixed(3));\n    console.log(\"variance:\",           Number(ss.variance(readings)).toFixed(3));\n    console.log(\"interquartileRange:\", Number(ss.interquartileRange(readings)).toFixed(3));\n    console.log(\"sampleSkewness:\",     Number(ss.sampleSkewness(readings)).toFixed(3));\n  } catch {\n    console.log(\"\\n(simple-statistics not installed — install via Packages → npm to enable rich stats)\");\n  }\n}\n\nrichStats();",
      "output": "",
      "executed": false,
      "anchor": "typed-stats",
      "description": "venus.stats + optional simple-statistics fallback"
    },
    {
      "id": "ts-501-md-3",
      "type": "MARKDOWN",
      "source": "## Inline HTML reports with `venus.html()`\n\nTypeScript lets you build template-literal HTML with strong types — perfect for inline reports.",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-501-4",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: html-report\n//@ description: Inline typed HTML report with venus.html\n\ninterface Row { label: string; value: number; color: string; }\n\nfunction bar(row: Row, maxValue: number): string {\n  const pct = Math.round((row.value / maxValue) * 100);\n  return `<div style=\"display:flex;align-items:center;gap:8px;margin:2px 0\">\n    <div style=\"width:70px;text-align:right;color:#aaa\">${row.label}</div>\n    <div style=\"flex:1;background:#222;border-radius:3px;overflow:hidden\">\n      <div style=\"width:${pct}%;background:${row.color};padding:2px 6px;color:#fff;font-weight:600\">\n        ${row.value}\n      </div>\n    </div>\n  </div>`;\n}\n\nconst rows: Row[] = [\n  { label: \"North\", value: 540, color: \"#3178c6\" },\n  { label: \"South\", value: 320, color: \"#06b6d4\" },\n  { label: \"East\",  value: 770, color: \"#22c55e\" },\n  { label: \"West\",  value: 250, color: \"#f59e0b\" },\n];\n\nconst maxVal: number = Math.max(...rows.map(r => r.value));\nconst html: string =\n  `<div style=\"font-family:sans-serif;padding:8px;background:#0f0f17;border-radius:6px\">\n    <h3 style=\"margin:0 0 8px 0;color:#3178c6\">◆ Regional Revenue</h3>\n    ${rows.map(r => bar(r, maxVal)).join(\"\")}\n  </div>`;\n\nvenus.html(html);",
      "output": "",
      "executed": false,
      "anchor": "html-report",
      "description": "Inline typed HTML report with venus.html"
    },
    {
      "id": "ts-501-md-4",
      "type": "MARKDOWN",
      "source": "## Defensive parsing with `Result<T, E>`\n\nReal-world data is messy. Use a typed `Result` to surface parse errors without throwing.",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-501-5",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: defensive-parse\n//@ description: Parse a CSV-ish string into Sale records safely\n\ntype Result<T, E = string> =\n  | { ok: true;  value: T }\n  | { ok: false; error: E; line: number };\n\ninterface Sale { region: string; product: string; qty: number; unitPrice: number; }\n\nfunction parseRow(line: string, idx: number): Result<Sale> {\n  const parts = line.split(\",\").map(p => p.trim());\n  if (parts.length !== 4) {\n    return { ok: false, error: `Expected 4 columns, got ${parts.length}`, line: idx };\n  }\n  const [region, product, qtyStr, priceStr] = parts;\n  const qty = Number(qtyStr);\n  const unitPrice = Number(priceStr);\n  if (!Number.isFinite(qty) || !Number.isFinite(unitPrice)) {\n    return { ok: false, error: `Non-numeric qty/price: \"${qtyStr}\" / \"${priceStr}\"`, line: idx };\n  }\n  return { ok: true, value: { region, product, qty, unitPrice } };\n}\n\nconst input: string =\n`N, Widget,   12, 19.95\nS, Widget,    9, 19.95\nE, Gadget,   xx, 29.50\nW, Gadget,    8\nN, Sprocket, 22, 4.95`;\n\nconst results: Array<Result<Sale>> = input.split(\"\\n\").map((l, i) => parseRow(l, i + 1));\nconst ok:    Sale[] = results.filter((r): r is { ok: true; value: Sale } => r.ok).map(r => r.value);\nconst errs           = results.filter((r): r is { ok: false; error: string; line: number } => !r.ok);\n\nconsole.log(`Parsed ${ok.length} row(s) successfully, ${errs.length} error(s):`);\nerrs.forEach(e => console.log(`  line ${e.line}: ${e.error}`));\n\nvenus.table(ok as unknown as Record<string, unknown>[]);",
      "output": "",
      "executed": false,
      "anchor": "defensive-parse",
      "description": "Parse a CSV-ish string into Sale records safely"
    }
  ],
  "metadata": {
    "category": "tutorial",
    "language": "typescript",
    "level": 501,
    "subcategory": "Data Science & Analytics"
  }
}
