    {
      "id": "jsc-setup",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: import-d3\n//@ description: Imports d3 package\nconst d3 = require('d3');\nconsole.log('D3.js', d3.version, '— ready');\nconsole.log('');\nconsole.log('Chart types in this notebook:');\nconsole.log('  Bar Chart     — monthly revenue comparison');\nconsole.log('  Line Chart    — multi-series stock performance');\nconsole.log('  Scatter Plot  — correlation + linear regression');\nconsole.log('  Histogram     — normal distribution with bell curve');\nconsole.log('  Donut Chart   — market share breakdown');\nconsole.log('  Heatmap       — feature correlation matrix');\nconsole.log('  Box Plot      — A/B/C test group comparison');\nconsole.log('  Area Chart    — website traffic by channel');",
      "output": "",
      "returnValue": null,
      "executed": true,
      "executionCount": 1,
      "error": "node:internal/modules/cjs/loader:686\n      throw e;\n      ^\n\nError [ERR_PACKAGE_PATH_NOT_EXPORTED]: Package subpath './package.json' is not defined by \"exports\" in C:\\Users\\sures\\Projects\\claude\\venus\\data\\npm-modules\\node_modules\\d3\\package.json\n    at exportsNotFound (node:internal/modules/esm/resolve:313:10)\n    at packageExportsResolve (node:internal/modules/esm/resolve:661:9)\n    at resolveExports (node:internal/modules/cjs/loader:679:36)\n    at Module._findPath (node:internal/modules/cjs/loader:746:31)\n    at Module._resolveFilename (node:internal/modules/cjs/loader:1406:27)\n    at defaultResolveImpl (node:internal/modules/cjs/loader:1059:19)\n    at resolveForCJSWithHooks (node:internal/modules/cjs/loader:1064:22)\n    at Module._load (node:internal/modules/cjs/loader:1227:37)\n    at TracingChannel.traceSync (node:diagnostics_channel:328:14)\n    at wrapModuleLoad (node:internal/modules/cjs/loader:245:24) {\n  code: 'ERR_PACKAGE_PATH_NOT_EXPORTED'\n}\n\nNode.js v24.13.0",
