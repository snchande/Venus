    {
      "id": "jsc-bar",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: bar-chart-monthly-revenue\n//@ description: ── BAR CHART — Monthly Revenue ──────────────────────────────────────────\n// ── BAR CHART — Monthly Revenue ──────────────────────────────────────────\nconst d3 = require('d3');\n\nconst data = [\n  {m:'Jan',v:42},{m:'Feb',v:38},{m:'Mar',v:51},{m:'Apr',v:47},\n  {m:'May',v:63},{m:'Jun',v:58},{m:'Jul',v:71},{m:'Aug',v:68},\n  {m:'Sep',v:55},{m:'Oct',v:72},{m:'Nov',v:65},{m:'Dec',v:80}\n];\n\nconst W=680, H=340, ml=55, mt=42, mr=20, mb=45;\nconst iw=W-ml-mr, ih=H-mt-mb;\nconst BG='#13131f', GRID='#252540', TXT='#8888aa', TTL='#cdd6f4';\n\nconst x = d3.scaleBand().domain(data.map(d=>d.m)).range([0,iw]).padding(0.3);\nconst y = d3.scaleLinear().domain([0, d3.max(data,d=>d.v)*1.15]).range([ih,0]).nice();\nconst maxV = d3.max(data,d=>d.v);\nconst yTicks = y.ticks(5);\n\nconst grid = yTicks.map(t=>\n  `<line x1='0' y1='${y(t).toFixed(1)}' x2='${iw}' y2='${y(t).toFixed(1)}' stroke='${GRID}' stroke-dasharray='3,3'/>`\n).join('');\n\nconst bars = data.map(d=>{\n  const t = d.v/maxV;\n  const hue  = (260+t*40).toFixed(0);\n  const sat  = (58+t*22).toFixed(0);\n  const lit  = (44+t*16).toFixed(0);\n  const bx   = x(d.m).toFixed(1);\n  const bw   = x.bandwidth().toFixed(1);\n  const bh   = (ih-y(d.v)).toFixed(1);\n  const by   = y(d.v).toFixed(1);\n  const mid  = (x(d.m)+x.bandwidth()/2).toFixed(1);\n  return `<rect x='${bx}' y='${by}' width='${bw}' height='${bh}' fill='hsl(${hue},${sat}%,${lit}%)' rx='3'/>`\n       + `<text x='${mid}' y='${(y(d.v)-5).toFixed(1)}' text-anchor='middle' font-size='10' fill='${TXT}'>${d.v}k</text>`;\n}).join('');\n\nconst xLbls = data.map(d=>\n  `<text x='${(x(d.m)+x.bandwidth()/2).toFixed(1)}' y='${ih+15}' text-anchor='middle' font-size='11' fill='${TXT}'>${d.m}</text>`\n).join('');\nconst yLbls = yTicks.map(t=>\n  `<text x='-8' y='${(y(t)+4).toFixed(1)}' text-anchor='end' font-size='11' fill='${TXT}'>${t}k</text>`\n).join('');\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${W/2}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>Monthly Revenue 2024 — Bar Chart</text>\n  <g transform='translate(${ml},${mt})'>\n    ${grid}${bars}\n    <line x1='0' y1='${ih}' x2='${iw}' y2='${ih}' stroke='#3a3a6a'/>\n    <line x1='0' y1='0' x2='0' y2='${ih}' stroke='#3a3a6a'/>\n    ${xLbls}${yLbls}\n    <text text-anchor='middle' fill='${TXT}' font-size='11' transform='translate(-42,${(ih/2).toFixed(0)}) rotate(-90)'>Revenue ($K)</text>\n  </g>\n</svg>`);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "bar-chart-monthly-revenue",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "── BAR CHART — Monthly Revenue ──────────────────────────────────────────"
    },
    {
      "id": "jsc-line",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: line-chart-multi-series-stock-perfo\n//@ description: ── LINE CHART — Multi-series Stock Performance ───────────────────────────\n// ── LINE CHART — Multi-series Stock Performance ───────────────────────────\nconst d3 = require('d3');\n\nconst months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];\nconst series = [\n  { name:'VenusAI',   color:'#7c3aed', vals:[142,156,148,171,163,182,195,188,201,215,208,234] },\n  { name:'CloudSys',  color:'#06b6d4', vals:[98,102,115,109,121,128,135,142,138,151,159,168] },\n  { name:'DataFlow',  color:'#10b981', vals:[67,74,71,83,79,88,92,86,95,102,98,115] }\n];\n\nconst W=680, H=340, ml=55, mt=42, mr=115, mb=45;\nconst iw=W-ml-mr, ih=H-mt-mb;\nconst BG='#13131f', GRID='#252540', TXT='#8888aa', TTL='#cdd6f4';\n\nconst allV = series.flatMap(s=>s.vals);\nconst x = d3.scaleLinear().domain([0,11]).range([0,iw]);\nconst y = d3.scaleLinear().domain([d3.min(allV)*0.88, d3.max(allV)*1.05]).range([ih,0]).nice();\nconst lineGen = d3.line().x((_,i)=>x(i)).y(v=>y(v)).curve(d3.curveMonotoneX);\nconst yTicks = y.ticks(5);\n\nconst grid = yTicks.map(t=>\n  `<line x1='0' y1='${y(t).toFixed(1)}' x2='${iw}' y2='${y(t).toFixed(1)}' stroke='${GRID}' stroke-dasharray='3,3'/>`\n).join('');\n\nconst lines = series.map(s=>{\n  const path = lineGen(s.vals);\n  const dots = s.vals.map((v,i)=>`<circle cx='${x(i).toFixed(1)}' cy='${y(v).toFixed(1)}' r='3.5' fill='${s.color}'/>`).join('');\n  return `<path d='${path}' fill='none' stroke='${s.color}' stroke-width='2.5'/>${dots}`;\n}).join('');\n\nconst xLbls = months.map((m,i)=>\n  `<text x='${x(i).toFixed(1)}' y='${ih+15}' text-anchor='middle' font-size='10' fill='${TXT}'>${m}</text>`\n).join('');\nconst yLbls = yTicks.map(t=>\n  `<text x='-8' y='${(y(t)+4).toFixed(1)}' text-anchor='end' font-size='11' fill='${TXT}'>${t}</text>`\n).join('');\nconst legend = series.map((s,i)=>\n  `<rect x='${iw+12}' y='${i*24}' width='14' height='14' fill='${s.color}' rx='3'/>`\n+ `<text x='${iw+30}' y='${i*24+11}' font-size='12' fill='${TXT}'>${s.name}</text>`\n).join('');\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${(W-100)/2}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>Stock Performance 2024 — Line Chart</text>\n  <g transform='translate(${ml},${mt})'>\n    ${grid}${lines}\n    <line x1='0' y1='${ih}' x2='${iw}' y2='${ih}' stroke='#3a3a6a'/>\n    <line x1='0' y1='0' x2='0' y2='${ih}' stroke='#3a3a6a'/>\n    ${xLbls}${yLbls}${legend}\n    <text text-anchor='middle' fill='${TXT}' font-size='11' transform='translate(-42,${(ih/2).toFixed(0)}) rotate(-90)'>Price ($)</text>\n  </g>\n</svg>`);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "line-chart-multi-series-stock-perfo",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "── LINE CHART — Multi-series Stock Performance ───────────────────────────"
    },
    {
      "id": "jsc-scatter",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: scatter-plot-correlation-linear-r\n//@ description: ── SCATTER PLOT — Correlation + Linear Regression ───────────────────────\n// ── SCATTER PLOT — Correlation + Linear Regression ───────────────────────\nconst d3 = require('d3');\n\n// Seeded pseudo-random (reproducible)\nlet _s = 42;\nconst rng = () => { _s = (_s*1664525+1013904223)&0xffffffff; return (_s>>>0)/4294967296; };\nconst gauss = () => Math.sqrt(-2*Math.log(rng()+1e-9))*Math.cos(2*Math.PI*rng());\n\nconst groupA = Array.from({length:45}, ()=>({ x:155+rng()*30, y:52+rng()*25, g:'A' }));\nconst groupB = Array.from({length:45}, ()=>({ x:162+rng()*30, y:62+rng()*30, g:'B' }));\nconst data   = [...groupA, ...groupB];\n\nconst W=680, H=360, ml=60, mt=42, mr=125, mb=50;\nconst iw=W-ml-mr, ih=H-mt-mb;\nconst BG='#13131f', GRID='#252540', TXT='#8888aa', TTL='#cdd6f4';\n\nconst x = d3.scaleLinear().domain([d3.min(data,d=>d.x)-2, d3.max(data,d=>d.x)+2]).range([0,iw]).nice();\nconst y = d3.scaleLinear().domain([d3.min(data,d=>d.y)-2, d3.max(data,d=>d.y)+2]).range([ih,0]).nice();\n\n// Least-squares regression\nconst n=data.length, mx=d3.mean(data,d=>d.x), my=d3.mean(data,d=>d.y);\nconst slope = data.reduce((s,d)=>s+(d.x-mx)*(d.y-my),0) / data.reduce((s,d)=>s+(d.x-mx)**2,0);\nconst intercept = my - slope*mx;\nconst [rx0,rx1] = x.domain();\nconst regLine = `<line x1='${x(rx0).toFixed(1)}' y1='${y(intercept+slope*rx0).toFixed(1)}'\n  x2='${x(rx1).toFixed(1)}' y2='${y(intercept+slope*rx1).toFixed(1)}'\n  stroke='#f59e0b' stroke-width='2' stroke-dasharray='6,3'/>`;\n\n// R²\nconst ssTot = data.reduce((s,d)=>s+(d.y-my)**2,0);\nconst ssRes = data.reduce((s,d)=>s+(d.y-(intercept+slope*d.x))**2,0);\nconst r2 = (1-ssRes/ssTot).toFixed(3);\n\nconst COLS = {A:'#7c3aed', B:'#06b6d4'};\nconst dots = data.map(d=>\n  `<circle cx='${x(d.x).toFixed(1)}' cy='${y(d.y).toFixed(1)}' r='4.5' fill='${COLS[d.g]}' fill-opacity='0.72'/>`\n).join('');\n\nconst yTicks = y.ticks(5), xTicks = x.ticks(5);\nconst grid = yTicks.map(t=>`<line x1='0' y1='${y(t).toFixed(1)}' x2='${iw}' y2='${y(t).toFixed(1)}' stroke='${GRID}' stroke-dasharray='3,3'/>`).join('');\nconst xLbls = xTicks.map(t=>`<text x='${x(t).toFixed(1)}' y='${ih+15}' text-anchor='middle' font-size='11' fill='${TXT}'>${t.toFixed(0)}</text>`).join('');\nconst yLbls = yTicks.map(t=>`<text x='-8' y='${(y(t)+4).toFixed(1)}' text-anchor='end' font-size='11' fill='${TXT}'>${t.toFixed(0)}</text>`).join('');\n\nconst legend =\n  `<circle cx='${iw+18}' cy='6'  r='6' fill='${COLS.A}' fill-opacity='0.8'/><text x='${iw+30}' y='11' font-size='12' fill='${TXT}'>Group A</text>`\n+ `<circle cx='${iw+18}' cy='28' r='6' fill='${COLS.B}' fill-opacity='0.8'/><text x='${iw+30}' y='33' font-size='12' fill='${TXT}'>Group B</text>`\n+ `<line x1='${iw+10}' y1='52' x2='${iw+26}' y2='52' stroke='#f59e0b' stroke-width='2' stroke-dasharray='5,2'/><text x='${iw+30}' y='56' font-size='12' fill='${TXT}'>Trend</text>`\n+ `<text x='${iw+10}' y='76' font-size='11' fill='${TXT}'>R²=${r2}</text>`\n+ `<text x='${iw+10}' y='93' font-size='11' fill='${TXT}'>m=${slope.toFixed(2)}</text>`;\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${(W-110)/2}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>Height vs Weight — Scatter Plot + Regression</text>\n  <g transform='translate(${ml},${mt})'>\n    ${grid}${regLine}${dots}\n    <line x1='0' y1='${ih}' x2='${iw}' y2='${ih}' stroke='#3a3a6a'/>\n    <line x1='0' y1='0' x2='0' y2='${ih}' stroke='#3a3a6a'/>\n    ${xLbls}${yLbls}${legend}\n    <text text-anchor='middle' fill='${TXT}' font-size='11' transform='translate(-44,${(ih/2).toFixed(0)}) rotate(-90)'>Weight (kg)</text>\n    <text x='${iw/2}' y='${ih+38}' text-anchor='middle' font-size='11' fill='${TXT}'>Height (cm)</text>\n  </g>\n</svg>`);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "scatter-plot-correlation-linear-r",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "── SCATTER PLOT — Correlation + Linear Regression ───────────────────────"
    },
    {
      "id": "jsc-histogram",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: histogram-normal-distribution-with\n//@ description: ── HISTOGRAM — Normal Distribution with Bell Curve ─────────────────────\n// ── HISTOGRAM — Normal Distribution with Bell Curve ─────────────────────\nconst d3 = require('d3');\n\nlet _s = 99;\nconst rng = () => { _s=(_s*1664525+1013904223)&0xffffffff; return (_s>>>0)/4294967296; };\nconst gauss = () => Math.sqrt(-2*Math.log(rng()+1e-9))*Math.cos(2*Math.PI*rng());\n\nconst MU=170, SIGMA=10;\nconst raw = Array.from({length:500}, ()=>MU+gauss()*SIGMA);\n\nconst W=680, H=350, ml=58, mt=42, mr=22, mb=50;\nconst iw=W-ml-mr, ih=H-mt-mb;\nconst BG='#13131f', GRID='#252540', TXT='#8888aa', TTL='#cdd6f4';\n\nconst x = d3.scaleLinear().domain([d3.min(raw)-2, d3.max(raw)+2]).range([0,iw]).nice();\nconst bins = d3.bin().domain(x.domain()).thresholds(x.ticks(28))(raw);\nconst y = d3.scaleLinear().domain([0, d3.max(bins,b=>b.length)]).range([ih,0]).nice();\n\nconst yTicks = y.ticks(5), xTicks = x.ticks(6);\nconst grid = yTicks.map(t=>`<line x1='0' y1='${y(t).toFixed(1)}' x2='${iw}' y2='${y(t).toFixed(1)}' stroke='${GRID}' stroke-dasharray='3,3'/>`).join('');\nconst yLbls = yTicks.map(t=>`<text x='-8' y='${(y(t)+4).toFixed(1)}' text-anchor='end' font-size='11' fill='${TXT}'>${t}</text>`).join('');\nconst xLbls = xTicks.map(t=>`<text x='${x(t).toFixed(1)}' y='${ih+15}' text-anchor='middle' font-size='11' fill='${TXT}'>${t.toFixed(0)}</text>`).join('');\n\nconst bars = bins.map(b=>{\n  const bx = x(b.x0).toFixed(1);\n  const bw = Math.max(0, x(b.x1)-x(b.x0)-1).toFixed(1);\n  const by = y(b.length).toFixed(1);\n  const bh = (ih-y(b.length)).toFixed(1);\n  const mid = (b.x0+b.x1)/2;\n  const z   = Math.abs(mid-MU)/SIGMA;\n  const col = z<1 ? '#7c3aed' : z<2 ? '#9b59b6' : '#5a3a8a';\n  return `<rect x='${bx}' y='${by}' width='${bw}' height='${bh}' fill='${col}' fill-opacity='0.82' rx='1'/>`;\n}).join('');\n\n// Bell curve overlay\nconst binW = bins.length>0 ? (bins[0].x1-bins[0].x0) : 1;\nconst bellPts = Array.from({length:120},(_,i)=>{\n  const xv = x.domain()[0] + (x.domain()[1]-x.domain()[0])*(i/119);\n  const density = Math.exp(-0.5*((xv-MU)/SIGMA)**2) / (SIGMA*Math.sqrt(2*Math.PI));\n  return `${x(xv).toFixed(1)},${y(density*raw.length*binW).toFixed(1)}`;\n}).join(' ');\nconst bell = `<polyline points='${bellPts}' fill='none' stroke='#f59e0b' stroke-width='2.5'/>`;\n\n// Annotation lines\nconst mx = x(MU).toFixed(1);\nconst s1a = x(MU-SIGMA).toFixed(1), s1b = x(MU+SIGMA).toFixed(1);\nconst s2a = x(MU-2*SIGMA).toFixed(1), s2b = x(MU+2*SIGMA).toFixed(1);\nconst annot =\n  `<line x1='${mx}' y1='0' x2='${mx}' y2='${ih}' stroke='#ef4444' stroke-width='1.5' stroke-dasharray='5,3'/>`\n+ `<text x='${parseFloat(mx)+4}' y='13' font-size='10' fill='#ef4444'>μ=${MU}</text>`\n+ `<line x1='${s1a}' y1='0' x2='${s1a}' y2='${ih}' stroke='#10b981' stroke-width='1' stroke-dasharray='4,3'/>`\n+ `<line x1='${s1b}' y1='0' x2='${s1b}' y2='${ih}' stroke='#10b981' stroke-width='1' stroke-dasharray='4,3'/>`\n+ `<text x='${parseFloat(s1b)+4}' y='26' font-size='10' fill='#10b981'>±1σ</text>`\n+ `<line x1='${s2a}' y1='0' x2='${s2a}' y2='${ih}' stroke='#3a7a5a' stroke-width='1' stroke-dasharray='3,4'/>`\n+ `<line x1='${s2b}' y1='0' x2='${s2b}' y2='${ih}' stroke='#3a7a5a' stroke-width='1' stroke-dasharray='3,4'/>`\n+ `<text x='${parseFloat(s2b)+4}' y='40' font-size='10' fill='#3a7a5a'>±2σ</text>`;\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${W/2}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>Height Distribution (N=500) — Histogram + Bell Curve</text>\n  <g transform='translate(${ml},${mt})'>\n    ${grid}${bars}${bell}${annot}\n    <line x1='0' y1='${ih}' x2='${iw}' y2='${ih}' stroke='#3a3a6a'/>\n    <line x1='0' y1='0' x2='0' y2='${ih}' stroke='#3a3a6a'/>\n    ${xLbls}${yLbls}\n    <text text-anchor='middle' fill='${TXT}' font-size='11' transform='translate(-44,${(ih/2).toFixed(0)}) rotate(-90)'>Count</text>\n    <text x='${iw/2}' y='${ih+38}' text-anchor='middle' font-size='11' fill='${TXT}'>Height (cm)</text>\n  </g>\n</svg>`);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "histogram-normal-distribution-with",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "── HISTOGRAM — Normal Distribution with Bell Curve ─────────────────────"
    },
    {
      "id": "jsc-donut",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: donut-chart-market-share\n//@ description: ── DONUT CHART — Market Share ────────────────────────────────────────────\n// ── DONUT CHART — Market Share ────────────────────────────────────────────\nconst d3 = require('d3');\n\nconst data = [\n  {label:'VenusAI',  value:34, color:'#7c3aed'},\n  {label:'CloudSys', value:28, color:'#06b6d4'},\n  {label:'DataFlow', value:19, color:'#10b981'},\n  {label:'NetPulse', value:12, color:'#f59e0b'},\n  {label:'Others',   value:7,  color:'#6b7280'}\n];\n\nconst W=680, H=380;\nconst cx=W/2-80, cy=H/2+8;\nconst outerR=140, innerR=72;\nconst BG='#13131f', TXT='#8888aa', TTL='#cdd6f4';\n\nconst pie = d3.pie().value(d=>d.value).sort(null);\nconst arc = d3.arc().innerRadius(innerR).outerRadius(outerR);\nconst labelArc = d3.arc().innerRadius(outerR+22).outerRadius(outerR+22);\nconst hoverArc = d3.arc().innerRadius(innerR).outerRadius(outerR+6);\n\nconst arcs = pie(data);\nconst slices = arcs.map(a=>{\n  const pathD = arc(a);\n  const [lx,ly] = labelArc.centroid(a);\n  const pct = ((a.endAngle-a.startAngle)/(2*Math.PI)*100).toFixed(1);\n  const lbl = pct>5 ? `<text x='${lx.toFixed(1)}' y='${(ly+4).toFixed(1)}' text-anchor='middle' font-size='11' fill='${TXT}'>${pct}%</text>` : '';\n  return `<path d='${pathD}' fill='${a.data.color}' stroke='${BG}' stroke-width='2.5'/>${lbl}`;\n}).join('');\n\nconst legend = data.map((d,i)=>{\n  const ly = (H-data.length*28)/2 + i*28;\n  return `<rect x='${W-162}' y='${ly}' width='15' height='15' fill='${d.color}' rx='3'/>`\n       + `<text x='${W-143}' y='${ly+12}' font-size='12' fill='${TXT}'>${d.label}</text>`\n       + `<text x='${W-30}'  y='${ly+12}' text-anchor='end' font-size='12' fill='${d.color}' font-weight='600'>${d.value}%</text>`;\n}).join('');\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${cx}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>Market Share — Donut Chart</text>\n  <g transform='translate(${cx},${cy})'>${slices}</g>\n  <text x='${cx}' y='${cy-10}' text-anchor='middle' font-size='22' font-weight='bold' fill='${TTL}'>100%</text>\n  <text x='${cx}' y='${cy+14}' text-anchor='middle' font-size='11' fill='${TXT}'>Market Total</text>\n  ${legend}\n</svg>`);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "donut-chart-market-share",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "── DONUT CHART — Market Share ────────────────────────────────────────────"
    },
    {
      "id": "jsc-heatmap",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: heatmap-feature-correlation-matrix\n//@ description: ── HEATMAP — Feature Correlation Matrix ─────────────────────────────────\n// ── HEATMAP — Feature Correlation Matrix ─────────────────────────────────\nconst d3 = require('d3');\n\nconst labels = ['Revenue','Users','Sessions','Conversions','Retention'];\nconst matrix = [\n  [1.00, 0.87, 0.82, 0.73, 0.65],\n  [0.87, 1.00, 0.91, 0.68, 0.72],\n  [0.82, 0.91, 1.00, 0.74, 0.69],\n  [0.73, 0.68, 0.74, 1.00, 0.81],\n  [0.65, 0.72, 0.69, 0.81, 1.00]\n];\n\nconst n=labels.length;\nconst W=540, H=460, ml=110, mt=90, mr=20, mb=20;\nconst iw=W-ml-mr, ih=H-mt-mb;\nconst cw=iw/n, ch=ih/n;\nconst BG='#13131f', TXT='#8888aa', TTL='#cdd6f4';\n\n// Color: low=cool blue, high=vivid purple\nconst colorScale = d3.scaleSequential().domain([0.55,1.0]).interpolator(\n  t => `hsl(${(260-t*40).toFixed(0)},${(40+t*45).toFixed(0)}%,${(25+t*30).toFixed(0)}%)`\n);\n\nconst cells = matrix.flatMap((row,i)=>row.map((val,j)=>{\n  const color = colorScale(val);\n  const tc = val>0.78 ? '#e8d8ff' : '#9090b8';\n  const fw = val===1.0 ? 'bold' : 'normal';\n  return `<rect x='${(j*cw).toFixed(1)}' y='${(i*ch).toFixed(1)}' width='${cw.toFixed(1)}' height='${ch.toFixed(1)}' fill='${color}' stroke='${BG}' stroke-width='2.5'/>`\n       + `<text x='${(j*cw+cw/2).toFixed(1)}' y='${(i*ch+ch/2+5).toFixed(1)}' text-anchor='middle' font-size='13' font-weight='${fw}' fill='${tc}'>${val.toFixed(2)}</text>`;\n})).join('');\n\nconst rowLbls = labels.map((l,i)=>\n  `<text x='-8' y='${(i*ch+ch/2+5).toFixed(1)}' text-anchor='end' font-size='12' fill='${TXT}'>${l}</text>`\n).join('');\nconst colLbls = labels.map((l,i)=>{\n  const cx2 = (i*cw+cw/2).toFixed(1);\n  return `<text x='${cx2}' y='-14' text-anchor='middle' font-size='12' fill='${TXT}' transform='rotate(-35,${cx2},-14)'>${l}</text>`;\n}).join('');\n\n// Color legend bar\nconst gradStops = Array.from({length:10},(_,k)=>{\n  const t=k/9;\n  const v = 0.55+t*0.45;\n  return `<stop offset='${(t*100).toFixed(0)}%' stop-color='${colorScale(v)}'/>` ;\n}).join('');\nconst legend =\n  `<defs><linearGradient id='lg' x1='0' x2='1'>${gradStops}</linearGradient></defs>`\n+ `<rect x='${ml}' y='${H-16}' width='${iw}' height='12' fill='url(#lg)' rx='3'/>`\n+ `<text x='${ml}' y='${H-20}' font-size='10' fill='${TXT}'>0.55</text>`\n+ `<text x='${ml+iw}' y='${H-20}' text-anchor='end' font-size='10' fill='${TXT}'>1.00</text>`;\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${W/2}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>Feature Correlation Matrix — Heatmap</text>\n  <g transform='translate(${ml},${mt})'>${cells}${rowLbls}${colLbls}</g>\n  ${legend}\n</svg>`);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "heatmap-feature-correlation-matrix",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "── HEATMAP — Feature Correlation Matrix ─────────────────────────────────"
    },
    {
      "id": "jsc-boxplot",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: box-plot-a-b-c-test-comparison\n//@ description: ── BOX PLOT — A/B/C Test Comparison ─────────────────────────────────────\n// ── BOX PLOT — A/B/C Test Comparison ─────────────────────────────────────\nconst d3 = require('d3');\n\nlet _s = 77;\nconst rng = () => { _s=(_s*1664525+1013904223)&0xffffffff; return (_s>>>0)/4294967296; };\nconst gauss = () => Math.sqrt(-2*Math.log(rng()+1e-9))*Math.cos(2*Math.PI*rng());\n\nconst groups = [\n  { name:'Control',     color:'#7c3aed', data: Array.from({length:60}, ()=>50+gauss()*8)   },\n  { name:'Treatment A', color:'#06b6d4', data: Array.from({length:60}, ()=>58+gauss()*7)   },\n  { name:'Treatment B', color:'#10b981', data: Array.from({length:60}, ()=>55+gauss()*12)  },\n  { name:'Treatment C', color:'#f59e0b', data: Array.from({length:60}, ()=>63+gauss()*5.5) }\n];\n\nconst W=680, H=360, ml=58, mt=42, mr=22, mb=55;\nconst iw=W-ml-mr, ih=H-mt-mb;\nconst BG='#13131f', GRID='#252540', TXT='#8888aa', TTL='#cdd6f4';\n\nconst allV = groups.flatMap(g=>g.data);\nconst x = d3.scaleBand().domain(groups.map(g=>g.name)).range([0,iw]).padding(0.35);\nconst y = d3.scaleLinear().domain([d3.min(allV)-3, d3.max(allV)+3]).range([ih,0]).nice();\n\nconst fiveNum = arr => {\n  const s = [...arr].sort((a,b)=>a-b);\n  const q1=d3.quantile(s,0.25), q3=d3.quantile(s,0.75), iqr=q3-q1;\n  return {\n    q1, q2:d3.quantile(s,0.50), q3, iqr,\n    lo: Math.max(s[0], q1-1.5*iqr),\n    hi: Math.min(s[s.length-1], q3+1.5*iqr),\n    outliers: s.filter(v=>v<q1-1.5*iqr||v>q3+1.5*iqr)\n  };\n};\n\nconst yTicks = y.ticks(6);\nconst grid = yTicks.map(t=>`<line x1='0' y1='${y(t).toFixed(1)}' x2='${iw}' y2='${y(t).toFixed(1)}' stroke='${GRID}' stroke-dasharray='3,3'/>`).join('');\nconst yLbls = yTicks.map(t=>`<text x='-8' y='${(y(t)+4).toFixed(1)}' text-anchor='end' font-size='11' fill='${TXT}'>${t.toFixed(0)}</text>`).join('');\n\nconst boxes = groups.map(g=>{\n  const st = fiveNum(g.data);\n  const bx=x(g.name), bw=x.bandwidth(), mid=bx+bw/2;\n  const [qTop,qBot] = [y(st.q3),y(st.q1)];\n  const [hiY,loY,medY] = [y(st.hi),y(st.lo),y(st.q2)];\n  const outlierDots = st.outliers.map(v=>`<circle cx='${mid.toFixed(1)}' cy='${y(v).toFixed(1)}' r='3.5' fill='none' stroke='${g.color}' stroke-width='1.5'/>`).join('');\n  return [\n    `<rect x='${bx.toFixed(1)}' y='${qTop.toFixed(1)}' width='${bw.toFixed(1)}' height='${(qBot-qTop).toFixed(1)}' fill='${g.color}' fill-opacity='0.28' stroke='${g.color}' stroke-width='2' rx='3'/>`,\n    `<line x1='${bx.toFixed(1)}' y1='${medY.toFixed(1)}' x2='${(bx+bw).toFixed(1)}' y2='${medY.toFixed(1)}' stroke='${g.color}' stroke-width='2.8'/>`,\n    `<line x1='${mid.toFixed(1)}' y1='${qTop.toFixed(1)}' x2='${mid.toFixed(1)}' y2='${hiY.toFixed(1)}' stroke='${g.color}' stroke-width='1.5' stroke-dasharray='4,2'/>`,\n    `<line x1='${mid.toFixed(1)}' y1='${qBot.toFixed(1)}' x2='${mid.toFixed(1)}' y2='${loY.toFixed(1)}' stroke='${g.color}' stroke-width='1.5' stroke-dasharray='4,2'/>`,\n    `<line x1='${(mid-9).toFixed(1)}' y1='${hiY.toFixed(1)}' x2='${(mid+9).toFixed(1)}' y2='${hiY.toFixed(1)}' stroke='${g.color}' stroke-width='2'/>`,\n    `<line x1='${(mid-9).toFixed(1)}' y1='${loY.toFixed(1)}' x2='${(mid+9).toFixed(1)}' y2='${loY.toFixed(1)}' stroke='${g.color}' stroke-width='2'/>`,\n    outlierDots,\n    `<text x='${mid.toFixed(1)}' y='${ih+18}' text-anchor='middle' font-size='11' fill='${TXT}'>${g.name}</text>`,\n    `<text x='${mid.toFixed(1)}' y='${ih+33}' text-anchor='middle' font-size='10' fill='${g.color}'>med=${st.q2.toFixed(1)}</text>`\n  ].join('');\n}).join('');\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${W/2}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>A/B/C Test Results — Box Plot</text>\n  <g transform='translate(${ml},${mt})'>\n    ${grid}${boxes}\n    <line x1='0' y1='${ih}' x2='${iw}' y2='${ih}' stroke='#3a3a6a'/>\n    <line x1='0' y1='0' x2='0' y2='${ih}' stroke='#3a3a6a'/>\n    ${yLbls}\n    <text text-anchor='middle' fill='${TXT}' font-size='11' transform='translate(-44,${(ih/2).toFixed(0)}) rotate(-90)'>Score</text>\n  </g>\n</svg>`);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "box-plot-a-b-c-test-comparison",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "── BOX PLOT — A/B/C Test Comparison ─────────────────────────────────────"
    },
    {
      "id": "jsc-area",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: area-chart-multi-channel-website-tr\n//@ description: ── AREA CHART — Multi-channel Website Traffic ────────────────────────────\n// ── AREA CHART — Multi-channel Website Traffic ────────────────────────────\nconst d3 = require('d3');\n\nlet _s = 55;\nconst rng = () => { _s=(_s*1664525+1013904223)&0xffffffff; return (_s>>>0)/4294967296; };\n\nconst N=30;\nconst days=Array.from({length:N},(_,i)=>i);\nconst organic = days.map(i=>Math.round(1200+i*15+(rng()-0.5)*220));\nconst paid    = days.map(i=>Math.round(800 +i*10+(rng()-0.5)*160));\nconst direct  = days.map(i=>Math.round(500 +i*5 +(rng()-0.5)*110));\n\nconst W=680, H=340, ml=60, mt=42, mr=120, mb=45;\nconst iw=W-ml-mr, ih=H-mt-mb;\nconst BG='#13131f', GRID='#252540', TXT='#8888aa', TTL='#cdd6f4';\n\nconst allV=[...organic,...paid,...direct];\nconst x = d3.scaleLinear().domain([0,N-1]).range([0,iw]);\nconst y = d3.scaleLinear().domain([0, d3.max(allV)*1.1]).range([ih,0]).nice();\n\nconst areaFn = vals => d3.area().x((_,i)=>x(i)).y0(y(0)).y1(v=>y(v)).curve(d3.curveMonotoneX)(vals);\nconst lineFn  = vals => d3.line().x((_,i)=>x(i)).y(v=>y(v)).curve(d3.curveMonotoneX)(vals);\n\nconst layers = [\n  { vals:organic, color:'#7c3aed', name:'Organic' },\n  { vals:paid,    color:'#06b6d4', name:'Paid'    },\n  { vals:direct,  color:'#10b981', name:'Direct'  }\n];\n\nconst areas = layers.map(l=>\n  `<path d='${areaFn(l.vals)}' fill='${l.color}' fill-opacity='0.2'/>`\n+ `<path d='${lineFn(l.vals)}' fill='none' stroke='${l.color}' stroke-width='2.5'/>`\n).join('');\n\nconst xTicks=[0,5,10,15,20,25,29];\nconst yTicks=y.ticks(5);\nconst grid = yTicks.map(t=>`<line x1='0' y1='${y(t).toFixed(1)}' x2='${iw}' y2='${y(t).toFixed(1)}' stroke='${GRID}' stroke-dasharray='3,3'/>`).join('');\nconst yLbls = yTicks.map(t=>`<text x='-8' y='${(y(t)+4).toFixed(1)}' text-anchor='end' font-size='11' fill='${TXT}'>${(t/1000).toFixed(1)}k</text>`).join('');\nconst xLbls = xTicks.map(t=>`<text x='${x(t).toFixed(1)}' y='${ih+15}' text-anchor='middle' font-size='11' fill='${TXT}'>Day ${t+1}</text>`).join('');\n\nconst legend = layers.map((l,i)=>\n  `<rect x='${iw+10}' y='${i*24}' width='14' height='14' fill='${l.color}' rx='3' fill-opacity='0.85'/>`\n+ `<text x='${iw+28}' y='${i*24+11}' font-size='12' fill='${TXT}'>${l.name}</text>`\n).join('');\n\n// End-of-period summary\nconst summary = layers.map((l,i)=>{\n  const last=l.vals[N-1], first=l.vals[0];\n  const pct=((last-first)/first*100).toFixed(0);\n  const sign=pct>0?'+':'';\n  return `<text x='${iw+28}' y='${i*24+24}' font-size='10' fill='${pct>0?\"#10b981\":\"#ef4444\"}'>${sign}${pct}% </text>`;\n}).join('');\n\nvenus.html(`<svg xmlns='http://www.w3.org/2000/svg' width='${W}' height='${H}' style='background:${BG};border-radius:10px;font-family:system-ui,sans-serif'>\n  <text x='${(W-120)/2}' y='27' text-anchor='middle' font-size='14' font-weight='bold' fill='${TTL}'>Website Traffic by Channel — Area Chart</text>\n  <g transform='translate(${ml},${mt})'>\n    ${grid}${areas}\n    <line x1='0' y1='${ih}' x2='${iw}' y2='${ih}' stroke='#3a3a6a'/>\n    <line x1='0' y1='0' x2='0' y2='${ih}' stroke='#3a3a6a'/>\n    ${xLbls}${yLbls}${legend}${summary}\n    <text text-anchor='middle' fill='${TXT}' font-size='11' transform='translate(-46,${(ih/2).toFixed(0)}) rotate(-90)'>Sessions</text>\n  </g>\n</svg>`);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "area-chart-multi-channel-website-tr",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "── AREA CHART — Multi-channel Website Traffic ────────────────────────────"
    }
  ],
