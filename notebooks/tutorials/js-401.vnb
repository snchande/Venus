    {
      "id": "jsds-8",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: generate-readings\n//@ description: Defines the generateReadings function\nconst ss   = require('simple-statistics');\nconst { create, all } = require('mathjs');\nconst math = create(all);\n\n// Simulated sensor readings dataset\nfunction generateReadings(n, baseMean, noise) {\n  return Array.from({ length: n }, (_, i) => ({\n    timestamp: new Date(Date.now() + i * 60000).toISOString().slice(11,19),\n    sensor: 'T-' + (Math.floor(i / 10) + 1),\n    value: +(baseMean + (Math.random() - 0.5) * noise * 2).toFixed(2)\n  }));\n}\n\nconst readings = generateReadings(30, 22.5, 3);\nconsole.log('=== Sensor Data Analysis ===');\nconsole.log('Sample (first 5):');\nvenus.table(readings.slice(0, 5));\n\nconst values = readings.map(r => r.value);\nconsole.log('\\nStatistical Summary:');\nconsole.log(`  Readings: ${values.length}`);\nconsole.log(`  Mean:     ${ss.mean(values).toFixed(3)}`);\nconsole.log(`  Std Dev:  ${ss.standardDeviation(values).toFixed(3)}`);\nconsole.log(`  Range:    [${ss.min(values)}, ${ss.max(values)}]`);\nconsole.log(`  IQR:      ${(ss.quantile(values, 0.75) - ss.quantile(values, 0.25)).toFixed(3)}`);\n\n// Detect outliers using z-score\nconst mean = ss.mean(values);\nconst std  = ss.standardDeviation(values);\nconst outliers = readings.filter(r => Math.abs((r.value - mean) / std) > 2);\nconsole.log(`\\nOutliers (|z| > 2): ${outliers.length}`);\nif (outliers.length > 0) venus.table(outliers);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "generate-readings",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Defines the generateReadings function"
    }
