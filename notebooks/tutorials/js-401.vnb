    {
      "id": "jsds-1",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: check-that-packages-are-installed\n//@ description: Check that packages are installed\n// Check that packages are installed\ntry {\n  const ss   = require('simple-statistics');\n  const math = require('mathjs');\n  console.log('✓ simple-statistics', ss.version || 'installed');\n  console.log('✓ mathjs', math.version || 'installed');\n  console.log('\\nReady for data science!');\n} catch(e) {\n  console.error('Missing package:', e.message);\n  console.error('Go to Packages → npm tab and install: simple-statistics, mathjs');\n}",
