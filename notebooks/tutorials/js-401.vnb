    {
      "id": "jsds-5",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: math\n//@ description: Declares math variable\nconst { create, all } = require('mathjs');\nconst math = create(all);\n\nconsole.log('=== mathjs Basics ===');\n\n// Expression evaluation\nconsole.log(math.evaluate('12 / (2.3 + 0.7)'));         // 4\nconsole.log(math.evaluate('sqrt(3^2 + 4^2)'));           // 5\nconsole.log(math.evaluate('log(1000, 10)'));             // 3\nconsole.log(math.format(math.evaluate('e^(pi*i) + 1'))); // ~0\n\n// Unit conversions\nconsole.log('\\n=== Unit Conversions ===');\nconsole.log(math.evaluate('100 km/h to mi/h').toString());\nconsole.log(math.evaluate('1 kg to lbs').toString());\nconsole.log(math.evaluate('100 degF to degC').toString());\nconsole.log(math.evaluate('1 atm to Pa').toString());",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "math",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Declares math variable"
    },
    {
      "id": "jsds-6",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: matrix-operations\n//@ description: Matrix operations\nconst { create, all } = require('mathjs');\nconst math = create(all);\n\n// Matrix operations\nconsole.log('=== Matrix Operations ===');\n\nconst A = math.matrix([[1, 2], [3, 4]]);\nconst B = math.matrix([[5, 6], [7, 8]]);\n\nconsole.log('A =', math.format(A));\nconsole.log('B =', math.format(B));\nconsole.log('A + B =', math.format(math.add(A, B)));\nconsole.log('A * B =', math.format(math.multiply(A, B)));\nconsole.log('det(A) =', math.det(A));\nconsole.log('inv(A) =', math.format(math.inv(A)));\nconsole.log('transpose(A) =', math.format(math.transpose(A)));\n\n// Eigenvalues\nconst sym = math.matrix([[4, -2], [-2, 3]]);\nconst eig = math.eigs(sym);\nconsole.log('\\nEigenvalues of [[4,-2],[-2,3]]:', math.format(eig.values));",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "matrix-operations",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Matrix operations"
    },
    {
      "id": "jsds-7",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: statistics-functions-in-mathjs\n//@ description: Statistics functions in mathjs\nconst { create, all } = require('mathjs');\nconst math = create(all);\n\n// Statistics functions in mathjs\nconsole.log('=== mathjs Statistics ===');\n\nconst data = [2, 4, 4, 4, 5, 5, 7, 9];\nconsole.log('Data:', data);\nconsole.log('Mean:', math.mean(data));\nconsole.log('Median:', math.median(data));\nconsole.log('Std (sample):', math.std(data).toFixed(4));\nconsole.log('Variance:', math.variance(data).toFixed(4));\nconsole.log('Mad (mean abs dev):', math.mad(data).toFixed(4));\n\n// Number formatting\nconsole.log('\\n=== Number Formatting ===');\nconsole.log(math.format(1.23456789e-7, { notation: 'engineering' }));\nconsole.log(math.format(1234567, { notation: 'fixed', precision: 0 }));\nconsole.log(math.format(math.pi, 10));",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "statistics-functions-in-mathjs",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Statistics functions in mathjs"
    },
    {
