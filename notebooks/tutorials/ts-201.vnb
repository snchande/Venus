{
  "id": "ts-201",
  "name": "TypeScript Intermediate — Generics, Classes, Unions",
  "description": "Generics, classes, modules, union & intersection types — the daily-driver TypeScript toolbox",
  "cells": [
    {
      "id": "ts-201-md-1",
      "type": "MARKDOWN",
      "source": "# TypeScript 201 — The Daily-Driver Toolbox\n\nThis notebook covers the features you reach for every day:\n\n1. **Generics** — write functions and classes that work for many types without losing type safety\n2. **Classes** — including access modifiers and parameter properties\n3. **Union & intersection types** — `A | B` and `A & B`\n4. **Discriminated unions** + exhaustiveness checking\n5. **Type narrowing** with `typeof`, `instanceof`, and `in`\n6. **Utility types** — `Partial`, `Pick`, `Omit`, `ReturnType`",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-201-1",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: generic-functions\n//@ description: Generic functions — type-safe identity and pair\n\nfunction identity<T>(value: T): T { return value; }\n\nfunction pair<A, B>(a: A, b: B): [A, B] { return [a, b]; }\n\nfunction firstOrNull<T>(arr: T[]): T | null {\n  return arr.length === 0 ? null : arr[0];\n}\n\nconsole.log(identity<string>(\"venus\"));\nconsole.log(identity(99));            // T inferred to number\nconsole.log(pair(\"answer\", 42));\nconsole.log(firstOrNull<number>([10, 20, 30]));\nconsole.log(firstOrNull([]));",
      "output": "",
      "executed": false,
      "anchor": "generic-functions",
      "description": "Generic functions — type-safe identity and pair"
    },
    {
      "id": "ts-201-2",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: generic-classes\n//@ description: A typed Stack<T> with constraints\n\nclass Stack<T> {\n  private items: T[] = [];\n  push(item: T): void { this.items.push(item); }\n  pop(): T | undefined { return this.items.pop(); }\n  peek(): T | undefined { return this.items.at(-1); }\n  get size(): number { return this.items.length; }\n  toArray(): readonly T[] { return [...this.items]; }\n}\n\nconst nums = new Stack<number>();\nnums.push(1); nums.push(2); nums.push(3);\nconsole.log(\"size:\", nums.size, \"peek:\", nums.peek());\nconsole.log(\"popped:\", nums.pop());\nconsole.log(\"after pop:\", nums.toArray().join(\", \"));\n\nconst names = new Stack<string>();\nnames.push(\"Alice\");\nnames.push(\"Bob\");\nconsole.log(\"names:\", names.toArray().join(\", \"));",
      "output": "",
      "executed": false,
      "anchor": "generic-classes",
      "description": "A typed Stack<T> with constraints"
    },
    {
      "id": "ts-201-md-2",
      "type": "MARKDOWN",
      "source": "## Union and intersection types\n\n- A **union** `A | B` is *either* type — narrow with `typeof`/`instanceof`/`in`\n- An **intersection** `A & B` is *both* types at once — merges shapes",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-201-3",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: unions-intersections\n//@ description: Union narrowing & intersection merging\n\nfunction len(x: string | string[]): number {\n  return typeof x === \"string\" ? x.length : x.length;\n}\n\ninterface Timestamped { createdAt: Date; }\ninterface Tagged      { tags: string[]; }\n\ntype Post = { title: string; body: string } & Timestamped & Tagged;\n\nconst post: Post = {\n  title: \"Hello TS\",\n  body:  \"Intersections merge fields from all parts.\",\n  createdAt: new Date(\"2026-05-10T00:00:00Z\"),\n  tags: [\"typescript\", \"venus\"],\n};\n\nconsole.log(\"len('venus') =\", len(\"venus\"));\nconsole.log(\"len(array) =\", len([\"a\",\"b\",\"c\"]));\nconsole.log(\"post:\", post.title, \"— tags:\", post.tags.join(\", \"));",
      "output": "",
      "executed": false,
      "anchor": "unions-intersections",
      "description": "Union narrowing & intersection merging"
    },
    {
      "id": "ts-201-md-3",
      "type": "MARKDOWN",
      "source": "## Discriminated unions + exhaustiveness\n\nGive every variant in a union a unique tag field, then `switch` on it. TypeScript will refuse to compile if a new variant is added but not handled.",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-201-4",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: discriminated-unions\n//@ description: Tagged unions with exhaustiveness check\n\ntype Shape =\n  | { kind: \"circle\";    radius: number }\n  | { kind: \"square\";    side:   number }\n  | { kind: \"rectangle\"; width:  number; height: number };\n\nfunction area(s: Shape): number {\n  switch (s.kind) {\n    case \"circle\":    return Math.PI * s.radius * s.radius;\n    case \"square\":    return s.side * s.side;\n    case \"rectangle\": return s.width * s.height;\n    default: {\n      const _exhaustive: never = s; // forces a compile error if a kind is forgotten\n      throw new Error(\"Unhandled shape: \" + JSON.stringify(_exhaustive));\n    }\n  }\n}\n\nconst shapes: Shape[] = [\n  { kind: \"circle\",    radius: 3 },\n  { kind: \"square\",    side:   4 },\n  { kind: \"rectangle\", width:  5, height: 6 },\n];\n\nshapes.forEach(s => console.log(s.kind.padEnd(10), \"area =\", area(s).toFixed(3)));",
      "output": "",
      "executed": false,
      "anchor": "discriminated-unions",
      "description": "Tagged unions with exhaustiveness check"
    },
    {
      "id": "ts-201-md-4",
      "type": "MARKDOWN",
      "source": "## Utility types\n\nTypeScript ships with a small library of *type transformers*: `Partial<T>`, `Required<T>`, `Pick<T,K>`, `Omit<T,K>`, `ReturnType<F>`, etc.",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-201-5",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: utility-types\n//@ description: Partial, Pick, Omit, ReturnType\n\ninterface User {\n  id: number;\n  name: string;\n  email: string;\n  passwordHash: string;\n}\n\n// Public-facing User — never expose passwordHash\ntype PublicUser = Omit<User, \"passwordHash\">;\n\n// PATCH payload — every field optional\ntype UserPatch = Partial<User>;\n\nfunction summarize(u: User) {\n  return { id: u.id, label: `${u.name} <${u.email}>` };\n}\ntype Summary = ReturnType<typeof summarize>;\n\nconst user: User = {\n  id: 1, name: \"Alice\", email: \"a@example.com\", passwordHash: \"x\"\n};\n\nconst pub: PublicUser = (() => { const { passwordHash, ...rest } = user; return rest; })();\nconst patch: UserPatch = { email: \"new@example.com\" };\nconst s: Summary = summarize(user);\n\nconsole.log(\"public:\", pub);\nconsole.log(\"patch:\",  patch);\nconsole.log(\"summary:\", s);",
      "output": "",
      "executed": false,
      "anchor": "utility-types",
      "description": "Partial, Pick, Omit, ReturnType"
    }
  ],
  "metadata": {
