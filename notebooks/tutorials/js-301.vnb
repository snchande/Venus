    {
      "id": "js-301-composition",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: function-composition\n//@ description: Function Composition\n// --- Function Composition ---\n// Compose: build a new function by chaining smaller functions together.\n// compose(f, g)(x) = f(g(x))   — right to left\n// pipe(f, g)(x)    = g(f(x))   — left to right (more readable for data pipelines)\n\n// Simple compose (right-to-left, like math notation: f∘g)\nconst compose = (...fns) => x => fns.reduceRight((acc, fn) => fn(acc), x);\n\n// pipe = compose in reverse (left-to-right, like a Unix pipe)\nconst pipe = (...fns) => x => fns.reduce((acc, fn) => fn(acc), x);\n\n// Building blocks — each is a pure, single-purpose function\nconst trim        = s => s.trim();\nconst toLower     = s => s.toLowerCase();\nconst removeSpaces = s => s.replace(/\\s+/g, '-');\nconst addPrefix   = prefix => s => `${prefix}${s}`;\nconst truncate    = max => s => s.length > max ? s.slice(0, max) + '...' : s;\n\n// Compose a URL-slug generator\nconst toSlug = pipe(\n    trim,\n    toLower,\n    removeSpaces,\n    addPrefix('post-'),\n    truncate(20)\n);\n\nconst titles = [\n    '  Hello World  ',\n    'Modern JavaScript Patterns',\n    '  Venus Notebooks Tutorial  ',\n    'A'\n];\n\nconsole.log('Slugs:');\ntitles.forEach(t => console.log(`  '${t}' → '${toSlug(t)}'`));\n\n// You can also compose predicates\nconst isString  = x => typeof x === 'string';\nconst isLong    = s => s.length > 5;\nconst hasVowel  = s => /[aeiou]/i.test(s);\n\nconst allPass = (...preds) => x => preds.every(p => p(x));\nconst anyPass = (...preds) => x => preds.some(p => p(x));\n\nconst isGoodWord = allPass(isString, isLong, hasVowel);\nconst words = ['hi', 'hello', 'rhythm', 'JavaScript', '123'];\nconsole.log('\\nGood words:', words.filter(isGoodWord));",
      "output": "",
      "returnValue": null,
      "executed": false,
