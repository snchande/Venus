      "description": "Pure Functions vs Side Effects"
    },
    {
      "id": "js-301-map-filter-reduce",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: map-filter-reduce-the-fp-trinity\n//@ description: map, filter, reduce — the FP trinity\n// --- map, filter, reduce — the FP trinity ---\n// These three array methods cover the vast majority of data transformation needs.\n// They are pure: they return new arrays/values, never mutate the original.\n\nconst products = [\n    { name: 'Widget',    price: 9.99,  qty: 100, category: 'hardware' },\n    { name: 'Gadget',    price: 24.99, qty: 25,  category: 'electronics' },\n    { name: 'Doohickey', price: 4.50,  qty: 500, category: 'hardware' },\n    { name: 'Thingamajig', price: 49.99, qty: 10, category: 'electronics' },\n    { name: 'Whatsit',   price: 1.99,  qty: 200, category: 'hardware' },\n];\n\n// map: transform each element, returns a new array of the same length\nconst names = products.map(p => p.name);\nconst withRevenue = products.map(p => ({ ...p, revenue: p.price * p.qty }));\nconsole.log('Names:', names);\nconsole.log('Revenue:', withRevenue.map(p => `${p.name}: $${p.revenue.toFixed(2)}`));\n\n// filter: keep elements that match a predicate, returns a shorter (or equal) array\nconst hardware = products.filter(p => p.category === 'hardware');\nconst expensive = products.filter(p => p.price > 20);\nconsole.log('\\nHardware products:', hardware.map(p => p.name));\nconsole.log('Expensive (>$20) :', expensive.map(p => p.name));\n\n// reduce: fold the array into a single value (number, string, object, array...)\n// reduce(callback, initialValue)\n// callback(accumulator, currentElement) → new accumulator\nconst totalRevenue = products.reduce((acc, p) => acc + p.price * p.qty, 0);\nconsole.log(`\\nTotal revenue: $${totalRevenue.toFixed(2)}`);\n\n// Build an index (object keyed by name) with reduce\nconst productIndex = products.reduce((acc, p) => {\n    acc[p.name] = p;    // acc is the object we're building up\n    return acc;\n}, {});\nconsole.log('Widget price:', productIndex['Widget'].price);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "map-filter-reduce-the-fp-trinity",
