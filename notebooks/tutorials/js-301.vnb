    {
      "id": "js-301-closures",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: closures-and-factory-functions\n//@ description: Closures and Factory Functions\n// --- Closures and Factory Functions ---\n// A CLOSURE is a function that remembers the variables from the scope where it was defined,\n// even after that outer scope has returned.\n// This is what makes higher-order functions and factory functions possible.\n\n// Factory function: returns a specialized function using a closure\nconst makeMultiplier = (factor) => {\n    // 'factor' is captured in the closure — stays alive as long as the returned function does\n    return (n) => n * factor;\n};\n\nconst double  = makeMultiplier(2);\nconst triple  = makeMultiplier(3);\nconst tenX    = makeMultiplier(10);\n\nconsole.log('double(7) :', double(7));   // 14\nconsole.log('triple(7) :', triple(7));   // 21\nconsole.log('tenX(7)   :', tenX(7));     // 70\n\n// Counter factory — private state via closure\nconst makeCounter = (start = 0, step = 1) => {\n    let count = start;  // private — not accessible from outside\n    return {\n        next:  () => { count += step; return count; },\n        reset: () => { count = start; },\n        value: () => count,\n    };\n};\n\nconst counter = makeCounter(0, 5);\nconsole.log('\\ncounter.next():', counter.next());   // 5\nconsole.log('counter.next():', counter.next());   // 10\nconsole.log('counter.next():', counter.next());   // 15\ncounter.reset();\nconsole.log('after reset:   ', counter.value());  // 0\n\n// Memoize: use a closure to cache expensive results\nconst memoize = (fn) => {\n    const cache = {};\n    return (...args) => {\n        const key = JSON.stringify(args);\n        if (key in cache) {\n            console.log(`  [cache hit] key=${key}`);\n            return cache[key];\n        }\n        cache[key] = fn(...args);\n        return cache[key];\n    };\n};\n\nconst slowSquare = memoize(n => { return n * n; });\nconsole.log('\\nslowSquare(5):', slowSquare(5));\nconsole.log('slowSquare(5):', slowSquare(5));   // cache hit",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "closures-and-factory-functions",
