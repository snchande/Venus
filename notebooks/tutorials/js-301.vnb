    {
      "id": "js-301-currying",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: currying-and-partial-application\n//@ description: Currying and Partial Application\n// --- Currying and Partial Application ---\n// CURRYING: transform f(a, b, c) into f(a)(b)(c)\n// Each call returns a new function waiting for the next argument.\n// WHY: enables partial application — pre-fill some arguments now, supply the rest later.\n\n// Manual curry\nconst curriedAdd = a => b => a + b;\nconst add10 = curriedAdd(10);   // partial: 'a' is fixed at 10\nconsole.log('add10(5)  :', add10(5));    // 15\nconsole.log('add10(32) :', add10(32));   // 42\n\n// Practical: a curried filter-builder\nconst filterBy = (key) => (value) => (arr) =>\n    arr.filter(item => item[key] === value);\n\nconst byCategory = filterBy('category');\nconst getHardware    = byCategory('hardware');\nconst getElectronics = byCategory('electronics');\n\nconst products = [\n    { name: 'Widget', category: 'hardware',    price: 9.99  },\n    { name: 'Gadget', category: 'electronics', price: 24.99 },\n    { name: 'Thingamajig', category: 'electronics', price: 49.99 },\n    { name: 'Doohickey',   category: 'hardware',    price: 4.50  },\n];\n\nconsole.log('Hardware:', getHardware(products).map(p => p.name));\nconsole.log('Electronics:', getElectronics(products).map(p => p.name));\n\n// General curry utility — wraps any function\nconst curry = (fn) => {\n    const arity = fn.length;   // number of declared parameters\n    return function curried(...args) {\n        if (args.length >= arity) return fn(...args);\n        return (...more) => curried(...args, ...more);\n    };\n};\n\nconst clamp = curry((min, max, value) => Math.min(Math.max(value, min), max));\nconst clamp0to100 = clamp(0, 100);\nconsole.log('\\nclamp0to100(-5) :', clamp0to100(-5));   // 0\nconsole.log('clamp0to100(42) :', clamp0to100(42));    // 42\nconsole.log('clamp0to100(200):', clamp0to100(200));   // 100",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "currying-and-partial-application",
