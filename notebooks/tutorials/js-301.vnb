    {
      "id": "js-301-immutability",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: immutability\n//@ description: Immutability\n// --- Immutability ---\n// WHY: Mutable shared state is the #1 source of bugs in large applications.\n// Immutable data means once created, an object never changes —\n// you create a new modified copy instead.\n\n// Object.freeze — shallow freeze (nested objects are still mutable)\nconst config = Object.freeze({\n    host: 'localhost',\n    port: 8585,\n    debug: false,\n});\n// config.port = 9000;  // silently ignored in sloppy mode, throws in strict mode\nconsole.log('config.port:', config.port);  // still 8585\n\n// Immutable update patterns using spread\nconst user = { name: 'Alice', age: 30, prefs: { theme: 'dark', lang: 'en' } };\n\n// Update top-level field\nconst olderUser = { ...user, age: 31 };\nconsole.log('user.age    :', user.age);       // 30 — unchanged\nconsole.log('olderUser.age:', olderUser.age); // 31\n\n// Update nested field (need to spread each level)\nconst lightUser = { ...user, prefs: { ...user.prefs, theme: 'light' } };\nconsole.log('user.prefs.theme     :', user.prefs.theme);      // dark\nconsole.log('lightUser.prefs.theme:', lightUser.prefs.theme); // light\n\n// Immutable array operations\nconst arr = [1, 2, 3, 4, 5];\n\n// Add to end / beginning\nconst withSix  = [...arr, 6];\nconst withZero = [0, ...arr];\n\n// Remove by index\nconst without3 = arr.filter((_, i) => i !== 2);   // remove index 2\n\n// Update element at index\nconst updated = arr.map((val, i) => i === 2 ? 99 : val);  // index 2 → 99\n\nconsole.log('\\nOriginal :', arr);\nconsole.log('withSix  :', withSix);\nconsole.log('withZero :', withZero);\nconsole.log('without3 :', without3);\nconsole.log('updated  :', updated);",
      "output": "",
      "returnValue": null,
      "executed": false,
