    {
      "id": "js-301-pipeline",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: complete-data-transformation-pipeline\n//@ description: Complete Data Transformation Pipeline\n// --- Complete Data Transformation Pipeline ---\n// Scenario: process CSV-like sales data using pure functions and composition.\n// Stages: parse → validate → enrich → aggregate → format report\n\n// 1. Raw input (simulated CSV rows as strings)\nconst rawRows = [\n    'Alice,Engineering,92000,Senior',\n    'Bob,Marketing,78000,Mid',\n    'Charlie,Engineering,105000,Senior',\n    'Diana,HR,68000,Junior',\n    'Eve,Engineering,88000,Mid',\n    'Frank,HR,,Junior',          // missing salary — will be filtered\n    'Grace,Marketing,95000,Senior',\n    'Hank,Engineering,115000,Senior',\n];\n\n// 2. Pure transformation functions\nconst parseRow = (row) => {\n    const [name, dept, salary, level] = row.split(',');\n    return { name, dept, salary: parseFloat(salary), level };\n};\n\nconst isValid = (emp) =>\n    emp.name && emp.dept && !isNaN(emp.salary) && emp.salary > 0;\n\nconst enrich = (emp) => ({\n    ...emp,\n    annualBonus: emp.level === 'Senior' ? emp.salary * 0.15\n               : emp.level === 'Mid'    ? emp.salary * 0.10\n               :                          emp.salary * 0.05,\n    totalComp: emp.salary + (emp.level === 'Senior' ? emp.salary * 0.15\n               : emp.level === 'Mid' ? emp.salary * 0.10 : emp.salary * 0.05),\n});\n\n// 3. Aggregation helpers\nconst groupBy = (key) => (arr) =>\n    arr.reduce((acc, item) => {\n        const k = item[key];\n        acc[k] = acc[k] || [];\n        acc[k].push(item);\n        return acc;\n    }, {});\n\nconst avgBy = (key) => (arr) =>\n    arr.reduce((sum, item) => sum + item[key], 0) / arr.length;\n\n// 4. Run the pipeline (pipe = left-to-right composition)\nconst pipe = (...fns) => x => fns.reduce((acc, fn) => fn(acc), x);\n\nconst employees = pipe(\n    rows => rows.map(parseRow),\n    rows => rows.filter(isValid),\n    rows => rows.map(enrich)\n)(rawRows);\n\nconsole.log(`Processed ${employees.length} valid employees (${rawRows.length} raw rows)`);\n\n// 5. Department report\nconst byDept = groupBy('dept')(employees);\nconsole.log('\\n=== Department Summary ===');\nObject.entries(byDept)\n    .sort(([a], [b]) => a.localeCompare(b))\n    .forEach(([dept, emps]) => {\n        const avg = avgBy('salary')(emps);\n        const headcount = emps.length;\n        const totalComp = emps.reduce((s, e) => s + e.totalComp, 0);\n        console.log(`  ${dept.padEnd(14)} | ${headcount} staff | avg salary $${avg.toFixed(0).padStart(7)} | total comp $${totalComp.toFixed(0).padStart(8)}`);\n    });\n\n// Top earners\nconsole.log('\\n=== Top 3 by Total Comp ===');\n[...employees]\n    .sort((a, b) => b.totalComp - a.totalComp)\n    .slice(0, 3)\n    .forEach((e, i) => console.log(`  ${i+1}. ${e.name.padEnd(10)} ${e.dept.padEnd(14)} $${e.totalComp.toFixed(0)}`));",
