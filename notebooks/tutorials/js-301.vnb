    {
      "id": "js-301-pure-functions",
      "type": "CODE",
      "mode": "nodejs",
      "source": "//@ anchor: pure-functions-vs-side-effects\n//@ description: Pure Functions vs Side Effects\n// --- Pure Functions vs Side Effects ---\n// A PURE function:\n//   1. Returns the same output for the same input (deterministic)\n//   2. Has no side effects (doesn't modify external state, no I/O)\n\n// IMPURE: depends on external state, has side effects\nlet total = 0;\nconst addToTotal = (n) => {\n    total += n;               // SIDE EFFECT: modifies external variable\n    return total;             // result depends on external state\n};\nconsole.log(addToTotal(5));   // 5\nconsole.log(addToTotal(5));   // 10 — same input, different output!\n\n// PURE: same input → same output, no external state\nconst add = (a, b) => a + b;\nconsole.log(add(5, 3));       // 8 — always\nconsole.log(add(5, 3));       // 8 — always\n\n// IMPURE: mutates its argument\nconst pushToArray = (arr, item) => {\n    arr.push(item);           // mutates the original array!\n    return arr;\n};\n\n// PURE: returns a new array, original unchanged\nconst appendToArray = (arr, item) => [...arr, item];\n\nconst original = [1, 2, 3];\nconst newArr = appendToArray(original, 4);\nconsole.log('original :', original);  // [1, 2, 3] — unchanged\nconsole.log('newArr   :', newArr);    // [1, 2, 3, 4]\n\n// Why it matters: pure functions are trivially testable and composable\nconst double  = x => x * 2;\nconst square  = x => x * x;\nconst addOne  = x => x + 1;\n\nconsole.log('double(square(addOne(3))):', double(square(addOne(3))));  // double(square(4)) = double(16) = 32",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "pure-functions-vs-side-effects",
      "dependsOn": [],
