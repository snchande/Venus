    {
      "id": "jshell-501-pipeline-run",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: pipeline-filter-transform-aggregate\n//@ description: Pipeline: filter → transform → aggregate\nimport java.util.*;\nimport java.util.function.*;\nimport java.util.stream.*;\n\n// --- Pipeline: filter → transform → aggregate ---\n// We use composable Predicate and Function objects built independently,\n// then wire them together — the 'functional pipeline' pattern.\n\n// Reusable predicates\nPredicate<SaleRecord> highValue  = r -> r.revenue() >= 500.0;\nPredicate<SaleRecord> isWidget   = r -> r.product().startsWith(\"Widget\");\nPredicate<SaleRecord> northOrEast = r -> r.region().equals(\"North\") || r.region().equals(\"East\");\n\n// 1. Revenue by region (all records)\nSystem.out.println(\"=== Revenue by Region ===\");\nsalesLog.stream()\n    .collect(Collectors.groupingBy(SaleRecord::region,\n             Collectors.summingDouble(SaleRecord::revenue)))\n    .entrySet().stream()\n    .sorted(Map.Entry.<String,Double>comparingByValue().reversed())\n    .forEach(e -> System.out.printf(\"  %-6s  $%8,.2f%n\", e.getKey(), e.getValue()));\n\n// 2. Top products by total quantity sold\nSystem.out.println(\"\\n=== Products by Units Sold ===\");\nsalesLog.stream()\n    .collect(Collectors.groupingBy(SaleRecord::product,\n             Collectors.summingInt(SaleRecord::quantity)))\n    .entrySet().stream()\n    .sorted(Map.Entry.<String,Integer>comparingByValue().reversed())\n    .forEach(e -> System.out.printf(\"  %-12s  %d units%n\", e.getKey(), e.getValue()));\n\n// 3. High-value Widget sales in North/East only\nSystem.out.println(\"\\n=== High-Value Widget Sales (North/East) ===\");\nsalesLog.stream()\n    .filter(highValue.and(isWidget).and(northOrEast))\n    .sorted(Comparator.comparingDouble(SaleRecord::revenue).reversed())\n    .forEach(r -> System.out.printf(\"  %-6s %-10s qty=%3d  rev=$%6.2f%n\",\n             r.region(), r.product(), r.quantity(), r.revenue()));\n\n// 4. Daily revenue trend\nSystem.out.println(\"\\n=== Daily Revenue Trend ===\");\nsalesLog.stream()\n    .collect(Collectors.groupingBy(SaleRecord::date,\n             Collectors.summingDouble(SaleRecord::revenue)))\n    .entrySet().stream()\n    .sorted(Map.Entry.comparingByKey())\n    .forEach(e -> {\n        int bars = (int)(e.getValue() / 100);\n        System.out.printf(\"  %s  $%7,.2f  %s%n\", e.getKey(), e.getValue(), \"█\".repeat(bars));\n    });",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "pipeline-filter-transform-aggregate",
      "dependsOn": [],
