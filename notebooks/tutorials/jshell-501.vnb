    {
      "id": "jshell-501-composition",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: function-composition-and-then-compose-pr\n//@ description: Function composition: andThen, compose, Predicate combinators\nimport java.util.function.*;\nimport java.util.List;\nimport java.util.stream.*;\n\n// --- Function composition: andThen, compose, Predicate combinators ---\n\n// andThen(f): apply this, then apply f to the result  →  g(f(x))\n// compose(f): apply f first, then apply this          →  this(f(x))\nFunction<Double, Double> toCelsius   = f -> (f - 32) * 5.0 / 9.0;\nFunction<Double, String> formatTemp  = c -> String.format(\"%.1f°C\", c);\n\n// compose a pipeline: fahrenheit → celsius → formatted string\nFunction<Double, String> describeFahr = toCelsius.andThen(formatTemp);\n\nList.of(32.0, 98.6, 212.0, 72.0)\n    .forEach(f -> System.out.printf(\"%.1f°F = %s%n\", f, describeFahr.apply(f)));\n\nSystem.out.println();\n\n// --- Predicate combinators: and, or, negate ---\nPredicate<Integer> isPositive  = n -> n > 0;\nPredicate<Integer> isEven      = n -> n % 2 == 0;\nPredicate<Integer> isSmall     = n -> n < 100;\n\nPredicate<Integer> isPositiveEven     = isPositive.and(isEven);\nPredicate<Integer> isPositiveOrEven   = isPositive.or(isEven);\nPredicate<Integer> isOdd              = isEven.negate();\nPredicate<Integer> isValidScore       = isPositive.and(isSmall);  // 1–99\n\nList<Integer> numbers = List.of(-4, 0, 3, 8, -2, 15, 100, 42, 7);\n\nSystem.out.println(\"Positive evens : \" + numbers.stream().filter(isPositiveEven).collect(Collectors.toList()));\nSystem.out.println(\"Positive or even: \" + numbers.stream().filter(isPositiveOrEven).collect(Collectors.toList()));\nSystem.out.println(\"Odd numbers     : \" + numbers.stream().filter(isOdd).collect(Collectors.toList()));\nSystem.out.println(\"Valid scores    : \" + numbers.stream().filter(isValidScore).collect(Collectors.toList()));",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "function-composition-and-then-compose-pr",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Function composition: andThen, compose, Predicate combinators"
