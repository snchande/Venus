    {
      "id": "jshell-501-pipeline-report",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: final-composable-report-generator\n//@ description: Final: composable report generator\nimport java.util.*;\nimport java.util.function.*;\nimport java.util.stream.*;\n\n// --- Final: composable report generator ---\n// This cell demonstrates function composition as a first-class design pattern:\n// build report sections as lambdas, chain them, run them over the same data.\n\nrecord ReportSection(String title, Runnable body) {\n    void print() {\n        System.out.println();\n        System.out.println(\"╔══ \" + title + \" \" + \"═\".repeat(Math.max(0, 50 - title.length())) + \"╗\");\n        body.run();\n        System.out.println(\"╚\" + \"═\".repeat(54) + \"╝\");\n    }\n}\n\n// Build sections\nvar sections = List.of(\n    new ReportSection(\"Executive Summary\", () -> {\n        double total   = salesLog.stream().mapToDouble(SaleRecord::revenue).sum();\n        long   records = salesLog.size();\n        double avgRev  = total / records;\n        System.out.printf(\"  Total revenue : $%,.2f%n\", total);\n        System.out.printf(\"  Transactions  : %d%n\", records);\n        System.out.printf(\"  Avg per txn   : $%,.2f%n\", avgRev);\n    }),\n    new ReportSection(\"Best Performing Region\", () -> {\n        salesLog.stream()\n            .collect(Collectors.groupingBy(SaleRecord::region,\n                     Collectors.summingDouble(SaleRecord::revenue)))\n            .entrySet().stream()\n            .max(Map.Entry.comparingByValue())\n            .ifPresent(e -> System.out.printf(\"  %s with $%,.2f%n\", e.getKey(), e.getValue()));\n    }),\n    new ReportSection(\"Best Selling Product\", () -> {\n        salesLog.stream()\n            .collect(Collectors.groupingBy(SaleRecord::product,\n                     Collectors.summingInt(SaleRecord::quantity)))\n            .entrySet().stream()\n            .max(Map.Entry.comparingByValue())\n            .ifPresent(e -> System.out.printf(\"  %s with %d units%n\", e.getKey(), e.getValue()));\n    })\n);\n\n// Run all sections\nSystem.out.println(\"BARISTA ANALYTICS — SALES REPORT\");\nsections.forEach(ReportSection::print);",
      "output": "",
      "returnValue": null,
      "executed": false,
