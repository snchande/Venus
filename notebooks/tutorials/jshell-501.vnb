    {
      "id": "jshell-501-method-refs",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: the-4-kinds-of-method-references\n//@ description: The 4 kinds of method references\nimport java.util.*;\nimport java.util.function.*;\nimport java.util.stream.*;\n\n// --- The 4 kinds of method references ---\n// Method references are shorthand lambdas when the lambda just calls one method.\n// Format: ClassName::methodName  or  instance::methodName\n\n// 1. Static method reference: ClassName::staticMethod\n//    equivalent to: (x) -> ClassName.staticMethod(x)\nFunction<String, Integer> parse = Integer::parseInt;    // Integer.parseInt(s)\nSystem.out.println(\"parseInt('42') = \" + parse.apply(\"42\"));\n\n// 2. Instance method reference on a specific instance: obj::method\nString prefix = \"BARISTA-\";\nFunction<String, String> addPrefix = prefix::concat;    // prefix.concat(s)\nSystem.out.println(\"addPrefix('007') = \" + addPrefix.apply(\"007\"));\n\n// 3. Instance method reference on an arbitrary instance of a type:\n//    ClassName::instanceMethod — the first lambda arg is the receiver\n//    equivalent to: (s) -> s.toUpperCase()\nFunction<String, String> upper = String::toUpperCase;\nFunction<String, String> trim  = String::trim;\nSystem.out.println(\"upper('hello')   = \" + upper.apply(\"hello\"));\n\n// 4. Constructor reference: ClassName::new\nFunction<String, StringBuilder> newSB = StringBuilder::new;\nStringBuilder sb = newSB.apply(\"initial\");\nSystem.out.println(\"StringBuilder = \" + sb);\n\n// Method refs in stream pipelines\nList<String> raw = List.of(\"  alice  \", \"  BOB  \", \" charlie \");\nList<String> cleaned = raw.stream()\n    .map(String::trim)            // (3) arbitrary instance\n    .map(String::toLowerCase)     // (3) arbitrary instance\n    .collect(Collectors.toList());\nSystem.out.println(\"cleaned = \" + cleaned);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "the-4-kinds-of-method-references",
      "dependsOn": [],
