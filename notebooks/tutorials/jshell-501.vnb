    {
      "id": "jshell-501-functional-interfaces",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: custom-functional-interface\n//@ description: Custom @FunctionalInterface\nimport java.util.function.*;\n\n// --- Custom @FunctionalInterface ---\n// Any interface with exactly ONE abstract method is a functional interface.\n// Annotate with @FunctionalInterface so the compiler enforces it.\n\n@FunctionalInterface\ninterface Transformer<A, B> {\n    B transform(A input);\n    // You can add default methods — only ONE abstract method allowed\n    default Transformer<A, B> withLogging(String label) {\n        return input -> {\n            B result = this.transform(input);\n            System.out.printf(\"  [%s] %s → %s%n\", label, input, result);\n            return result;\n        };\n    }\n}\n\n@FunctionalInterface\ninterface Validator<T> {\n    boolean validate(T value);\n    default Validator<T> and(Validator<T> other) {\n        return v -> this.validate(v) && other.validate(v);\n    }\n}\n\n// Use them with lambdas\nTransformer<String, Integer> wordLength = String::length;\nTransformer<String, String> shout = s -> s.toUpperCase() + \"!\";\nValidator<String> notEmpty = s -> !s.isBlank();\nValidator<String> shortEnough = s -> s.length() <= 10;\n\n// Apply them\nSystem.out.println(\"wordLength('hello') = \" + wordLength.transform(\"hello\"));\nSystem.out.println(\"shout('hello')       = \" + shout.transform(\"hello\"));\n\n// Compose validators\nValidator<String> nameValid = notEmpty.and(shortEnough);\nSystem.out.println(\"'Alice' valid   : \" + nameValid.validate(\"Alice\"));\nSystem.out.println(\"'' valid        : \" + nameValid.validate(\"\"));\nSystem.out.println(\"'VeryLongName!!' valid: \" + nameValid.validate(\"VeryLongName!!\"));\n\n// With logging\nTransformer<String, Integer> logged = wordLength.withLogging(\"length\");\nlogged.transform(\"Arima\");",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "custom-functional-interface",
      "dependsOn": [],
