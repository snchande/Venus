    {
      "id": "jshell-401-local-types",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: var-local-records-and-local-interfaces\n//@ description: var, local records, and local interfaces\n// --- var, local records, and local interfaces ---\n// 'var' infers the type at compile time — no runtime cost, just less typing.\n// Local records and interfaces can be declared inside a method in JShell.\n\n// var with complex generics (saves a lot of typing)\nvar map = new java.util.HashMap<String, java.util.List<Integer>>();\nmap.put(\"evens\", java.util.List.of(2, 4, 6, 8, 10));\nmap.put(\"odds\",  java.util.List.of(1, 3, 5, 7, 9));\n\n// var in for-each loop\nfor (var entry : map.entrySet()) {\n    var key  = entry.getKey();    // inferred: String\n    var vals = entry.getValue();  // inferred: List<Integer>\n    System.out.printf(\"%-6s: sum = %d%n\", key, vals.stream().mapToInt(i->i).sum());\n}\n\n// Local record: useful for returning multiple values from a computation\nrecord Stat(double min, double max, double avg) {}\n\nStat computeStats(java.util.List<Double> data) {\n    var stats = data.stream()\n        .mapToDouble(Double::doubleValue)\n        .summaryStatistics();\n    return new Stat(stats.getMin(), stats.getMax(), stats.getAverage());\n}\n\nvar data = java.util.List.of(14.5, 88.1, 3.0, 55.7, 42.2, 99.9, 27.6);\nvar s = computeStats(data);\nSystem.out.printf(\"%nData stats: min=%.1f  max=%.1f  avg=%.2f%n\", s.min(), s.max(), s.avg());",
      "output": "",
      "returnValue": null,
      "executed": false,
