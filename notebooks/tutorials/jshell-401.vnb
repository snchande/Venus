  "id": "jshell-401",
  "name": "JShell 401 — Modern Java Features",
  "description": "Explore Java 14–21 language features: records, text blocks, switch expressions, pattern matching instanceof, sealed classes, and local types.",
  "created": "2026-03-29T00:00:00",
