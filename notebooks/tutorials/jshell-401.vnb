      "description": "Text Blocks (Java 15)"
    },
    {
      "id": "jshell-401-switch",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: switch-expressions-java-14\n//@ description: Switch Expressions (Java 14)\n// --- Switch Expressions (Java 14) ---\n// Traditional switch: statement, fall-through, verbose\n// Switch expression: returns a value, arrow syntax, no fall-through\n\nenum Season { SPRING, SUMMER, AUTUMN, WINTER }\n\nSeason season = Season.AUTUMN;\n\n// Arrow syntax: each case is a single expression, returns a value\nString description = switch (season) {\n    case SPRING -> \"Warm and rainy\";\n    case SUMMER -> \"Hot and sunny\";\n    case AUTUMN -> \"Cool and windy\";\n    case WINTER -> \"Cold and snowy\";\n};\n// No default needed — the compiler checks exhaustiveness for enums!\nSystem.out.println(season + \" : \" + description);\n\n// Multi-line case with yield\nint numLetters = switch (season) {\n    case SPRING, SUMMER -> 6;\n    case AUTUMN -> {\n        System.out.println(\"  (computing autumn letters...)\");\n        yield 6;   // 'yield' returns the value from a block\n    }\n    case WINTER -> 6;\n};\nSystem.out.println(\"Letters in '\" + season + \"': \" + numLetters);\n\n// Switch on String\nString command = \"start\";\nString result = switch (command.toLowerCase()) {\n    case \"start\", \"run\", \"go\" -> \"Executing...\";\n    case \"stop\", \"halt\"       -> \"Stopping...\";\n    case \"help\"               -> \"Showing help\";\n    default                   -> \"Unknown command: \" + command;\n};\nSystem.out.println(\"Command '\" + command + \"' → \" + result);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "switch-expressions-java-14",
      "dependsOn": [],
