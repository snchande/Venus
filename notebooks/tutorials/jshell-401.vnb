      "description": "Switch Expressions (Java 14)"
    },
    {
      "id": "jshell-401-instanceof",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: pattern-matching-instanceof-java-16\n//@ description: Pattern Matching instanceof (Java 16)\n// --- Pattern Matching instanceof (Java 16) ---\n// Old: check type with instanceof, then cast manually (redundant)\n// New: if the check passes, a typed binding variable is in scope\n\n// Pretend we receive Objects from some API\nObject obj1 = \"Hello, pattern matching!\";\nObject obj2 = 42;\nObject obj3 = 3.14;\nObject obj4 = java.util.List.of(1, 2, 3);\n\nvoid describeObject(Object obj) {\n    // Old way:\n    // if (obj instanceof String) { String s = (String) obj; ... }\n\n    // New way: 'obj instanceof String s' — s is bound if true\n    if (obj instanceof String s) {\n        System.out.println(\"String of length \" + s.length() + \": \" + s.toUpperCase());\n    } else if (obj instanceof Integer i) {\n        System.out.println(\"Integer, doubled: \" + (i * 2));\n    } else if (obj instanceof Double d) {\n        System.out.printf(\"Double, formatted: %.4f%n\", d);\n    } else if (obj instanceof java.util.List<?> list) {\n        System.out.println(\"List with \" + list.size() + \" elements: \" + list);\n    } else {\n        System.out.println(\"Unknown type: \" + obj.getClass().getSimpleName());\n    }\n}\n\ndescribeObject(obj1);\ndescribeObject(obj2);\ndescribeObject(obj3);\ndescribeObject(obj4);\n\n// You can even use the bound variable in the same condition\nObject maybeString = \"Venus\";\nif (maybeString instanceof String s && s.length() > 3) {\n    System.out.println(\"Long string: \" + s);\n}",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
