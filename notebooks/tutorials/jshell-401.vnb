    {
      "id": "jshell-401-sealed",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: sealed-classes-java-17\n//@ description: Sealed Classes (Java 17)\n// --- Sealed Classes (Java 17) ---\n// A sealed class/interface restricts which classes can extend or implement it.\n// This enables exhaustive pattern matching — the compiler knows all possible subtypes.\n\n// Define a sealed interface for shapes\nsealed interface Shape permits Circle, Rectangle, Triangle {}\n\nrecord Circle(double radius)       implements Shape {}\nrecord Rectangle(double w, double h) implements Shape {}\nrecord Triangle(double base, double h) implements Shape {}\n\n// Since Shape is sealed, the switch knows all subtypes — no default needed!\ndouble area(Shape shape) {\n    return switch (shape) {\n        case Circle c       -> Math.PI * c.radius() * c.radius();\n        case Rectangle r    -> r.w() * r.h();\n        case Triangle t     -> 0.5 * t.base() * t.h();\n    };\n}\n\nString describe(Shape shape) {\n    return switch (shape) {\n        case Circle c       -> \"Circle with radius %.2f\".formatted(c.radius());\n        case Rectangle r    -> \"Rectangle %.1f × %.1f\".formatted(r.w(), r.h());\n        case Triangle t     -> \"Triangle base %.1f, height %.1f\".formatted(t.base(), t.h());\n    };\n}\n\nvar shapes = java.util.List.<Shape>of(\n    new Circle(5),\n    new Rectangle(4, 7),\n    new Triangle(6, 3)\n);\n\nSystem.out.println(\"=== Shape Report ===\");\nfor (Shape s : shapes) {\n    System.out.printf(\"%-35s  area = %.2f%n\", describe(s), area(s));\n}",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "sealed-classes-java-17",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Sealed Classes (Java 17)"
    },
    {
      "id": "jshell-401-switch-patterns",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: switch-with-type-patterns-java-21\n//@ description: Switch with Type Patterns (Java 21)\n// --- Switch with Type Patterns (Java 21) ---\n// Combine sealed types + pattern matching in a single switch.\n// Guarded patterns: add 'when' condition to a case.\n\n// Re-using Shape hierarchy from the previous cell\n\nvoid classifyShape(Shape shape) {\n    String category = switch (shape) {\n        case Circle c when c.radius() > 10  -> \"Large circle (r=\" + c.radius() + \")\";\n        case Circle c                        -> \"Small circle  (r=\" + c.radius() + \")\";\n        case Rectangle r when r.w() == r.h() -> \"Square (\" + r.w() + \"×\" + r.h() + \")\";\n        case Rectangle r                     -> \"Rectangle (\" + r.w() + \"×\" + r.h() + \")\";\n        case Triangle t                      -> \"Triangle\";\n    };\n    System.out.println(\"  \" + category);\n}\n\nSystem.out.println(\"Shape classification:\");\njava.util.List.<Shape>of(\n    new Circle(3),\n    new Circle(15),\n    new Rectangle(5, 5),\n    new Rectangle(4, 7),\n    new Triangle(6, 3)\n).forEach(s -> classifyShape(s));\n\n// Record patterns (Java 21): destructure record components inline\nShape myCircle = new Circle(7.5);\nif (myCircle instanceof Circle(double r)) {\n    System.out.printf(\"%nCircle radius via record pattern: %.1f%n\", r);\n}",
      "output": "",
      "returnValue": null,
