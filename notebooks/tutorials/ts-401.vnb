{
  "id": "ts-401",
  "name": "TypeScript Expert — Async, Patterns, Modern Features",
  "description": "Async/await patterns, error-as-values, branded types, ES2024 features in TypeScript",
  "cells": [
    {
      "id": "ts-401-md-1",
      "type": "MARKDOWN",
      "source": "# TypeScript 401 — Expert Patterns\n\nThis notebook covers patterns experienced TypeScript developers reach for:\n\n1. **Typed async/await** with proper error handling\n2. **Result types** — errors as values instead of exceptions\n3. **Branded (nominal) types** — distinguish two `string`s by intent\n4. **Builder pattern** with chained fluent API\n5. **Modern ES2024** — `Array.prototype.findLast`, `Object.groupBy`, `Promise.withResolvers`",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-401-1",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: typed-async\n//@ description: Typed async/await with parallel fetch simulation\n\ninterface Sensor { id: number; name: string; reading: number; }\n\nasync function readSensor(id: number): Promise<Sensor> {\n  await new Promise(r => setTimeout(r, 5));\n  return { id, name: `sensor-${id}`, reading: Math.round(Math.random() * 100) / 10 };\n}\n\nasync function main(): Promise<void> {\n  const ids: number[] = [1, 2, 3, 4, 5];\n  const sensors: Sensor[] = await Promise.all(ids.map(readSensor));\n  venus.table(sensors.map(s => ({ ID: s.id, Sensor: s.name, Reading: s.reading })));\n  venus.stats(sensors.map(s => s.reading));\n}\n\nmain();",
      "output": "",
      "executed": false,
      "anchor": "typed-async",
      "description": "Typed async/await with parallel fetch simulation"
    },
    {
      "id": "ts-401-2",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: result-type\n//@ description: Errors as values — the Result<T, E> pattern\n\ntype Result<T, E = string> =\n  | { ok: true;  value: T }\n  | { ok: false; error: E };\n\nfunction parseIntSafe(s: string): Result<number> {\n  const n = Number(s);\n  if (Number.isFinite(n)) return { ok: true, value: n };\n  return { ok: false, error: `Not a number: \"${s}\"` };\n}\n\nfunction divideSafe(a: number, b: number): Result<number> {\n  if (b === 0) return { ok: false, error: \"Division by zero\" };\n  return { ok: true, value: a / b };\n}\n\nconst tests = [\"42\", \"hello\", \"3.14\"];\ntests.forEach(t => {\n  const r = parseIntSafe(t);\n  console.log(r.ok ? `parse(\"${t}\") = ${r.value}` : `parse(\"${t}\") ERROR: ${r.error}`);\n});\n\nconst d = divideSafe(10, 0);\nconsole.log(d.ok ? `result = ${d.value}` : `ERROR: ${d.error}`);",
      "output": "",
      "executed": false,
      "anchor": "result-type",
      "description": "Errors as values — the Result<T, E> pattern"
    },
    {
      "id": "ts-401-md-2",
      "type": "MARKDOWN",
      "source": "## Branded types (nominal typing in a structural world)\n\nTypeScript is structural by default — any two `string`s are interchangeable. **Branded types** attach a phantom tag so the compiler treats `UserId` and `OrderId` as distinct, even though they're both `string` at runtime.",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-401-3",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: branded-types\n//@ description: Distinguish two strings of different intent\n\ntype Brand<T, B> = T & { readonly __brand: B };\n\ntype UserId  = Brand<string, \"UserId\">;\ntype OrderId = Brand<string, \"OrderId\">;\n\nfunction userId(s: string):  UserId  { return s as UserId; }\nfunction orderId(s: string): OrderId { return s as OrderId; }\n\nfunction loadUser(id: UserId): void { console.log(\"loadUser called with\", id); }\n\nconst u = userId(\"u-100\");\nconst o = orderId(\"o-500\");\n\nloadUser(u);          // ✓ OK\n// loadUser(o);       // ✗ TS would refuse: Argument of type 'OrderId' is not assignable to parameter of type 'UserId'\n// loadUser(\"u-100\"); // ✗ TS would refuse: raw string is not a UserId\n\nconsole.log(\"u =\", u);\nconsole.log(\"o =\", o);",
      "output": "",
      "executed": false,
      "anchor": "branded-types",
      "description": "Distinguish two strings of different intent"
    },
    {
      "id": "ts-401-md-3",
      "type": "MARKDOWN",
      "source": "## Fluent builder pattern\n\nGenerics + `this`-typing make chainable APIs that preserve type information across each step.",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-401-4",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: builder-pattern\n//@ description: Fluent QueryBuilder with type-preserving chains\n\nclass QueryBuilder<T> {\n  private filters: Array<(row: T) => boolean> = [];\n  private orderKey: keyof T | null = null;\n  private orderDir: \"asc\" | \"desc\" = \"asc\";\n  private limitN: number = Infinity;\n\n  where(pred: (row: T) => boolean): this { this.filters.push(pred); return this; }\n  orderBy(key: keyof T, dir: \"asc\" | \"desc\" = \"asc\"): this {\n    this.orderKey = key; this.orderDir = dir; return this;\n  }\n  limit(n: number): this { this.limitN = n; return this; }\n\n  run(rows: T[]): T[] {\n    let out = rows.filter(r => this.filters.every(f => f(r)));\n    if (this.orderKey) {\n      const k = this.orderKey;\n      out = [...out].sort((a, b) => {\n        const av = a[k] as unknown as number | string;\n        const bv = b[k] as unknown as number | string;\n        return (av < bv ? -1 : av > bv ? 1 : 0) * (this.orderDir === \"asc\" ? 1 : -1);\n      });\n    }\n    return out.slice(0, this.limitN);\n  }\n}\n\ninterface Person { name: string; age: number; }\nconst people: Person[] = [\n  { name: \"Alice\", age: 30 },\n  { name: \"Bob\",   age: 25 },\n  { name: \"Carol\", age: 35 },\n  { name: \"Dave\",  age: 28 },\n];\n\nconst result = new QueryBuilder<Person>()\n  .where(p => p.age >= 28)\n  .orderBy(\"age\", \"desc\")\n  .limit(2)\n  .run(people);\n\nvenus.table(result as unknown as Record<string, unknown>[]);",
      "output": "",
      "executed": false,
      "anchor": "builder-pattern",
      "description": "Fluent QueryBuilder with type-preserving chains"
    },
    {
      "id": "ts-401-md-4",
      "type": "MARKDOWN",
      "source": "## Modern ES features in TypeScript\n\nModern Node ships ES2024+ features. TypeScript's standard lib knows about them.",
      "output": "",
      "executed": false
    },
    {
      "id": "ts-401-5",
      "type": "CODE",
      "mode": "typescript",
      "source": "//@ anchor: es2024-features\n//@ description: findLast, Object.groupBy, Promise.withResolvers\n\nconst nums: number[] = [1, 4, 2, 8, 5, 7, 3];\nconst lastEven: number | undefined = nums.findLast(n => n % 2 === 0);\nconsole.log(\"lastEven =\", lastEven); // 8\n\n// Object.groupBy — ES2024\ninterface Sale { region: string; amount: number; }\nconst sales: Sale[] = [\n  { region: \"N\", amount: 10 },\n  { region: \"S\", amount: 22 },\n  { region: \"N\", amount: 14 },\n  { region: \"S\", amount: 18 },\n];\n\nconst grouped = (Object as any).groupBy(sales, (s: Sale) => s.region) as Record<string, Sale[]>;\nObject.entries(grouped).forEach(([region, rows]) => {\n  const total = rows.reduce((a, r) => a + r.amount, 0);\n  console.log(`region=${region}  total=${total}`);\n});\n\n// Promise.withResolvers — ES2024 — expose resolve/reject without nesting\ntype Withr<T> = { promise: Promise<T>; resolve: (v: T) => void; reject: (e: unknown) => void };\nconst { promise, resolve } = (Promise as any).withResolvers() as Withr<string>;\nsetTimeout(() => resolve(\"done\"), 1);\npromise.then(v => console.log(\"withResolvers ->\", v));",
      "output": "",
      "executed": false,
      "anchor": "es2024-features",
      "description": "findLast, Object.groupBy, Promise.withResolvers"
    }
  ],
  "metadata": {
