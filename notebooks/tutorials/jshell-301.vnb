    {
      "id": "jshell-301-reduce",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: reduce-distinct-limit-count\n//@ description: reduce, distinct, limit, count\nimport java.util.List;\nimport java.util.stream.Collectors;\n\n// --- reduce, distinct, limit, count ---\n\nList<Integer> numbers = List.of(3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5);\n\n// reduce(identity, accumulator) — fold all elements into one value\n// identity is the starting value (like 0 for sum, 1 for product)\nint total = numbers.stream()\n    .reduce(0, (acc, n) -> acc + n);   // could also use Integer::sum\nSystem.out.println(\"Sum    : \" + total);\n\nint product = numbers.stream()\n    .reduce(1, (acc, n) -> acc * n);\nSystem.out.println(\"Product: \" + product);\n\n// distinct — removes duplicates (uses equals/hashCode)\nList<Integer> unique = numbers.stream()\n    .distinct()\n    .sorted()\n    .collect(Collectors.toList());\nSystem.out.println(\"Distinct sorted: \" + unique);\n\n// limit and skip — pagination-style control\nList<Integer> page = numbers.stream()\n    .distinct()\n    .sorted()\n    .skip(2)     // skip first 2\n    .limit(3)    // take next 3\n    .collect(Collectors.toList());\nSystem.out.println(\"Page (skip 2, limit 3): \" + page);\n\n// count, min, max\nlong count = numbers.stream().distinct().count();\nint max = numbers.stream().mapToInt(Integer::intValue).max().getAsInt();\nint min = numbers.stream().mapToInt(Integer::intValue).min().getAsInt();\nSystem.out.printf(\"Unique count: %d  Min: %d  Max: %d%n\", count, min, max);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "reduce-distinct-limit-count",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "reduce, distinct, limit, count"
    },
    {
      "id": "jshell-301-flatmap",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: flat-map-flatten-nested-structures\n//@ description: flatMap — flatten nested structures\nimport java.util.List;\nimport java.util.stream.Collectors;\nimport java.util.stream.Stream;\n\n// --- flatMap — flatten nested structures ---\n// map() produces a Stream<Stream<T>>, flatMap() flattens it to Stream<T>.\n// Use it when each element maps to multiple values.\n\nList<List<Integer>> nested = List.of(\n    List.of(1, 2, 3),\n    List.of(4, 5),\n    List.of(6, 7, 8, 9)\n);\n\n// Without flatMap: you'd get a Stream of Lists\n// With flatMap: each inner list is streamed and merged into one flat stream\nList<Integer> flat = nested.stream()\n    .flatMap(List::stream)\n    .collect(Collectors.toList());\nSystem.out.println(\"Flattened: \" + flat);\n\n// Practical: split sentences into individual words\nList<String> sentences = List.of(\n    \"the quick brown fox\",\n    \"jumps over the lazy dog\"\n);\n\nList<String> allWords = sentences.stream()\n    .flatMap(s -> Stream.of(s.split(\" \")))  // each sentence → stream of words\n    .distinct()\n    .sorted()\n    .collect(Collectors.toList());\nSystem.out.println(\"Unique words: \" + allWords);\nSystem.out.println(\"Word count  : \" + allWords.size());",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "flat-map-flatten-nested-structures",
