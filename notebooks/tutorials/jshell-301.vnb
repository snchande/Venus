    {
      "id": "jshell-301-collectors",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: collectors-grouping-by-split-a-stream-in\n//@ description: Collectors.groupingBy — split a stream into groups\nimport java.util.List;\nimport java.util.Map;\nimport java.util.stream.Collectors;\n\n// --- Collectors.groupingBy — split a stream into groups ---\n// groupingBy(classifier) returns Map<K, List<V>>\n\nrecord Employee(String name, String dept, double salary) {}\n\nList<Employee> employees = List.of(\n    new Employee(\"Alice\",   \"Engineering\", 120_000),\n    new Employee(\"Bob\",     \"Marketing\",    85_000),\n    new Employee(\"Charlie\", \"Engineering\", 110_000),\n    new Employee(\"Diana\",   \"Marketing\",    90_000),\n    new Employee(\"Eve\",     \"Engineering\", 135_000),\n    new Employee(\"Frank\",   \"HR\",           75_000),\n    new Employee(\"Grace\",   \"HR\",           80_000)\n);\n\n// Group employees by department\nMap<String, List<Employee>> byDept = employees.stream()\n    .collect(Collectors.groupingBy(Employee::dept));\n\nSystem.out.println(\"=== Employees by Department ===\");\nbyDept.forEach((dept, emps) -> {\n    System.out.println(dept + \":\");\n    emps.forEach(e -> System.out.printf(\"  %-10s $%.0f%n\", e.name(), e.salary()));\n});\n\n// Count per department\nMap<String, Long> countByDept = employees.stream()\n    .collect(Collectors.groupingBy(Employee::dept, Collectors.counting()));\nSystem.out.println(\"\\nHeadcount: \" + countByDept);\n\n// Average salary per department\nMap<String, Double> avgSalary = employees.stream()\n    .collect(Collectors.groupingBy(Employee::dept,\n             Collectors.averagingDouble(Employee::salary)));\nSystem.out.println(\"Avg salary:\");\navgSalary.forEach((dept, avg) -> System.out.printf(\"  %-12s $%.0f%n\", dept, avg));",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "collectors-grouping-by-split-a-stream-in",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Collectors.groupingBy — split a stream into groups"
    },
    {
      "id": "jshell-301-optional",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: optional-null-safe-wrappers\n//@ description: Optional — null-safe wrappers\nimport java.util.Optional;\nimport java.util.List;\n\n// --- Optional — null-safe wrappers ---\n// Optional<T> is a container that may or may not hold a value.\n// Use it instead of returning null to force callers to handle the absence case.\n\n// Creating\nOptional<String> present = Optional.of(\"hello\");         // must be non-null\nOptional<String> empty   = Optional.empty();\nOptional<String> maybe   = Optional.ofNullable(null);    // safe even if null\n\nSystem.out.println(\"present.isPresent()  : \" + present.isPresent());\nSystem.out.println(\"empty.isEmpty()      : \" + empty.isEmpty());\nSystem.out.println(\"present.get()        : \" + present.get());\n\n// orElse / orElseGet — provide a fallback\nString val1 = empty.orElse(\"default\");\nString val2 = empty.orElseGet(() -> \"computed-\" + System.currentTimeMillis());\nSystem.out.println(\"orElse               : \" + val1);\nSystem.out.println(\"orElseGet            : \" + val2);\n\n// map and filter on Optional\nOptional<Integer> length = present.map(String::length);  // Optional<Integer> with 5\nSystem.out.println(\"map to length        : \" + length.orElse(0));\n\nOptional<String> filtered = present.filter(s -> s.startsWith(\"h\"));\nSystem.out.println(\"filter startsWith h  : \" + filtered.orElse(\"no match\"));\n\n// In practice: findFirst returns Optional\nList<String> names = List.of(\"Charlie\", \"Alice\", \"Bob\", \"Diana\");\nString first = names.stream()\n    .filter(n -> n.startsWith(\"A\"))\n    .findFirst()\n    .orElse(\"not found\");\nSystem.out.println(\"First name with A    : \" + first);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "optional-null-safe-wrappers",
      "dependsOn": [],
