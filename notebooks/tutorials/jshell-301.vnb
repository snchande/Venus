      "description": "Optional — null-safe wrappers"
    },
    {
      "id": "jshell-301-pipeline",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: putting-it-all-together-employee-data-pi\n//@ description: Putting it all together: Employee data pipeline\nimport java.util.List;\nimport java.util.Map;\nimport java.util.stream.Collectors;\n\n// --- Putting it all together: Employee data pipeline ---\n// This re-uses the Employee record and employees list from the previous cell.\n\n// Task: Find departments where average salary > 90_000,\n//       list the top earner in each such department.\n\nSystem.out.println(\"=== High-Value Departments Report ===\");\nSystem.out.println();\n\n// Step 1: group by department\nMap<String, List<Employee>> byDept = employees.stream()\n    .collect(Collectors.groupingBy(Employee::dept));\n\n// Step 2: filter to depts with avg > 90_000, step 3: find top earner each\nbyDept.entrySet().stream()\n    .filter(entry -> entry.getValue().stream()\n            .mapToDouble(Employee::salary)\n            .average()\n            .orElse(0) > 90_000)\n    .sorted(Map.Entry.comparingByKey())\n    .forEach(entry -> {\n        String dept = entry.getKey();\n        List<Employee> emps = entry.getValue();\n\n        double avg = emps.stream()\n            .mapToDouble(Employee::salary).average().orElse(0);\n\n        Employee top = emps.stream()\n            .max((a, b) -> Double.compare(a.salary(), b.salary()))\n            .orElseThrow();\n\n        System.out.printf(\"Dept: %-14s  Avg: $%,.0f  Top earner: %s ($%,.0f)%n\",\n            dept, avg, top.name(), top.salary());\n    });",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "putting-it-all-together-employee-data-pi",
