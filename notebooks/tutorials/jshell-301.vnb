    {
      "id": "jshell-301-create",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: creating-streams\n//@ description: Creating Streams\nimport java.util.stream.Stream;\nimport java.util.stream.IntStream;\nimport java.util.Arrays;\nimport java.util.List;\n\n// --- Creating Streams ---\n\n// 1. From a List (most common)\nList<String> colors = List.of(\"red\", \"green\", \"blue\", \"red\", \"yellow\", \"blue\");\nStream<String> s1 = colors.stream();\nSystem.out.println(\"From List count: \" + s1.count());   // consumes the stream\n\n// 2. Stream.of — ad-hoc stream from values\nStream.of(\"alpha\", \"beta\", \"gamma\")\n      .forEach(w -> System.out.print(w + \" \"));\nSystem.out.println();\n\n// 3. Arrays.stream\nint[] nums = {5, 3, 8, 1, 9, 2, 7};\nint sum = Arrays.stream(nums).sum();\nSystem.out.println(\"Sum of array: \" + sum);\n\n// 4. IntStream.range / rangeClosed — generates sequences\nSystem.out.print(\"range(1,6)  : \");\nIntStream.range(1, 6).forEach(i -> System.out.print(i + \" \"));\nSystem.out.println();\n\n// 5. Stream.iterate — infinite stream with a seed + function\nSystem.out.print(\"Powers of 2 : \");\nStream.iterate(1, n -> n * 2)\n      .limit(8)             // MUST limit infinite streams\n      .forEach(n -> System.out.print(n + \" \"));\nSystem.out.println();",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "creating-streams",
