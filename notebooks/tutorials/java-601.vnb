    {
      "id": "601-distributions",
      "type": "CODE",
      "mode": "jshell",
      "anchor": "distributions",
      "source": "//@ anchor: distributions\n//@ description: Prints t(10)   P(T<2.228)=%.4f%n\nimport org.apache.commons.math3.distribution.BinomialDistribution;\nimport org.apache.commons.math3.distribution.PoissonDistribution;\nNormalDistribution nd = new NormalDistribution(0,1);\nTDistribution td = new TDistribution(10);\nBinomialDistribution bd = new BinomialDistribution(20,0.4);\nPoissonDistribution pd = new PoissonDistribution(3.5);\nSystem.out.printf(\"Normal  P(X<1.96)=%.4f  95%% z=%.3f%n\",\n    nd.cumulativeProbability(1.96), nd.inverseCumulativeProbability(0.975));\nSystem.out.printf(\"t(10)   P(T<2.228)=%.4f%n\", td.cumulativeProbability(2.228));\nSystem.out.printf(\"Binom(20,0.4) P(X=8)=%.4f%n\", bd.probability(8));\nSystem.out.printf(\"Poisson(3.5)  P(X<=5)=%.4f%n\", pd.cumulativeProbability(5));\n\nint n2=80; double[] xv=new double[n2],nv=new double[n2],tv=new double[n2];\nfor(int i=0;i<n2;i++){xv[i]=-4.0+i*8.0/n2; nv[i]=nd.density(xv[i]); tv[i]=td.density(xv[i]);}\nXYChart dist=VenusDisplay.xyChart(\"Normal vs t(10) PDF\",\"x\",\"Density\",700,360);\ndist.getStyler().setMarkerSize(0);\ndist.addSeries(\"N(0,1)\",xv,nv); dist.addSeries(\"t(10)\",xv,tv);\nVenusDisplay.show(dist);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Prints t(10)   P(T<2.228)=%.4f%n"
    },
