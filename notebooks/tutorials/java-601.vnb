    {
      "id": "601-correlation",
      "type": "CODE",
      "mode": "jshell",
      "anchor": "correlation",
      "source": "//@ anchor: correlation\n//@ description: Prints height vs weight\nimport org.apache.commons.math3.stat.correlation.PearsonsCorrelation;\nimport org.apache.commons.math3.stat.correlation.SpearmansCorrelation;\ndouble[] height={160,165,170,175,180,185,190};\ndouble[] weight={55,62,68,74,80,88,95};\ndouble[] noise ={90,45,72,30,85,50,60};\nPearsonsCorrelation pc=new PearsonsCorrelation();\nSpearmansCorrelation sc2=new SpearmansCorrelation();\nSystem.out.printf(\"height↔weight  Pearson=%.4f  Spearman=%.4f%n\",\n    pc.correlation(height,weight), sc2.correlation(height,weight));\nSystem.out.printf(\"height↔noise   Pearson=%.4f  Spearman=%.4f%n\",\n    pc.correlation(height,noise), sc2.correlation(height,noise));\nVenusDisplay.table(new String[][]{\n    {\"height vs weight\",String.format(\"%.4f\",pc.correlation(height,weight)),\"Strong positive\"},\n    {\"height vs noise\", String.format(\"%.4f\",pc.correlation(height,noise)), \"Weak/random\"}\n},\"Pair\",\"Pearson r\",\"Interpretation\");",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Prints height vs weight"
    },
