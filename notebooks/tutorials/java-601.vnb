    {
      "id": "601-charts-stacked",
      "type": "CODE",
      "mode": "jshell",
      "anchor": "charts-stacked",
      "source": "//@ anchor: charts-stacked\n//@ description: Stacked bar — quarterly regional sales\n// Stacked bar — quarterly regional sales\nCategoryChart stacked=VenusDisplay.barChart(\"Quarterly Sales by Region\",\"Quarter\",\"Units\",700,320);\nstacked.getStyler().setStacked(true);\nstacked.addSeries(\"North\",List.of(\"Q1\",\"Q2\",\"Q3\",\"Q4\"),List.of(120,140,160,180));\nstacked.addSeries(\"South\",List.of(\"Q1\",\"Q2\",\"Q3\",\"Q4\"),List.of(90,110,130,150));\nstacked.addSeries(\"West\", List.of(\"Q1\",\"Q2\",\"Q3\",\"Q4\"),List.of(70,80,95,110));\nVenusDisplay.show(stacked);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Stacked bar — quarterly regional sales"
    },
