    {
      "id": "601-desc-stats",
      "type": "CODE",
      "mode": "jshell",
      "anchor": "desc-stats",
      "source": "//@ anchor: desc-stats\n//@ description: Prints N=%d  Min=%.1f  Max=%.1f%n\ndouble[] temps = {3.1,4.8,8.2,13.5,18.0,22.4,25.1,24.6,19.8,13.2,7.4,3.9};\nDescriptiveStatistics ds = new DescriptiveStatistics(temps);\nSystem.out.printf(\"N=%d  Min=%.1f  Max=%.1f%n\", (int)ds.getN(), ds.getMin(), ds.getMax());\nSystem.out.printf(\"Mean=%.2f  Median=%.2f  StdDev=%.2f%n\",\n    ds.getMean(), ds.getPercentile(50), ds.getStandardDeviation());\nSystem.out.printf(\"Skewness=%.3f  Kurtosis=%.3f%n\", ds.getSkewness(), ds.getKurtosis());\nSystem.out.printf(\"P25=%.2f  P75=%.2f  P90=%.2f%n\",\n    ds.getPercentile(25), ds.getPercentile(75), ds.getPercentile(90));\nVenusDisplay.stats(\"Monthly Temps (°C)\", temps);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Prints N=%d  Min=%.1f  Max=%.1f%n"
    },
    {
