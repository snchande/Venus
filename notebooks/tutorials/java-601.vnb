    {
      "id": "601-regression",
      "type": "CODE",
      "mode": "jshell",
      "anchor": "regression",
      "source": "//@ anchor: regression\n//@ description: Prints y = %.4fx + %.4f%n\nSimpleRegression reg = new SimpleRegression();\ndouble[][] pts = {{1,2.1},{2,4.3},{3,5.9},{4,8.2},{5,10.1},{6,11.8},{7,14.0},{8,16.2}};\nfor (double[] p : pts) reg.addData(p[0], p[1]);\nSystem.out.printf(\"y = %.4fx + %.4f%n\", reg.getSlope(), reg.getIntercept());\nSystem.out.printf(\"R²=%.4f  SlopeErr=%.4f  Predict(9)=%.3f%n\",\n    reg.getRSquare(), reg.getSlopeStdErr(), reg.predict(9));\n\nXYChart c = VenusDisplay.xyChart(\"Linear Regression\",\"X\",\"Y\",700,380);\nc.getStyler().setDefaultSeriesRenderStyle(XYSeries.XYSeriesRenderStyle.Scatter);\ndouble[] xs=Arrays.stream(pts).mapToDouble(p->p[0]).toArray();\ndouble[] ys=Arrays.stream(pts).mapToDouble(p->p[1]).toArray();\nc.addSeries(\"Data\",xs,ys).setMarkerColor(VenusDisplay.PALETTE[0]);\nc.getStyler().setDefaultSeriesRenderStyle(XYSeries.XYSeriesRenderStyle.Line);\nXYSeries fit=c.addSeries(\"Fit\",new double[]{1,8},new double[]{reg.predict(1),reg.predict(8)});\nfit.setMarker(SeriesMarkers.NONE); fit.setLineColor(VenusDisplay.PALETTE[2]);\nVenusDisplay.show(c);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Prints y = %.4fx + %.4f%n"
    },
    {
