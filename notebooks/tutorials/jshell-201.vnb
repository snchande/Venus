    {
      "id": "jshell-201-wordfreq",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: practical-word-frequency-counter\n//@ description: Practical: Word Frequency Counter\nimport java.util.HashMap;\nimport java.util.Map;\nimport java.util.Arrays;\n\n// --- Practical: Word Frequency Counter ---\n// Classic interview problem. HashMap maps each word to how many times it appears.\n\nString text = \"the quick brown fox jumps over the lazy dog the fox\";\nString[] words = text.split(\" \");\n\nHashMap<String, Integer> freq = new HashMap<>();\nfor (String word : words) {\n    // getOrDefault returns current count (or 0 if first time seeing the word)\n    freq.put(word, freq.getOrDefault(word, 0) + 1);\n}\n\nSystem.out.println(\"Word frequencies:\");\n// Sort entries by value (count) descending for a nicer report\nfreq.entrySet()\n    .stream()\n    .sorted(Map.Entry.<String, Integer>comparingByValue().reversed())\n    .forEach(e -> System.out.printf(\"  %-10s : %d%n\", e.getKey(), e.getValue()));\n\nSystem.out.println(\"\\nTotal unique words : \" + freq.size());\nSystem.out.println(\"Total words        : \" + words.length);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "practical-word-frequency-counter",
      "dependsOn": [],
