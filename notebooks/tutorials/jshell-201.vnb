      "description": "Practical: Word Frequency Counter"
    },
    {
      "id": "jshell-201-hashset",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: hash-set-unique-elements-only\n//@ description: HashSet — unique elements only\nimport java.util.HashSet;\nimport java.util.ArrayList;\nimport java.util.Arrays;\n\n// --- HashSet — unique elements only ---\n// HashSet guarantees no duplicates. Adding an element that already exists is a no-op.\n// Backed by a HashMap internally, so O(1) contains/add/remove.\n\nHashSet<String> visited = new HashSet<>();\n\nString[] urls = {\n    \"https://example.com\",\n    \"https://java.dev\",\n    \"https://example.com\",   // duplicate!\n    \"https://venus.io\",\n    \"https://java.dev\",      // duplicate!\n    \"https://openai.com\"\n};\n\nfor (String url : urls) {\n    boolean added = visited.add(url);   // returns false if already present\n    System.out.printf(\"  add %-30s → %s%n\", url, added ? \"OK\" : \"already seen\");\n}\n\nSystem.out.println(\"\\nUnique URLs visited: \" + visited.size());\nSystem.out.println(\"Contains java.dev   : \" + visited.contains(\"https://java.dev\"));\n\n// Set operations: retainAll (intersection), removeAll (difference), addAll (union)\nHashSet<Integer> setA = new HashSet<>(Arrays.asList(1, 2, 3, 4, 5));\nHashSet<Integer> setB = new HashSet<>(Arrays.asList(3, 4, 5, 6, 7));\n\nHashSet<Integer> union = new HashSet<>(setA);        union.addAll(setB);\nHashSet<Integer> intersection = new HashSet<>(setA); intersection.retainAll(setB);\nHashSet<Integer> difference = new HashSet<>(setA);   difference.removeAll(setB);\n\nSystem.out.println(\"\\nSet A        : \" + setA);\nSystem.out.println(\"Set B        : \" + setB);\nSystem.out.println(\"Union        : \" + union);\nSystem.out.println(\"Intersection : \" + intersection);\nSystem.out.println(\"A - B        : \" + difference);",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "hash-set-unique-elements-only",
      "dependsOn": [],
