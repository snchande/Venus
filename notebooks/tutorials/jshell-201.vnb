    {
      "id": "jshell-201-arrays",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: arrays\n//@ description: Arrays\nimport java.util.Arrays;\n\n// --- Arrays ---\n// Arrays have a fixed length set at creation time.\n// Access by index (0-based). Attempting to access outside bounds throws ArrayIndexOutOfBoundsException.\n\nint[] scores = {88, 42, 95, 67, 73, 55, 91};\n\nSystem.out.println(\"Length     : \" + scores.length);\nSystem.out.println(\"First      : \" + scores[0]);\nSystem.out.println(\"Last       : \" + scores[scores.length - 1]);\n\n// Arrays.sort sorts in place (modifies the original array)\nArrays.sort(scores);\nSystem.out.println(\"Sorted     : \" + Arrays.toString(scores));\n\n// Arrays.copyOfRange(arr, from, to) — to is exclusive\nint[] top3 = Arrays.copyOfRange(scores, scores.length - 3, scores.length);\nSystem.out.println(\"Top 3      : \" + Arrays.toString(top3));\n\n// 2D arrays\nint[][] matrix = {\n    {1, 2, 3},\n    {4, 5, 6},\n    {7, 8, 9}\n};\nSystem.out.println(\"matrix[1][2] = \" + matrix[1][2]);  // 6 (row 1, col 2)",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "arrays",
      "dependsOn": [],
      "pipelineSteps": [],
      "description": "Arrays"
    },
    {
      "id": "jshell-201-arraylist",
      "type": "CODE",
      "mode": "jshell",
      "source": "//@ anchor: array-list\n//@ description: ArrayList\nimport java.util.ArrayList;\nimport java.util.Collections;\n\n// --- ArrayList ---\n// A resizable array. Use when you need an ordered list that grows/shrinks dynamically.\n// ArrayList<Type> — the type parameter T must be a class (use Integer, not int).\n\nArrayList<String> fruits = new ArrayList<>();\n\n// Adding elements\nfruits.add(\"Apple\");\nfruits.add(\"Banana\");\nfruits.add(\"Cherry\");\nfruits.add(\"Mango\");\nfruits.add(1, \"Avocado\");    // insert at index 1, shifts others right\n\nSystem.out.println(\"List       : \" + fruits);\nSystem.out.println(\"Size       : \" + fruits.size());\nSystem.out.println(\"Get(2)     : \" + fruits.get(2));\nSystem.out.println(\"Contains 'Mango': \" + fruits.contains(\"Mango\"));\nSystem.out.println(\"Index of 'Apple': \" + fruits.indexOf(\"Apple\"));\n\n// Removing elements\nfruits.remove(\"Banana\");      // remove by value\nfruits.remove(0);              // remove by index\nSystem.out.println(\"After removes  : \" + fruits);\n\n// Sorting\nCollections.sort(fruits);\nSystem.out.println(\"Sorted         : \" + fruits);\n\n// Iterating with for-each\nSystem.out.print(\"For-each       : \");\nfor (String fruit : fruits) System.out.print(fruit + \" \");\nSystem.out.println();",
      "output": "",
      "returnValue": null,
      "executed": false,
      "executionCount": null,
      "error": "",
      "anchor": "array-list",
