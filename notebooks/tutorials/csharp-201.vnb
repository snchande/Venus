  "cells": [
    {
      "id": "cs201-md-1",
      "type": "MARKDOWN",
      "source": "# C# Data Processing & Pipelines\n\nThis notebook covers:\n- LINQ grouping, aggregation, and joins\n- Working with `Dictionary<K,V>` and nested collections\n- **Pipeline orchestration** using `//@ anchor:` and `//@ depends:` annotations\n\n## How Pipelines Work\n\nAnnotate C# cells just like JShell cells:\n```csharp\n//@ anchor: myStep\n// This cell can be referenced by other cells\n```\n```csharp\n//@ depends: myStep\n// Venus runs myStep first, then this cell\n```\n\nClick **Run with deps** (→ button) or use a **Pipeline cell** to orchestrate multi-cell workflows.",
      "output": "",
      "executed": false
    },
    {
      "id": "cs201-load",
      "type": "CODE",
      "mode": "csharp",
      "anchor": "cs_loadSalesData",
      "source": "//@ anchor: cs_loadSalesData\n//@ description: Step 1: Define data model and load dataset\n// Step 1: Define data model and load dataset\nrecord Sale(string Region, string Product, int Quarter, decimal Amount, int Units);\n\nvar sales = new List<Sale> {\n    new(\"North\", \"Widget A\", 1, 12400m, 124),\n    new(\"North\", \"Widget B\", 1,  8900m,  89),\n    new(\"South\", \"Widget A\", 1, 11200m, 112),\n    new(\"South\", \"Widget B\", 1,  6300m,  63),\n    new(\"North\", \"Widget A\", 2, 15600m, 156),\n    new(\"North\", \"Widget B\", 2,  9800m,  98),\n    new(\"South\", \"Widget A\", 2, 14100m, 141),\n    new(\"South\", \"Widget B\", 2,  7900m,  79),\n    new(\"North\", \"Widget A\", 3, 13800m, 138),\n    new(\"East\",  \"Widget A\", 3, 10500m, 105),\n    new(\"East\",  \"Widget B\", 3,  5600m,  56),\n    new(\"West\",  \"Widget A\", 3,  9200m,  92),\n};\n\nConsole.WriteLine($\"Loaded {sales.Count} sales records\");\nVenusTable(sales);",
      "output": "",
      "executed": false,
      "description": "Step 1: Define data model and load dataset"
    },
    {
      "id": "cs201-md-2",
      "type": "MARKDOWN",
      "source": "## Grouping and Aggregation\n\nLINQ's `GroupBy` is perfect for pivot-style analysis.",
      "output": "",
      "executed": false
    },
    {
      "id": "cs201-group",
      "type": "CODE",
      "mode": "csharp",
      "anchor": "cs_salesByRegion",
      "source": "//@ anchor: cs_salesByRegion\n//@ depends: cs_loadSalesData\n//@ description: Step 2: Aggregate by region\n// Step 2: Aggregate by region\nvar byRegion = sales\n    .GroupBy(s => s.Region)\n    .Select(g => new {\n        Region     = g.Key,\n        TotalSales = g.Sum(s => s.Amount),\n        TotalUnits = g.Sum(s => s.Units),\n        AvgDeal    = g.Average(s => s.Amount)\n    })\n    .OrderByDescending(r => r.TotalSales)\n    .ToList();\n\nConsole.WriteLine(\"Sales by region:\");\nforeach (var r in byRegion)\n    Console.WriteLine($\"  {r.Region,-8} ${r.TotalSales,10:N0}  units: {r.TotalUnits,5}  avg: ${r.AvgDeal:N0}\");",
      "output": "",
      "executed": false,
      "description": "Step 2: Aggregate by region"
    },
    {
      "id": "cs201-product",
      "type": "CODE",
      "mode": "csharp",
      "anchor": "cs_salesByProduct",
      "source": "//@ anchor: cs_salesByProduct\n//@ depends: cs_loadSalesData\n//@ description: Step 3: Aggregate by product\n// Step 3: Aggregate by product\nvar byProduct = sales\n    .GroupBy(s => s.Product)\n    .Select(g => new {\n        Product    = g.Key,\n        TotalSales = g.Sum(s => s.Amount),\n        TotalUnits = g.Sum(s => s.Units),\n        RegionCount = g.Select(s => s.Region).Distinct().Count()\n    })\n    .OrderByDescending(p => p.TotalSales)\n    .ToList();\n\nConsole.WriteLine(\"Sales by product:\");\nforeach (var p in byProduct)\n    Console.WriteLine($\"  {p.Product,-12} ${p.TotalSales,10:N0}  units: {p.TotalUnits,5}  regions: {p.RegionCount}\");",
      "output": "",
      "executed": false,
      "description": "Step 3: Aggregate by product"
    },
    {
      "id": "cs201-report",
      "type": "CODE",
      "mode": "csharp",
      "anchor": "cs_finalReport",
      "source": "//@ anchor: cs_finalReport\n//@ depends: cs_salesByRegion, cs_salesByProduct\n//@ description: Step 4: Final summary\n// Step 4: Final summary\nvar totalRevenue = sales.Sum(s => s.Amount);\nvar totalUnits   = sales.Sum(s => s.Units);\nvar topRegion    = byRegion.First().Region;\nvar topProduct   = byProduct.First().Product;\n\nVenusHtml($\"<h3>Sales Summary</h3><ul><li>Total Revenue: <strong>${totalRevenue:N0}</strong></li><li>Total Units Sold: <strong>{totalUnits:N0}</strong></li><li>Top Region: <strong>{topRegion}</strong></li><li>Top Product: <strong>{topProduct}</strong></li></ul>\");",
      "output": "",
      "executed": false,
      "description": "Step 4: Final summary"
    },
    {
      "id": "cs201-pipeline",
      "type": "CODE",
      "mode": "csharp",
      "source": "//@ pipeline: C# Sales Analysis\n//@ steps: cs_loadSalesData, cs_salesByRegion, cs_salesByProduct, cs_finalReport\n//@ description: Full sales analysis pipeline\n// Click the ▶ Run Pipeline button to execute all steps in order",
      "output": "",
      "executed": false
    }
  ],
